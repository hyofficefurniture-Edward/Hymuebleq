---
import BaseLayout from '../../layouts/BaseLayout.astro';
const pageTitle = "Minibar Hotel Chapa Nogal Ventilación | Fabricante Mobiliario Hotelero";
const pageDescription = "Minibar de hotel con chapa de nogal y sistema de ventilación térmica integrada. Reduce temperatura interna 4.5°C, prolonga vida del electrodoméstico. Fabricación a medida.";
const canonicalUrl = "/productos/minibar-hotel-chapa-nogal-ventilacion/";
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonicalPath={canonicalUrl}
>
  <!-- Schema.org JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "Minibar de Hotel con Chapa de Nogal y Sistema de Ventilación Integrado",
    "description": "Minibar de hotel con chapa de nogal y sistema de ventilación térmica integrada. Reduce temperatura interna 4.5°C, prolonga vida del electrodoméstico. Fabricación a medida.",
    "category": "Armarios y Almacenaje",
    "brand": {
      "@type": "Brand",
      "name": "HYMUEBLE"
    },
    "manufacturer": {
      "@type": "Organization",
      "name": "Hongye Furniture Group Co., Ltd."
    },
    "offers": {
      "@type": "Offer",
      "availability": "https://schema.org/InStock",
      "priceSpecification": {
        "@type": "PriceSpecification",
        "price": "Consultar",
        "priceCurrency": "USD"
      }
    }
  })}>
  </script>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {"@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://hymueble.com/"},
      {"@type": "ListItem", "position": 2, "name": "Productos", "item": "https://hymueble.com/productos/"},
      {"@type": "ListItem", "position": 3, "name": "Minibar de Hotel con Chapa de Nogal y Sistema de Ventilación Integrado"}
    ]
  })}>
  </script>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [{"@type": "Question", "name": "¿El mueble viene con el frigorífico incluido?", "acceptedAnswer": {"@type": "Answer", "text": "No, el mueble se fabrica para alojar el frigorífico que el hotel seleccione. Solicitamos la ficha técnica del modelo para ajustar el hueco interior con la holgura de ventilación correcta. Si lo prefiere, podemos gestionar la compra del electrodoméstico como servicio adicional."}}, {"@type": "Question", "name": "¿Se puede instalar en habitaciones ya construidas sin hacer obra?", "acceptedAnswer": {"@type": "Answer", "text": "Sí. La instalación eléctrica se resuelve con un cable de 2 metros con clavija estándar que se conecta a la toma de pared más cercana. El mueble apoya directamente sobre el suelo con patas niveladoras y no requiere fijación a pared."}}, {"@type": "Question", "name": "¿Qué ocurre si el frigorífico gotea o derrama líquido?", "acceptedAnswer": {"@type": "Answer", "text": "La base del hueco del frigorífico tiene un pequeño rebaje perimetral que actúa como bandeja de retención. La chapa interior está sellada con barniz impermeable para que la humedad ocasional no dañe el mueble."}}]
  })}>
  </script>

  <article class="producto-page">
    <!-- Breadcrumb -->
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <div class="breadcrumb-container">
        <a href="/">Inicio</a>
        <span aria-hidden="true">›</span>
        <a href="/productos/">Productos</a>
        <span aria-hidden="true">›</span>
        <span>Minibar de Hotel con Chapa de Nogal y Sistema de Ventilación Integrado</span>
      </div>
    </nav>

    <!-- Product Hero -->
    <div class="producto-hero">
      <div class="producto-gallery">
        <div class="gallery-main">
          <img class="gallery-main-img" src="/images/productos/prd-05/prd-05-01.jpg" alt="Producto principal" loading="eager" width="600" height="600">
          <div class="gallery-main-content" style="display:none"><h4>Minibar de Hotel con Chapa de Nogal y Sistema de Ventilación Integrado</h4>
            <p>Imagen principal del producto — 5 vistas disponibles</p>
          </div>
        </div>
        <div class="gallery-thumbs">
          <div class="gallery-thumb active"><img src="/images/productos/prd-05/prd-05-01.jpg" alt="Vista 1" loading="lazy" width="120" height="120" onclick="document.querySelector('.gallery-main-img').src='/images/productos/prd-05/prd-05-01.jpg'"></div><div class="gallery-thumb"><img src="/images/productos/prd-05/prd-05-02.jpg" alt="Vista 2" loading="lazy" width="120" height="120" onclick="document.querySelector('.gallery-main-img').src='/images/productos/prd-05/prd-05-02.jpg'"></div><div class="gallery-thumb"><img src="/images/productos/prd-05/prd-05-03.jpg" alt="Vista 3" loading="lazy" width="120" height="120" onclick="document.querySelector('.gallery-main-img').src='/images/productos/prd-05/prd-05-03.jpg'"></div><div class="gallery-thumb"><img src="/images/productos/prd-05/prd-05-04.jpg" alt="Vista 4" loading="lazy" width="120" height="120" onclick="document.querySelector('.gallery-main-img').src='/images/productos/prd-05/prd-05-04.jpg'"></div>
        </div>
      </div>

      <div class="producto-info">
        <span class="producto-categoria">Armarios y Almacenaje</span>
        <h1>Minibar de Hotel con Chapa de Nogal y Sistema de Ventilación Integrado</h1>
        <p class="producto-intro">El mueble minibar con chapa de nogal integra el frigorífico en la habitación con discreción y estilo. Su sistema de ventilación, basado en rejillas de aluminio en la base y salida trasera, crea un efecto chimenea que reduce la temperatura interna 4.5°C y alarga la vida del electrodoméstico un 35%. Un detalle técnico que el huésped no ve pero que el hotel agradece en cada revisión de mantenimiento.</p>
        <div class="producto-cta-group">
          <a href="/contacto/" class="btn-primary">📋 Solicitar cotización</a>
          <a href="/contacto/" class="btn-secondary">📞 Contactar ventas</a>
        </div>
      </div>
    </div>

    <!-- Ventajas -->
    <section class="section">
      <div class="content-container">
        <h2 class="section-title">Ventajas del producto</h2>
        <div class="ventajas-grid">
                    <div class="ventaja-item">
                        <div class="ventaja-icon">🛡️</div>
                        <div class="ventaja-content">
                            <p>El sistema de ventilación con doble rejilla (entrada inferior + salida trasera superior) genera un flujo de aire natural que mantiene el compresor del frigorífico a temperatura óptima de trabajo. Esto se traduce en un 35% más de vida útil del electrodoméstico y cero incidencias por sobrecalentamiento.</p>
                        </div>
                    </div>
                    <div class="ventaja-item">
                        <div class="ventaja-icon">📐</div>
                        <div class="ventaja-content">
                            <p>El mueble ocupa solo 65 cm de ancho y 55 cm de fondo, pero integra frigorífico, cafetera, hervidor y bandeja para servicio de té en un solo módulo vertical. Comparado con distribuir estos elementos en muebles separados, se ahorra un 18% de superficie útil en la habitación.</p>
                        </div>
                    </div>
                    <div class="ventaja-item">
                        <div class="ventaja-icon">🔧</div>
                        <div class="ventaja-content">
                            <p>La encimera es de compacto HPL antihuellas que resiste salpicaduras de café, agua y productos de limpieza sin degradarse. Los cantos redondeados evitan enganchones con la ropa o la maleta al pasar cerca del mueble.</p>
                        </div>
                    </div>
        </div>
      </div>
    </section>

    <!-- Especificaciones técnicas -->
    <section class="section">
      <div class="content-container">
        <h2 class="section-title">Especificaciones técnicas</h2>
        <div class="specs-wrapper">
          <table class="specs-table">
            <tbody>
                        <tr>
                            <td class="spec-label">Material principal</td>
                            <td class="spec-value">Chapa de nogal sobre MDF E1 hidrófugo; encimera HPL compacto 12 mm</td>
                        </tr>
                        <tr>
                            <td class="spec-label">Ventilación</td>
                            <td class="spec-value">Rejillas aluminio ranurado: entrada inferior 200×80 mm + salida trasera superior</td>
                        </tr>
                        <tr>
                            <td class="spec-label">Dimensiones</td>
                            <td class="spec-value">Ancho 650/800 mm × fondo 550 mm × alto 900/1100 mm (configurable)</td>
                        </tr>
                        <tr>
                            <td class="spec-label">Capacidad frigorífico</td>
                            <td class="spec-value">Compatible con modelos 30-40 L (Dometic, Indel B, Vitrifrigo)</td>
                        </tr>
                        <tr>
                            <td class="spec-label">Herrajes</td>
                            <td class="spec-value">Bisagras ocultas cierre suave 110°; correderas bola carga 30 kg</td>
                        </tr>
                        <tr>
                            <td class="spec-label">Instalación eléctrica</td>
                            <td class="spec-value">Pasacables ABS Ø60 mm con tapa protectora; regleta interior 3 tomas</td>
                        </tr>
                        <tr>
                            <td class="spec-label">Certificaciones</td>
                            <td class="spec-value">FSC, E1, resistencia fuego Clase B (bajo pedido)</td>
                        </tr>
                        <tr>
                            <td class="spec-label">Garantía</td>
                            <td class="spec-value">5 años estructura, 2 años herrajes</td>
                        </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- Aplicaciones -->
    <section class="section">
      <div class="content-container">
        <h2 class="section-title">Aplicaciones en proyectos hoteleros</h2>
        <div class="usos-grid">
                        <div class="uso-card">
                            <span class="uso-num">01</span>
                            <p>Habitación estándar hotel 3-4 estrellas: módulo compacto de 65 cm junto al armario o en zona de entrada, agrupando todas las funciones de hospitalidad en un solo punto.</p>
                        </div>
                        <div class="uso-card">
                            <span class="uso-num">02</span>
                            <p>Suite ejecutiva: módulo ampliado de 80 cm con doble puerta, cajón para tés y cafés, y bandeja extraíble que funciona como superficie de trabajo adicional para el huésped de negocios.</p>
                        </div>
                        <div class="uso-card">
                            <span class="uso-num">03</span>
                            <p>Apartahotel: versión con mayor fondo (600 mm) y frigorífico de 40 L, adaptada a estancias de media y larga duración donde el huésped necesita más capacidad de nevera.</p>
                        </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="section">
      <div class="content-container">
        <h2 class="section-title">Preguntas frecuentes</h2>
        <div class="faq-list">
                    <div class="faq-item">
                        <button class="faq-question" onclick="this.parentElement.classList.toggle('open')">
                            <span>¿El mueble viene con el frigorífico incluido?</span>
                            <span class="faq-arrow">+</span>
                        </button>
                        <div class="faq-answer">
                            <p>No, el mueble se fabrica para alojar el frigorífico que el hotel seleccione. Solicitamos la ficha técnica del modelo para ajustar el hueco interior con la holgura de ventilación correcta. Si lo prefiere, podemos gestionar la compra del electrodoméstico como servicio adicional.</p>
                        </div>
                    </div>
                    <div class="faq-item">
                        <button class="faq-question" onclick="this.parentElement.classList.toggle('open')">
                            <span>¿Se puede instalar en habitaciones ya construidas sin hacer obra?</span>
                            <span class="faq-arrow">+</span>
                        </button>
                        <div class="faq-answer">
                            <p>Sí. La instalación eléctrica se resuelve con un cable de 2 metros con clavija estándar que se conecta a la toma de pared más cercana. El mueble apoya directamente sobre el suelo con patas niveladoras y no requiere fijación a pared.</p>
                        </div>
                    </div>
                    <div class="faq-item">
                        <button class="faq-question" onclick="this.parentElement.classList.toggle('open')">
                            <span>¿Qué ocurre si el frigorífico gotea o derrama líquido?</span>
                            <span class="faq-arrow">+</span>
                        </button>
                        <div class="faq-answer">
                            <p>La base del hueco del frigorífico tiene un pequeño rebaje perimetral que actúa como bandeja de retención. La chapa interior está sellada con barniz impermeable para que la humedad ocasional no dañe el mueble.</p>
                        </div>
                    </div>
        </div>
      </div>
    </section>

    <!-- CTA final -->
    <section class="cta-section">
      <div class="content-container">
        <h2>Solicite una cotización para su proyecto</h2>
        <p>Respondemos en menos de 24 horas con presupuesto detallado, planos técnicos y muestras de materiales.</p>
        <a href="/contacto/" class="btn-primary">📋 Solicitar cotización ahora</a>
      </div>
    </section>
  </article>
</BaseLayout>

<style>
  .producto-page {
    font-family: var(--font-body, -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif);
    color: var(--color-text, #2C2416);
    background: var(--color-bg, #FDFCF9);
    line-height: 1.7;
  }

  /* Breadcrumb */
  .breadcrumb {
    background: var(--color-surface, #FFFFFF);
    border-bottom: 1px solid var(--color-border, #E8E3D9);
    padding: 12px 0;
  }
  .breadcrumb-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: var(--color-text-light, #6B6358);
  }
  .breadcrumb a {
    color: var(--color-text-light, #6B6358);
    text-decoration: none;
  }
  .breadcrumb a:hover { color: var(--color-primary, #1a3a5c); }
  .breadcrumb span { color: var(--color-text, #2C2416); font-weight: 500; }

  /* Producto Hero */
  .producto-hero {
    max-width: 1200px;
    margin: 0 auto;
    padding: 40px 24px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: start;
  }

  .gallery-main {
    background: #EEF0F3;
    border-radius: 8px;
    aspect-ratio: 4/3;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-light, #6B6358);
    font-size: 15px;
    text-align: center;
    padding: 40px;
  }
  .gallery-main-content h4 {
    font-size: 20px;
    margin-bottom: 8px;
    color: var(--color-primary, #1a3a5c);
  }
  .gallery-main-content p {
    font-size: 14px;
  }
  .gallery-thumbs {
    display: flex;
    gap: 8px;
    margin-top: 12px;
  }
  .gallery-thumb {
    width: 72px;
    height: 54px;
    background: #EEF0F3;
    border-radius: 4px;
    border: 2px solid transparent;
    cursor: pointer;
    transition: border-color 0.2s;
  }
  .gallery-thumb:hover, .gallery-thumb.active {
    border-color: var(--color-accent, #c9a962);
  }

  .producto-info h1 {
    font-size: 32px;
    line-height: 1.25;
    color: var(--color-text, #2C2416);
    margin-bottom: 12px;
    letter-spacing: -0.3px;
  }
  .producto-categoria {
    display: inline-block;
    background: #EEF0F3;
    color: var(--color-primary, #1a3a5c);
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    padding: 4px 12px;
    border-radius: 100px;
    margin-bottom: 16px;
  }
  .producto-intro {
    font-size: 16px;
    color: var(--color-text-light, #6B6358);
    line-height: 1.8;
    margin-bottom: 24px;
  }
  .producto-cta-group {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }
  .btn-primary {
    background: var(--color-primary, #1a3a5c);
    color: #fff;
    border: none;
    padding: 14px 32px;
    font-size: 15px;
    font-weight: 600;
    border-radius: 8px;
    cursor: pointer;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: background 0.2s;
  }
  .btn-primary:hover { background: #142d4a; }
  .btn-secondary {
    background: var(--color-surface, #FFFFFF);
    color: var(--color-primary, #1a3a5c);
    border: 2px solid var(--color-border, #E8E3D9);
    padding: 14px 32px;
    font-size: 15px;
    font-weight: 600;
    border-radius: 8px;
    cursor: pointer;
    text-decoration: none;
    transition: all 0.2s;
  }
  .btn-secondary:hover { border-color: var(--color-primary, #1a3a5c); }

  /* Secciones */
  .content-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }
  .section {
    padding: 48px 0;
    border-top: 1px solid var(--color-border, #E8E3D9);
  }
  .section-title {
    font-size: 24px;
    color: var(--color-text, #2C2416);
    margin-bottom: 28px;
    letter-spacing: -0.2px;
  }

  /* Ventajas */
  .ventajas-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }
  .ventaja-item {
    display: flex;
    gap: 16px;
    align-items: flex-start;
    padding: 24px;
    background: var(--color-surface, #FFFFFF);
    border-radius: 8px;
    box-shadow: 0 2px 12px rgba(44,36,22,0.06);
  }
  .ventaja-icon {
    font-size: 28px;
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #EEF0F3;
    border-radius: 8px;
  }
  .ventaja-content p {
    font-size: 14.5px;
    color: var(--color-text-light, #6B6358);
    line-height: 1.75;
  }

  /* Specs Table */
  .specs-wrapper {
    background: var(--color-surface, #FFFFFF);
    border-radius: 8px;
    box-shadow: 0 2px 12px rgba(44,36,22,0.06);
    overflow: hidden;
  }
  .specs-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 14.5px;
  }
  .specs-table td {
    padding: 14px 20px;
    border-bottom: 1px solid var(--color-border, #E8E3D9);
  }
  .spec-label {
    font-weight: 600;
    color: var(--color-text, #2C2416);
    width: 30%;
  }
  .spec-value {
    color: var(--color-text-light, #6B6358);
  }

  /* Usos */
  .usos-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .uso-card {
    padding: 28px 24px;
    background: var(--color-surface, #FFFFFF);
    border-radius: 8px;
    box-shadow: 0 2px 12px rgba(44,36,22,0.06);
    position: relative;
  }
  .uso-num {
    font-size: 36px;
    color: #D8DDE3;
    font-weight: bold;
    line-height: 1;
    margin-bottom: 12px;
    display: block;
  }
  .uso-card p {
    font-size: 14px;
    color: var(--color-text-light, #6B6358);
    line-height: 1.7;
  }

  /* FAQ */
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .faq-item {
    border: 1px solid var(--color-border, #E8E3D9);
    border-radius: 8px;
    background: var(--color-surface, #FFFFFF);
    overflow: hidden;
  }
  .faq-question {
    width: 100%;
    background: none;
    border: none;
    padding: 18px 24px;
    font-size: 15px;
    font-weight: 600;
    color: var(--color-text, #2C2416);
    text-align: left;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
  }
  .faq-arrow {
    font-size: 20px;
    font-weight: 300;
    color: var(--color-text-light, #6B6358);
    transition: transform 0.3s;
    flex-shrink: 0;
  }
  .faq-item.open .faq-arrow {
    transform: rotate(45deg);
  }
  .faq-answer {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
  }
  .faq-item.open .faq-answer {
    max-height: 500px;
  }
  .faq-answer p {
    padding: 0 24px 18px;
    font-size: 14.5px;
    color: var(--color-text-light, #6B6358);
    line-height: 1.75;
  }

  /* CTA */
  .cta-section {
    padding: 48px 0;
    border-top: 1px solid var(--color-border, #E8E3D9);
    text-align: center;
  }
  .cta-section h2 {
    font-size: 22px;
    margin-bottom: 12px;
  }
  .cta-section p {
    color: var(--color-text-light, #6B6358);
    margin-bottom: 24px;
  }

  @media (max-width: 768px) {
    .producto-hero {
      grid-template-columns: 1fr;
      gap: 24px;
    }
    .ventajas-grid {
      grid-template-columns: 1fr;
    }
    .usos-grid {
      grid-template-columns: 1fr;
    }
    .producto-info h1 {
      font-size: 24px;
    }
  }

    .gallery-main-img {
      width: 100%;
      height: 100%;
      object-fit: contain;
      position: absolute;
      top: 0;
      left: 0;
    }
    .gallery-thumb img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      border-radius: 4px;
    }
  </style>

<script>
  document.querySelectorAll('.faq-question').forEach(btn => {
    btn.addEventListener('click', () => {
      btn.closest('.faq-item')?.classList.toggle('open');
    });
  });
</script>
