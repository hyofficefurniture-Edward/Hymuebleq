---
import BaseLayout from '../../layouts/BaseLayout.astro';
const pageTitle = "Mesa Banquetes Plegable Chapa Madera | Equipamiento Hotelero Salones";
const pageDescription = "Mesa de banquetes plegable con tablero de chapa de madera y sillas apilables. Sistema plegado rápido, almacenaje compacto. Fabricación para hoteles y salones de eventos.";
const canonicalUrl = "/productos/mesa-banquetes-plegable-chapa-sillas/";
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonicalPath={canonicalUrl}
>
  <!-- Schema.org JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "Mesa de Banquetes Plegable con Tablero de Chapa y Sillas Apilables",
    "description": "Mesa de banquetes plegable con tablero de chapa de madera y sillas apilables. Sistema plegado rápido, almacenaje compacto. Fabricación para hoteles y salones de eventos.",
    "category": "Mesas",
    "brand": {
      "@type": "Brand",
      "name": "HYMUEBLE"
    },
    "manufacturer": {
      "@type": "Organization",
      "name": "Hongye Furniture Group Co., Ltd."
    },
    "offers": {
      "@type": "Offer",
      "availability": "https://schema.org/InStock",
      "priceSpecification": {
        "@type": "PriceSpecification",
        "price": "Consultar",
        "priceCurrency": "USD"
      }
    }
  })}>
  </script>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {"@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://hymueble.com/"},
      {"@type": "ListItem", "position": 2, "name": "Productos", "item": "https://hymueble.com/productos/"},
      {"@type": "ListItem", "position": 3, "name": "Mesa de Banquetes Plegable con Tablero de Chapa y Sillas Apilables"}
    ]
  })}>
  </script>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [{"@type": "Question", "name": "¿Se pueden pedir manteles a medida?", "acceptedAnswer": {"@type": "Answer", "text": "Sí, ofrecemos servicio de mantelería a medida como complemento. Solo necesitamos las dimensiones exactas de la mesa y la caída deseada. Se confeccionan en tejido poliéster ignífugo lavable a 60°C."}}, {"@type": "Question", "name": "¿Cuántas mesas caben en un contenedor de 20 pies?", "acceptedAnswer": {"@type": "Answer", "text": "Aproximadamente 110-130 mesas plegadas, en función del tamaño exacto del modelo. El equipo de logística calcula la cubicación óptima para cada pedido y presenta el plan de carga antes de confirmar el envío."}}, {"@type": "Question", "name": "¿El tablero se marca si se apoya una bandeja caliente directamente?", "acceptedAnswer": {"@type": "Answer", "text": "No. El barniz de poliuretano de grado contract soporta temperatura superficial de hasta 85°C durante un máximo de 15 minutos sin alterarse. Para mayor seguridad, recomendamos el uso de salvamanteles, que también podemos suministrar."}}]
  })}>
  </script>

  <article class="producto-page">
    <!-- Breadcrumb -->
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <div class="breadcrumb-container">
        <a href="/">Inicio</a>
        <span aria-hidden="true">›</span>
        <a href="/productos/">Productos</a>
        <span aria-hidden="true">›</span>
        <span>Mesa de Banquetes Plegable con Tablero de Chapa y Sillas Apilables</span>
      </div>
    </nav>

    <!-- Product Hero -->
    <div class="producto-hero">
      <div class="producto-gallery">
        <div class="gallery-main">
          <img class="gallery-main-img" src="/images/productos/prd-07/prd-07-01.jpg" alt="Producto principal" loading="eager" width="600" height="600">
          <div class="gallery-main-content" style="display:none"><h4>Mesa de Banquetes Plegable con Tablero de Chapa y Sillas Apilables</h4>
            <p>Imagen principal del producto — 4 vistas disponibles</p>
          </div>
        </div>
        <div class="gallery-thumbs">
          <div class="gallery-thumb active"><img src="/images/productos/prd-07/prd-07-01.jpg" alt="Vista 1" loading="lazy" width="120" height="120" onclick="document.querySelector('.gallery-main-img').src='/images/productos/prd-07/prd-07-01.jpg'"></div><div class="gallery-thumb"><img src="/images/productos/prd-07/prd-07-02.jpg" alt="Vista 2" loading="lazy" width="120" height="120" onclick="document.querySelector('.gallery-main-img').src='/images/productos/prd-07/prd-07-02.jpg'"></div><div class="gallery-thumb"><img src="/images/productos/prd-07/prd-07-03.jpg" alt="Vista 3" loading="lazy" width="120" height="120" onclick="document.querySelector('.gallery-main-img').src='/images/productos/prd-07/prd-07-03.jpg'"></div><div class="gallery-thumb"><img src="/images/productos/prd-07/prd-07-04.jpg" alt="Vista 4" loading="lazy" width="120" height="120" onclick="document.querySelector('.gallery-main-img').src='/images/productos/prd-07/prd-07-04.jpg'"></div>
        </div>
      </div>

      <div class="producto-info">
        <span class="producto-categoria">Mesas</span>
        <h1>Mesa de Banquetes Plegable con Tablero de Chapa y Sillas Apilables</h1>
        <p class="producto-intro">La mesa de banquetes plegable con tablero de chapa de madera está pensada para salones que cambian de configuración varias veces por semana. Se pliega en menos de 30 segundos sin herramientas, se almacena verticalmente en carros que ocupan un 70% menos de espacio que las mesas fijas, y al desplegarse ofrece un aspecto impecable que no delata su uso intensivo.</p>
        <div class="producto-cta-group">
          <a href="/contacto/" class="btn-primary">📋 Solicitar cotización</a>
          <a href="/contacto/" class="btn-secondary">📞 Contactar ventas</a>
        </div>
      </div>
    </div>

    <!-- Ventajas -->
    <section class="section">
      <div class="content-container">
        <h2 class="section-title">Ventajas del producto</h2>
        <div class="ventajas-grid">
                    <div class="ventaja-item">
                        <div class="ventaja-icon">🛡️</div>
                        <div class="ventaja-content">
                            <p>El mecanismo de plegado con bloqueo de seguridad permite a una sola persona montar o recoger cada mesa en 30 segundos. Las patas se abren y cierran con un solo gesto, y el sistema anti-apertura accidental evita sustos durante el transporte. Un carro estándar almacena 12 mesas plegadas ocupando solo 1 metro cuadrado de superficie.</p>
                        </div>
                    </div>
                    <div class="ventaja-item">
                        <div class="ventaja-icon">📐</div>
                        <div class="ventaja-content">
                            <p>El tablero de 25 mm con chapa de madera y canto de ABS de 2 mm resiste arañazos de cubiertos y calor de fuentes sin marcar. Las patas de acero llevan tacos antideslizantes que no rayan el suelo y amortiguan el ruido al recolocar las mesas durante el montaje de la sala.</p>
                        </div>
                    </div>
                    <div class="ventaja-item">
                        <div class="ventaja-icon">🔧</div>
                        <div class="ventaja-content">
                            <p>Las sillas apilables del conjunto pesan 5.2 kg y se pueden apilar hasta 10 unidades. El respaldo elástico bascula 8° hacia atrás, ofreciendo una ligera reclinación que los comensales agradecen en banquetes, conferencias y cenas de gala que se prolongan más de dos horas.</p>
                        </div>
                    </div>
        </div>
      </div>
    </section>

    <!-- Especificaciones técnicas -->
    <section class="section">
      <div class="content-container">
        <h2 class="section-title">Especificaciones técnicas</h2>
        <div class="specs-wrapper">
          <table class="specs-table">
            <tbody>
                        <tr>
                            <td class="spec-label">Mesa - tablero</td>
                            <td class="spec-value">Chapa madera sobre MDF E1 25 mm, canto ABS 2 mm, barniz mate</td>
                        </tr>
                        <tr>
                            <td class="spec-label">Mesa - estructura</td>
                            <td class="spec-value">Acero tubular 30×30 mm con pintura epoxi; mecanismo plegado con bloqueo</td>
                        </tr>
                        <tr>
                            <td class="spec-label">Mesa - dimensiones</td>
                            <td class="spec-value">180 × 80 × 75 cm (plegada: 180 × 80 × 12 cm); otros tamaños disponibles</td>
                        </tr>
                        <tr>
                            <td class="spec-label">Silla - estructura</td>
                            <td class="spec-value">Acero tubular Ø22 mm; apilable hasta 10 uds.; peso 5.2 kg</td>
                        </tr>
                        <tr>
                            <td class="spec-label">Silla - asiento y respaldo</td>
                            <td class="spec-value">Polipropileno inyectado antichoque; respaldo basculante 8°</td>
                        </tr>
                        <tr>
                            <td class="spec-label">Carga máxima</td>
                            <td class="spec-value">Mesa 150 kg distribuidos; silla 130 kg</td>
                        </tr>
                        <tr>
                            <td class="spec-label">Certificaciones</td>
                            <td class="spec-value">EN 15373 nivel 3, EN 581 contract, resistencia fuego M2</td>
                        </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- Aplicaciones -->
    <section class="section">
      <div class="content-container">
        <h2 class="section-title">Aplicaciones en proyectos hoteleros</h2>
        <div class="usos-grid">
                        <div class="uso-card">
                            <span class="uso-num">01</span>
                            <p>Salón de banquetes polivalente: configuración rápida para bodas, conferencias y cenas de empresa. El mismo salón pasa de reunión de 100 personas a banquete de 150 en menos de una hora con el equipo de montaje.</p>
                        </div>
                        <div class="uso-card">
                            <span class="uso-num">02</span>
                            <p>Terraza de eventos al aire libre: las mesas con barniz marino y herrajes de acero inoxidable resisten la humedad y el sol directo sin deformarse ni perder color.</p>
                        </div>
                        <div class="uso-card">
                            <span class="uso-num">03</span>
                            <p>Sala de reuniones flexible: formato rectangular para juntas de trabajo por la mañana y disposición en U para formación por la tarde, con el mismo juego de mesas.</p>
                        </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="section">
      <div class="content-container">
        <h2 class="section-title">Preguntas frecuentes</h2>
        <div class="faq-list">
                    <div class="faq-item">
                        <button class="faq-question" onclick="this.parentElement.classList.toggle('open')">
                            <span>¿Se pueden pedir manteles a medida?</span>
                            <span class="faq-arrow">+</span>
                        </button>
                        <div class="faq-answer">
                            <p>Sí, ofrecemos servicio de mantelería a medida como complemento. Solo necesitamos las dimensiones exactas de la mesa y la caída deseada. Se confeccionan en tejido poliéster ignífugo lavable a 60°C.</p>
                        </div>
                    </div>
                    <div class="faq-item">
                        <button class="faq-question" onclick="this.parentElement.classList.toggle('open')">
                            <span>¿Cuántas mesas caben en un contenedor de 20 pies?</span>
                            <span class="faq-arrow">+</span>
                        </button>
                        <div class="faq-answer">
                            <p>Aproximadamente 110-130 mesas plegadas, en función del tamaño exacto del modelo. El equipo de logística calcula la cubicación óptima para cada pedido y presenta el plan de carga antes de confirmar el envío.</p>
                        </div>
                    </div>
                    <div class="faq-item">
                        <button class="faq-question" onclick="this.parentElement.classList.toggle('open')">
                            <span>¿El tablero se marca si se apoya una bandeja caliente directamente?</span>
                            <span class="faq-arrow">+</span>
                        </button>
                        <div class="faq-answer">
                            <p>No. El barniz de poliuretano de grado contract soporta temperatura superficial de hasta 85°C durante un máximo de 15 minutos sin alterarse. Para mayor seguridad, recomendamos el uso de salvamanteles, que también podemos suministrar.</p>
                        </div>
                    </div>
        </div>
      </div>
    </section>

    <!-- CTA final -->
    <section class="cta-section">
      <div class="content-container">
        <h2>Solicite una cotización para su proyecto</h2>
        <p>Respondemos en menos de 24 horas con presupuesto detallado, planos técnicos y muestras de materiales.</p>
        <a href="/contacto/" class="btn-primary">📋 Solicitar cotización ahora</a>
      </div>
    </section>
  </article>
</BaseLayout>

<style>
  .producto-page {
    font-family: var(--font-body, -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif);
    color: var(--color-text, #2C2416);
    background: var(--color-bg, #FDFCF9);
    line-height: 1.7;
  }

  /* Breadcrumb */
  .breadcrumb {
    background: var(--color-surface, #FFFFFF);
    border-bottom: 1px solid var(--color-border, #E8E3D9);
    padding: 12px 0;
  }
  .breadcrumb-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: var(--color-text-light, #6B6358);
  }
  .breadcrumb a {
    color: var(--color-text-light, #6B6358);
    text-decoration: none;
  }
  .breadcrumb a:hover { color: var(--color-primary, #1a3a5c); }
  .breadcrumb span { color: var(--color-text, #2C2416); font-weight: 500; }

  /* Producto Hero */
  .producto-hero {
    max-width: 1200px;
    margin: 0 auto;
    padding: 40px 24px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: start;
  }

  .gallery-main {
    background: #EEF0F3;
    border-radius: 8px;
    aspect-ratio: 4/3;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-light, #6B6358);
    font-size: 15px;
    text-align: center;
    padding: 40px;
  }
  .gallery-main-content h4 {
    font-size: 20px;
    margin-bottom: 8px;
    color: var(--color-primary, #1a3a5c);
  }
  .gallery-main-content p {
    font-size: 14px;
  }
  .gallery-thumbs {
    display: flex;
    gap: 8px;
    margin-top: 12px;
  }
  .gallery-thumb {
    width: 72px;
    height: 54px;
    background: #EEF0F3;
    border-radius: 4px;
    border: 2px solid transparent;
    cursor: pointer;
    transition: border-color 0.2s;
  }
  .gallery-thumb:hover, .gallery-thumb.active {
    border-color: var(--color-accent, #c9a962);
  }

  .producto-info h1 {
    font-size: 32px;
    line-height: 1.25;
    color: var(--color-text, #2C2416);
    margin-bottom: 12px;
    letter-spacing: -0.3px;
  }
  .producto-categoria {
    display: inline-block;
    background: #EEF0F3;
    color: var(--color-primary, #1a3a5c);
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    padding: 4px 12px;
    border-radius: 100px;
    margin-bottom: 16px;
  }
  .producto-intro {
    font-size: 16px;
    color: var(--color-text-light, #6B6358);
    line-height: 1.8;
    margin-bottom: 24px;
  }
  .producto-cta-group {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }
  .btn-primary {
    background: var(--color-primary, #1a3a5c);
    color: #fff;
    border: none;
    padding: 14px 32px;
    font-size: 15px;
    font-weight: 600;
    border-radius: 8px;
    cursor: pointer;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: background 0.2s;
  }
  .btn-primary:hover { background: #142d4a; }
  .btn-secondary {
    background: var(--color-surface, #FFFFFF);
    color: var(--color-primary, #1a3a5c);
    border: 2px solid var(--color-border, #E8E3D9);
    padding: 14px 32px;
    font-size: 15px;
    font-weight: 600;
    border-radius: 8px;
    cursor: pointer;
    text-decoration: none;
    transition: all 0.2s;
  }
  .btn-secondary:hover { border-color: var(--color-primary, #1a3a5c); }

  /* Secciones */
  .content-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }
  .section {
    padding: 48px 0;
    border-top: 1px solid var(--color-border, #E8E3D9);
  }
  .section-title {
    font-size: 24px;
    color: var(--color-text, #2C2416);
    margin-bottom: 28px;
    letter-spacing: -0.2px;
  }

  /* Ventajas */
  .ventajas-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }
  .ventaja-item {
    display: flex;
    gap: 16px;
    align-items: flex-start;
    padding: 24px;
    background: var(--color-surface, #FFFFFF);
    border-radius: 8px;
    box-shadow: 0 2px 12px rgba(44,36,22,0.06);
  }
  .ventaja-icon {
    font-size: 28px;
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #EEF0F3;
    border-radius: 8px;
  }
  .ventaja-content p {
    font-size: 14.5px;
    color: var(--color-text-light, #6B6358);
    line-height: 1.75;
  }

  /* Specs Table */
  .specs-wrapper {
    background: var(--color-surface, #FFFFFF);
    border-radius: 8px;
    box-shadow: 0 2px 12px rgba(44,36,22,0.06);
    overflow: hidden;
  }
  .specs-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 14.5px;
  }
  .specs-table td {
    padding: 14px 20px;
    border-bottom: 1px solid var(--color-border, #E8E3D9);
  }
  .spec-label {
    font-weight: 600;
    color: var(--color-text, #2C2416);
    width: 30%;
  }
  .spec-value {
    color: var(--color-text-light, #6B6358);
  }

  /* Usos */
  .usos-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .uso-card {
    padding: 28px 24px;
    background: var(--color-surface, #FFFFFF);
    border-radius: 8px;
    box-shadow: 0 2px 12px rgba(44,36,22,0.06);
    position: relative;
  }
  .uso-num {
    font-size: 36px;
    color: #D8DDE3;
    font-weight: bold;
    line-height: 1;
    margin-bottom: 12px;
    display: block;
  }
  .uso-card p {
    font-size: 14px;
    color: var(--color-text-light, #6B6358);
    line-height: 1.7;
  }

  /* FAQ */
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .faq-item {
    border: 1px solid var(--color-border, #E8E3D9);
    border-radius: 8px;
    background: var(--color-surface, #FFFFFF);
    overflow: hidden;
  }
  .faq-question {
    width: 100%;
    background: none;
    border: none;
    padding: 18px 24px;
    font-size: 15px;
    font-weight: 600;
    color: var(--color-text, #2C2416);
    text-align: left;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
  }
  .faq-arrow {
    font-size: 20px;
    font-weight: 300;
    color: var(--color-text-light, #6B6358);
    transition: transform 0.3s;
    flex-shrink: 0;
  }
  .faq-item.open .faq-arrow {
    transform: rotate(45deg);
  }
  .faq-answer {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
  }
  .faq-item.open .faq-answer {
    max-height: 500px;
  }
  .faq-answer p {
    padding: 0 24px 18px;
    font-size: 14.5px;
    color: var(--color-text-light, #6B6358);
    line-height: 1.75;
  }

  /* CTA */
  .cta-section {
    padding: 48px 0;
    border-top: 1px solid var(--color-border, #E8E3D9);
    text-align: center;
  }
  .cta-section h2 {
    font-size: 22px;
    margin-bottom: 12px;
  }
  .cta-section p {
    color: var(--color-text-light, #6B6358);
    margin-bottom: 24px;
  }

  @media (max-width: 768px) {
    .producto-hero {
      grid-template-columns: 1fr;
      gap: 24px;
    }
    .ventajas-grid {
      grid-template-columns: 1fr;
    }
    .usos-grid {
      grid-template-columns: 1fr;
    }
    .producto-info h1 {
      font-size: 24px;
    }
  }

    .gallery-main-img {
      width: 100%;
      height: 100%;
      object-fit: contain;
      position: absolute;
      top: 0;
      left: 0;
    }
    .gallery-thumb img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      border-radius: 4px;
    }
  </style>

<script>
  document.querySelectorAll('.faq-question').forEach(btn => {
    btn.addEventListener('click', () => {
      btn.closest('.faq-item')?.classList.toggle('open');
    });
  });
</script>
