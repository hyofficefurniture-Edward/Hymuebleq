---
import BaseLayout from '../../layouts/BaseLayout.astro';
const pageTitle = "Mesa Sillas Restaurante Hotel Chapa Madera | Mobiliario Hostelería";
const pageDescription = "Conjunto de mesa y sillas para restaurante de hotel con chapa de madera. Diseño apilable, resistente a uso intensivo. Fabricación a medida para cadenas hoteleras.";
const canonicalUrl = "/productos/mesa-sillas-restaurante-hotel-chapa-madera/";
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonicalPath={canonicalUrl}
>
  <!-- Schema.org JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "Conjunto de Mesa y Sillas para Restaurante de Hotel con Chapa de Madera",
    "description": "Conjunto de mesa y sillas para restaurante de hotel con chapa de madera. Diseño apilable, resistente a uso intensivo. Fabricación a medida para cadenas hoteleras.",
    "category": "Mesas",
    "brand": {
      "@type": "Brand",
      "name": "HYMUEBLE"
    },
    "manufacturer": {
      "@type": "Organization",
      "name": "Hongye Furniture Group Co., Ltd."
    },
    "offers": {
      "@type": "Offer",
      "availability": "https://schema.org/InStock",
      "priceSpecification": {
        "@type": "PriceSpecification",
        "price": "Consultar",
        "priceCurrency": "USD"
      }
    }
  })}>
  </script>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {"@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://hymueble.com/"},
      {"@type": "ListItem", "position": 2, "name": "Productos", "item": "https://hymueble.com/productos/"},
      {"@type": "ListItem", "position": 3, "name": "Conjunto de Mesa y Sillas para Restaurante de Hotel con Chapa de Madera"}
    ]
  })}>
  </script>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [{"@type": "Question", "name": "¿Las sillas vienen montadas o hay que ensamblarlas?", "acceptedAnswer": {"@type": "Answer", "text": "Llegan completamente montadas y listas para usar. Cada silla se envuelve individualmente con protección de esquinas para que el transporte no deje ninguna marca."}}, {"@type": "Question", "name": "¿Se puede pedir la mesa con sistema de extensión?", "acceptedAnswer": {"@type": "Answer", "text": "Sí. Bajo pedido fabricamos mesas de restaurante con 1 o 2 extensiones laterales de 30 cm cada una, ocultas bajo el sobre. Es una opción muy demandada por hoteles que usan el mismo espacio para desayuno buffet y cenas de gala."}}, {"@type": "Question", "name": "¿Qué mantenimiento requiere el tapizado de las sillas?", "acceptedAnswer": {"@type": "Answer", "text": "Limpieza diaria con paño húmedo y jabón neutro. Recomendamos una limpieza profesional con espuma seca cada 4 meses en temporada alta. El tapizado está diseñado para durar 3-4 años en uso intensivo antes de necesitar retapizado."}}]
  })}>
  </script>

  <article class="producto-page">
    <!-- Breadcrumb -->
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <div class="breadcrumb-container">
        <a href="/">Inicio</a>
        <span aria-hidden="true">›</span>
        <a href="/productos/">Productos</a>
        <span aria-hidden="true">›</span>
        <span>Conjunto de Mesa y Sillas para Restaurante de Hotel con Chapa de Madera</span>
      </div>
    </nav>

    <!-- Product Hero -->
    <div class="producto-hero">
      <div class="producto-gallery">
        <div class="gallery-main">
          <img class="gallery-main-img" src="/images/productos/prd-06/prd-06-01.jpg" alt="Conjunto de Mesa y Sillas para Restaurante de" loading="eager" width="600" height="600">
          <div class="gallery-main-content" style="display:none"><h4>Conjunto de Mesa y Sillas para Restaurante de Hotel con Chapa de Madera</h4>
            <p>Imagen principal del producto — 5 vistas disponibles</p>
          </div>
        </div>
        <div class="gallery-thumbs">
          <div class="gallery-thumb active"><img src="/images/productos/prd-06/prd-06-01.jpg" alt="Conjunto de Mesa y Sillas - vista 1 de 5" loading="lazy" width="120" height="120" onclick="document.querySelector('.gallery-main-img').src='/images/productos/prd-06/prd-06-01.jpg'"></div><div class="gallery-thumb"><img src="/images/productos/prd-06/prd-06-02.jpg" alt="Conjunto de Mesa y Sillas - vista 2 de 5" loading="lazy" width="120" height="120" onclick="document.querySelector('.gallery-main-img').src='/images/productos/prd-06/prd-06-02.jpg'"></div><div class="gallery-thumb"><img src="/images/productos/prd-06/prd-06-03.jpg" alt="Conjunto de Mesa y Sillas - vista 3 de 5" loading="lazy" width="120" height="120" onclick="document.querySelector('.gallery-main-img').src='/images/productos/prd-06/prd-06-03.jpg'"></div><div class="gallery-thumb"><img src="/images/productos/prd-06/prd-06-04.jpg" alt="Conjunto de Mesa y Sillas - vista 4 de 5" loading="lazy" width="120" height="120" onclick="document.querySelector('.gallery-main-img').src='/images/productos/prd-06/prd-06-04.jpg'"></div><div class="gallery-thumb"><img src="/images/productos/prd-06/prd-06-05.jpg" alt="Conjunto de Mesa y Sillas - vista 5 de 5" loading="lazy" width="120" height="120" onclick="document.querySelector('.gallery-main-img').src='/images/productos/prd-06/prd-06-05.jpg'"></div>
        </div>
      </div>

      <div class="producto-info">
        <span class="producto-categoria">Mesas</span>
        <h1>Conjunto de Mesa y Sillas para Restaurante de Hotel con Chapa de Madera</h1>
        <p class="producto-intro">El conjunto de mesa y sillas para restaurante hotelero está diseñado para resistir el ritmo de tres servicios diarios sin perder presencia. La mesa, con sobre de chapa de madera y canto de aluminio, soporta sin deformarse el calor de los platos, las manchas de vino y los productos de limpieza más exigentes. Las sillas, apilables y ligeras, agilizan la reposición de la sala entre servicio y servicio.</p>
        <div class="producto-cta-group">
          <a href="/contacto/" class="btn-primary">📋 Solicitar cotización</a>
          <a href="/contacto/" class="btn-secondary">📞 Contactar ventas</a>
        </div>
      </div>
    </div>

    <!-- Ventajas -->
    <section class="section">
      <div class="content-container">
        <h2 class="section-title">Ventajas del producto</h2>
        <div class="ventajas-grid">
                    <div class="ventaja-item">
                        <div class="ventaja-icon">🛡️</div>
                        <div class="ventaja-content">
                            <p>El sobre de la mesa incorpora un canto de aluminio anodizado de 3 mm que protege el perímetro contra golpes de bandeja y carros de servicio. Los ensayos internos confirman que la mesa mantiene su integridad estructural tras 8.000 ciclos de limpieza con productos de uso común en hostelería.</p>
                        </div>
                    </div>
                    <div class="ventaja-item">
                        <div class="ventaja-icon">📐</div>
                        <div class="ventaja-content">
                            <p>Las sillas pesan solo 4.8 kg, lo que permite a una persona mover y apilar 6 unidades en menos de 2 minutos. Esta agilidad es fundamental en restaurantes que cambian la configuración de la sala entre desayuno, almuerzo y cena con tiempos de margen ajustados.</p>
                        </div>
                    </div>
                    <div class="ventaja-item">
                        <div class="ventaja-icon">🔧</div>
                        <div class="ventaja-content">
                            <p>El tapizado de las sillas lleva un tratamiento hidrófugo que convierte los líquidos derramados en gotas que resbalan sin penetrar en la espuma. Entre servicio y servicio, un paño húmedo basta para dejar el asiento listo para el siguiente comensal.</p>
                        </div>
                    </div>
        </div>
      </div>
    </section>

    <!-- Especificaciones técnicas -->
    <section class="section">
      <div class="content-container">
        <h2 class="section-title">Especificaciones técnicas</h2>
        <div class="specs-wrapper">
          <table class="specs-table">
            <tbody>
                        <tr>
                            <td class="spec-label">Mesa - sobre</td>
                            <td class="spec-value">Chapa de madera sobre MDF 30 mm, canto aluminio anodizado 3 mm</td>
                        </tr>
                        <tr>
                            <td class="spec-label">Mesa - base</td>
                            <td class="spec-value">Columna central de acero Ø60 mm + base redonda lastrada 15 kg</td>
                        </tr>
                        <tr>
                            <td class="spec-label">Mesa - dimensiones</td>
                            <td class="spec-value">Diámetro 90/100/120 cm; altura 75 cm</td>
                        </tr>
                        <tr>
                            <td class="spec-label">Silla - estructura</td>
                            <td class="spec-value">Acero tubular Ø18 mm con recubrimiento epoxi; apilable hasta 8 uds.</td>
                        </tr>
                        <tr>
                            <td class="spec-label">Silla - asiento</td>
                            <td class="spec-value">Espuma moldeada 50 kg/m³ + tapizado hidrófugo 100K Martindale</td>
                        </tr>
                        <tr>
                            <td class="spec-label">Silla - peso</td>
                            <td class="spec-value">4.8 kg por unidad</td>
                        </tr>
                        <tr>
                            <td class="spec-label">Certificaciones</td>
                            <td class="spec-value">EN 15373 nivel 3 (contract), EN 1022 estabilidad, resistencia fuego M2</td>
                        </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- Aplicaciones -->
    <section class="section">
      <div class="content-container">
        <h2 class="section-title">Aplicaciones en proyectos hoteleros</h2>
        <div class="usos-grid">
                        <div class="uso-card">
                            <span class="uso-num">01</span>
                            <p>Restaurante buffet de hotel: mesas de 100 cm con 4 sillas cada una, configuración que maximiza el número de comensales sin sensación de agobio.</p>
                        </div>
                        <div class="uso-card">
                            <span class="uso-num">02</span>
                            <p>Restaurante a la carta: mesas de 90 cm para 2-3 comensales en formato íntimo, con sillas de respaldo más alto y asiento ligeramente más ancho para favorecer las cenas largas.</p>
                        </div>
                        <div class="uso-card">
                            <span class="uso-num">03</span>
                            <p>Terraza cubierta del hotel: versión con estructura de acero inoxidable 316 y tapizado outdoor, resistente a cambios de temperatura y humedad sin perder aspecto.</p>
                        </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="section">
      <div class="content-container">
        <h2 class="section-title">Preguntas frecuentes</h2>
        <div class="faq-list">
                    <div class="faq-item">
                        <button class="faq-question" onclick="this.parentElement.classList.toggle('open')">
                            <span>¿Las sillas vienen montadas o hay que ensamblarlas?</span>
                            <span class="faq-arrow">+</span>
                        </button>
                        <div class="faq-answer">
                            <p>Llegan completamente montadas y listas para usar. Cada silla se envuelve individualmente con protección de esquinas para que el transporte no deje ninguna marca.</p>
                        </div>
                    </div>
                    <div class="faq-item">
                        <button class="faq-question" onclick="this.parentElement.classList.toggle('open')">
                            <span>¿Se puede pedir la mesa con sistema de extensión?</span>
                            <span class="faq-arrow">+</span>
                        </button>
                        <div class="faq-answer">
                            <p>Sí. Bajo pedido fabricamos mesas de restaurante con 1 o 2 extensiones laterales de 30 cm cada una, ocultas bajo el sobre. Es una opción muy demandada por hoteles que usan el mismo espacio para desayuno buffet y cenas de gala.</p>
                        </div>
                    </div>
                    <div class="faq-item">
                        <button class="faq-question" onclick="this.parentElement.classList.toggle('open')">
                            <span>¿Qué mantenimiento requiere el tapizado de las sillas?</span>
                            <span class="faq-arrow">+</span>
                        </button>
                        <div class="faq-answer">
                            <p>Limpieza diaria con paño húmedo y jabón neutro. Recomendamos una limpieza profesional con espuma seca cada 4 meses en temporada alta. El tapizado está diseñado para durar 3-4 años en uso intensivo antes de necesitar retapizado.</p>
                        </div>
                    </div>
        </div>
      </div>
    </section>

    <!-- CTA final -->
    <section class="cta-section">
      <div class="content-container">
        <h2>Solicite una cotización para su proyecto</h2>
        <p>Respondemos en menos de 24 horas con presupuesto detallado, planos técnicos y muestras de materiales.</p>
        <a href="/contacto/" class="btn-primary">📋 Solicitar cotización ahora</a>
      </div>
    </section>
  </article>
</BaseLayout>

<style>
  .producto-page {
    font-family: var(--font-body, -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif);
    color: var(--color-text, #2C2416);
    background: var(--color-bg, #FDFCF9);
    line-height: 1.7;
  }

  /* Breadcrumb */
  .breadcrumb {
    background: var(--color-surface, #FFFFFF);
    border-bottom: 1px solid var(--color-border, #E8E3D9);
    padding: 12px 0;
  }
  .breadcrumb-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: var(--color-text-light, #6B6358);
  }
  .breadcrumb a {
    color: var(--color-text-light, #6B6358);
    text-decoration: none;
  }
  .breadcrumb a:hover { color: var(--color-primary, #1a3a5c); }
  .breadcrumb span { color: var(--color-text, #2C2416); font-weight: 500; }

  /* Producto Hero */
  .producto-hero {
    max-width: 1200px;
    margin: 0 auto;
    padding: 40px 24px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: start;
  }

  .gallery-main {
    background: #EEF0F3;
    border-radius: 8px;
    aspect-ratio: 4/3;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-light, #6B6358);
    font-size: 15px;
    text-align: center;
    padding: 40px;
  }
  .gallery-main-content h4 {
    font-size: 20px;
    margin-bottom: 8px;
    color: var(--color-primary, #1a3a5c);
  }
  .gallery-main-content p {
    font-size: 14px;
  }
  .gallery-thumbs {
    display: flex;
    gap: 8px;
    margin-top: 12px;
  }
  .gallery-thumb {
    width: 72px;
    height: 54px;
    background: #EEF0F3;
    border-radius: 4px;
    border: 2px solid transparent;
    cursor: pointer;
    transition: border-color 0.2s;
  }
  .gallery-thumb:hover, .gallery-thumb.active {
    border-color: var(--color-accent, #c9a962);
  }

  .producto-info h1 {
    font-size: 32px;
    line-height: 1.25;
    color: var(--color-text, #2C2416);
    margin-bottom: 12px;
    letter-spacing: -0.3px;
  }
  .producto-categoria {
    display: inline-block;
    background: #EEF0F3;
    color: var(--color-primary, #1a3a5c);
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    padding: 4px 12px;
    border-radius: 100px;
    margin-bottom: 16px;
  }
  .producto-intro {
    font-size: 16px;
    color: var(--color-text-light, #6B6358);
    line-height: 1.8;
    margin-bottom: 24px;
  }
  .producto-cta-group {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }
  .btn-primary {
    background: var(--color-primary, #1a3a5c);
    color: #fff;
    border: none;
    padding: 14px 32px;
    font-size: 15px;
    font-weight: 600;
    border-radius: 8px;
    cursor: pointer;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: background 0.2s;
  }
  .btn-primary:hover { background: #142d4a; }
  .btn-secondary {
    background: var(--color-surface, #FFFFFF);
    color: var(--color-primary, #1a3a5c);
    border: 2px solid var(--color-border, #E8E3D9);
    padding: 14px 32px;
    font-size: 15px;
    font-weight: 600;
    border-radius: 8px;
    cursor: pointer;
    text-decoration: none;
    transition: all 0.2s;
  }
  .btn-secondary:hover { border-color: var(--color-primary, #1a3a5c); }

  /* Secciones */
  .content-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }
  .section {
    padding: 48px 0;
    border-top: 1px solid var(--color-border, #E8E3D9);
  }
  .section-title {
    font-size: 24px;
    color: var(--color-text, #2C2416);
    margin-bottom: 28px;
    letter-spacing: -0.2px;
  }

  /* Ventajas */
  .ventajas-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }
  .ventaja-item {
    display: flex;
    gap: 16px;
    align-items: flex-start;
    padding: 24px;
    background: var(--color-surface, #FFFFFF);
    border-radius: 8px;
    box-shadow: 0 2px 12px rgba(44,36,22,0.06);
  }
  .ventaja-icon {
    font-size: 28px;
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #EEF0F3;
    border-radius: 8px;
  }
  .ventaja-content p {
    font-size: 14.5px;
    color: var(--color-text-light, #6B6358);
    line-height: 1.75;
  }

  /* Specs Table */
  .specs-wrapper {
    background: var(--color-surface, #FFFFFF);
    border-radius: 8px;
    box-shadow: 0 2px 12px rgba(44,36,22,0.06);
    overflow: hidden;
  }
  .specs-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 14.5px;
  }
  .specs-table td {
    padding: 14px 20px;
    border-bottom: 1px solid var(--color-border, #E8E3D9);
  }
  .spec-label {
    font-weight: 600;
    color: var(--color-text, #2C2416);
    width: 30%;
  }
  .spec-value {
    color: var(--color-text-light, #6B6358);
  }

  /* Usos */
  .usos-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .uso-card {
    padding: 28px 24px;
    background: var(--color-surface, #FFFFFF);
    border-radius: 8px;
    box-shadow: 0 2px 12px rgba(44,36,22,0.06);
    position: relative;
  }
  .uso-num {
    font-size: 36px;
    color: #D8DDE3;
    font-weight: bold;
    line-height: 1;
    margin-bottom: 12px;
    display: block;
  }
  .uso-card p {
    font-size: 14px;
    color: var(--color-text-light, #6B6358);
    line-height: 1.7;
  }

  /* FAQ */
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .faq-item {
    border: 1px solid var(--color-border, #E8E3D9);
    border-radius: 8px;
    background: var(--color-surface, #FFFFFF);
    overflow: hidden;
  }
  .faq-question {
    width: 100%;
    background: none;
    border: none;
    padding: 18px 24px;
    font-size: 15px;
    font-weight: 600;
    color: var(--color-text, #2C2416);
    text-align: left;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
  }
  .faq-arrow {
    font-size: 20px;
    font-weight: 300;
    color: var(--color-text-light, #6B6358);
    transition: transform 0.3s;
    flex-shrink: 0;
  }
  .faq-item.open .faq-arrow {
    transform: rotate(45deg);
  }
  .faq-answer {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
  }
  .faq-item.open .faq-answer {
    max-height: 500px;
  }
  .faq-answer p {
    padding: 0 24px 18px;
    font-size: 14.5px;
    color: var(--color-text-light, #6B6358);
    line-height: 1.75;
  }

  /* CTA */
  .cta-section {
    padding: 48px 0;
    border-top: 1px solid var(--color-border, #E8E3D9);
    text-align: center;
  }
  .cta-section h2 {
    font-size: 22px;
    margin-bottom: 12px;
  }
  .cta-section p {
    color: var(--color-text-light, #6B6358);
    margin-bottom: 24px;
  }

  @media (max-width: 768px) {
    .producto-hero {
      grid-template-columns: 1fr;
      gap: 24px;
    }
    .ventajas-grid {
      grid-template-columns: 1fr;
    }
    .usos-grid {
      grid-template-columns: 1fr;
    }
    .producto-info h1 {
      font-size: 24px;
    }
  }

    .gallery-main-img {
      width: 100%;
      height: 100%;
      object-fit: contain;
      position: absolute;
      top: 0;
      left: 0;
    }
    .gallery-thumb img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      border-radius: 4px;
    }
  </style>

<script>
  document.querySelectorAll('.faq-question').forEach(btn => {
    btn.addEventListener('click', () => {
      btn.closest('.faq-item')?.classList.toggle('open');
    });
  });
</script>
