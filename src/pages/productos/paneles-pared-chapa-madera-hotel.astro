---
import BaseLayout from '../../layouts/BaseLayout.astro';
const pageTitle = "Paneles Pared Chapa Madera Hotel | Revestimiento Hotelero | Fabricante";
const pageDescription = "Paneles de pared con chapa de madera natural para hoteles. Sistema click de instalación rápida, acabados acústicos opcionales. Fabricación a medida, certificación FSC.";
const canonicalUrl = "/productos/paneles-pared-chapa-madera-hotel/";
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonicalPath={canonicalUrl}
>
  <!-- Schema.org JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "Paneles de Pared con Chapa de Madera Natural para Hoteles",
    "description": "Paneles de pared con chapa de madera natural para hoteles. Sistema click de instalación rápida, acabados acústicos opcionales. Fabricación a medida, certificación FSC.",
    "category": "Revestimientos",
    "brand": {
      "@type": "Brand",
      "name": "HYMUEBLE"
    },
    "manufacturer": {
      "@type": "Organization",
      "name": "Hongye Furniture Group Co., Ltd."
    },
    "offers": {
      "@type": "Offer",
      "availability": "https://schema.org/InStock",
      "priceSpecification": {
        "@type": "PriceSpecification",
        "price": "Consultar",
        "priceCurrency": "USD"
      }
    }
  })}>
  </script>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {"@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://hymueble.com/"},
      {"@type": "ListItem", "position": 2, "name": "Productos", "item": "https://hymueble.com/productos/"},
      {"@type": "ListItem", "position": 3, "name": "Paneles de Pared con Chapa de Madera Natural para Hoteles"}
    ]
  })}>
  </script>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [{"@type": "Question", "name": "¿Se pueden instalar sobre una pared ya construida sin hacer obra?", "acceptedAnswer": {"@type": "Answer", "text": "Sí. El sistema de rastreles de aluminio se fija a la pared existente con tacos cada 60 cm. No requiere enfoscar, enlucir ni pintar: los paneles cubren la pared original por completo y las instalaciones eléctricas discurren por el espacio hueco entre panel y pared (25 mm)."}}, {"@type": "Question", "name": "¿Cómo se limpian los paneles?", "acceptedAnswer": {"@type": "Answer", "text": "Con un paño de microfibra seco o ligeramente humedecido. El barniz de poliuretano repele el polvo y las huellas. No requieren ceras ni aceites. En zonas de alto contacto, recomendamos una limpieza semanal."}}, {"@type": "Question", "name": "¿Se pueden pedir con formas curvas para paredes no rectas?", "acceptedAnswer": {"@type": "Answer", "text": "Sí, fabricamos paneles curvos por termoformado con un radio mínimo de 600 mm. Hay que facilitar la plantilla o los planos de la curva exacta. El sobrecoste respecto al panel recto es de aproximadamente un 30% y el plazo se amplía 10 días laborables."}}]
  })}>
  </script>

  <article class="producto-page">
    <!-- Breadcrumb -->
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <div class="breadcrumb-container">
        <a href="/">Inicio</a>
        <span aria-hidden="true">›</span>
        <a href="/productos/">Productos</a>
        <span aria-hidden="true">›</span>
        <span>Paneles de Pared con Chapa de Madera Natural para Hoteles</span>
      </div>
    </nav>

    <!-- Product Hero -->
    <div class="producto-hero">
      <div class="producto-gallery">
        <div class="gallery-main">
          <img class="gallery-main-img" src="/images/productos/prd-09/prd-09-01.jpg" alt="Producto principal" loading="eager" width="600" height="600">
          <div class="gallery-main-content" style="display:none"><h4>Paneles de Pared con Chapa de Madera Natural para Hoteles</h4>
            <p>Imagen principal del producto — 4 vistas disponibles</p>
          </div>
        </div>
        <div class="gallery-thumbs">
          <div class="gallery-thumb active"><img src="/images/productos/prd-09/prd-09-01.jpg" alt="Vista 1" loading="lazy" width="120" height="120" onclick="document.querySelector('.gallery-main-img').src='/images/productos/prd-09/prd-09-01.jpg'"></div><div class="gallery-thumb"><img src="/images/productos/prd-09/prd-09-02.jpg" alt="Vista 2" loading="lazy" width="120" height="120" onclick="document.querySelector('.gallery-main-img').src='/images/productos/prd-09/prd-09-02.jpg'"></div><div class="gallery-thumb"><img src="/images/productos/prd-09/prd-09-03.jpg" alt="Vista 3" loading="lazy" width="120" height="120" onclick="document.querySelector('.gallery-main-img').src='/images/productos/prd-09/prd-09-03.jpg'"></div><div class="gallery-thumb"><img src="/images/productos/prd-09/prd-09-04.jpg" alt="Vista 4" loading="lazy" width="120" height="120" onclick="document.querySelector('.gallery-main-img').src='/images/productos/prd-09/prd-09-04.jpg'"></div>
        </div>
      </div>

      <div class="producto-info">
        <span class="producto-categoria">Revestimientos</span>
        <h1>Paneles de Pared con Chapa de Madera Natural para Hoteles</h1>
        <p class="producto-intro">Los paneles murales de chapa de madera natural transforman cualquier pared en un elemento arquitectónico con carácter. Ideales para cabeceros de cama, paredes de recepción o revestimientos de pasillo, su sistema de instalación por clip permite cubrir 30 metros cuadrados en una jornada de trabajo sin generar escombros ni polvo. Disponibles en 12 especies de chapa y con opción de panel acústico para zonas donde el confort sonoro es prioritario.</p>
        <div class="producto-cta-group">
          <a href="/contacto/" class="btn-primary">📋 Solicitar cotización</a>
          <a href="/contacto/" class="btn-secondary">📞 Contactar ventas</a>
        </div>
      </div>
    </div>

    <!-- Ventajas -->
    <section class="section">
      <div class="content-container">
        <h2 class="section-title">Ventajas del producto</h2>
        <div class="ventajas-grid">
                    <div class="ventaja-item">
                        <div class="ventaja-icon">🛡️</div>
                        <div class="ventaja-content">
                            <p>El sistema de fijación por clip sobre rastreles de aluminio permite instalar 30 m² de paneles en 8 horas con solo dos operarios. A diferencia de los revestimientos tradicionales con cola o clavos, no genera olores, no mancha y permite desmontar paneles individuales para acceder a instalaciones sin dañar los contiguos.</p>
                        </div>
                    </div>
                    <div class="ventaja-item">
                        <div class="ventaja-icon">📐</div>
                        <div class="ventaja-content">
                            <p>En su versión acústica, los paneles incorporan un núcleo fonoabsorbente de fibra de poliéster reciclado de 12 mm que reduce la reverberación en un 45%. Ideal para lobbies, pasillos y restaurantes de hotel donde el ruido ambiente afecta a la experiencia del huésped.</p>
                        </div>
                    </div>
                    <div class="ventaja-item">
                        <div class="ventaja-icon">🔧</div>
                        <div class="ventaja-content">
                            <p>La chapa de madera natural se selecciona hoja a hoja para garantizar continuidad de veta entre paneles contiguos. Cada lote se numera en fábrica y se entrega con un plano de colocación para que el instalador sepa exactamente dónde va cada pieza.</p>
                        </div>
                    </div>
        </div>
      </div>
    </section>

    <!-- Especificaciones técnicas -->
    <section class="section">
      <div class="content-container">
        <h2 class="section-title">Especificaciones técnicas</h2>
        <div class="specs-wrapper">
          <table class="specs-table">
            <tbody>
                        <tr>
                            <td class="spec-label">Material</td>
                            <td class="spec-value">Chapa de madera natural sobre tablero MDF E1 16 mm + núcleo acústico opcional</td>
                        </tr>
                        <tr>
                            <td class="spec-label">Dimensiones panel</td>
                            <td class="spec-value">600 × 2400/2800/3000 mm; espesor 16+12 mm (estándar+acústico)</td>
                        </tr>
                        <tr>
                            <td class="spec-label">Sistema instalación</td>
                            <td class="spec-value">Clip oculto sobre rastrel aluminio; junta 3 mm entre paneles</td>
                        </tr>
                        <tr>
                            <td class="spec-label">Especies disponibles</td>
                            <td class="spec-value">Roble, nogal, fresno, cerezo, wengué, arce, haya, palisandro, olmo, zebrano, ébano, teka</td>
                        </tr>
                        <tr>
                            <td class="spec-label">Acabados</td>
                            <td class="spec-value">Barniz mate, satinado o lacado RAL; ignífugo Clase B-s1,d0 bajo pedido</td>
                        </tr>
                        <tr>
                            <td class="spec-label">Acústica</td>
                            <td class="spec-value">Núcleo fonoabsorbente 12 mm; reducción reverberación 45% (NRC 0.75)</td>
                        </tr>
                        <tr>
                            <td class="spec-label">Certificaciones</td>
                            <td class="spec-value">FSC, E1, Euroclase B-s1,d0 (configuración ignífuga)</td>
                        </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- Aplicaciones -->
    <section class="section">
      <div class="content-container">
        <h2 class="section-title">Aplicaciones en proyectos hoteleros</h2>
        <div class="usos-grid">
                        <div class="uso-card">
                            <span class="uso-num">01</span>
                            <p>Cabecero de cama en habitación: panel de ancho completo (300 cm) que hace las veces de cabecero, mesilla integrada y soporte para iluminación de lectura, todo en un solo elemento.</p>
                        </div>
                        <div class="uso-card">
                            <span class="uso-num">02</span>
                            <p>Pared de recepción: revestimiento de pared principal con el logotipo del hotel grabado mediante fresado CNC, creando un elemento de marca de alto impacto visual.</p>
                        </div>
                        <div class="uso-card">
                            <span class="uso-num">03</span>
                            <p>Pasillo de planta: paneles acústicos en pasillos largos para reducir el ruido de tránsito y mejorar la sensación de confort al caminar hacia la habitación.</p>
                        </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="section">
      <div class="content-container">
        <h2 class="section-title">Preguntas frecuentes</h2>
        <div class="faq-list">
                    <div class="faq-item">
                        <button class="faq-question" onclick="this.parentElement.classList.toggle('open')">
                            <span>¿Se pueden instalar sobre una pared ya construida sin hacer obra?</span>
                            <span class="faq-arrow">+</span>
                        </button>
                        <div class="faq-answer">
                            <p>Sí. El sistema de rastreles de aluminio se fija a la pared existente con tacos cada 60 cm. No requiere enfoscar, enlucir ni pintar: los paneles cubren la pared original por completo y las instalaciones eléctricas discurren por el espacio hueco entre panel y pared (25 mm).</p>
                        </div>
                    </div>
                    <div class="faq-item">
                        <button class="faq-question" onclick="this.parentElement.classList.toggle('open')">
                            <span>¿Cómo se limpian los paneles?</span>
                            <span class="faq-arrow">+</span>
                        </button>
                        <div class="faq-answer">
                            <p>Con un paño de microfibra seco o ligeramente humedecido. El barniz de poliuretano repele el polvo y las huellas. No requieren ceras ni aceites. En zonas de alto contacto, recomendamos una limpieza semanal.</p>
                        </div>
                    </div>
                    <div class="faq-item">
                        <button class="faq-question" onclick="this.parentElement.classList.toggle('open')">
                            <span>¿Se pueden pedir con formas curvas para paredes no rectas?</span>
                            <span class="faq-arrow">+</span>
                        </button>
                        <div class="faq-answer">
                            <p>Sí, fabricamos paneles curvos por termoformado con un radio mínimo de 600 mm. Hay que facilitar la plantilla o los planos de la curva exacta. El sobrecoste respecto al panel recto es de aproximadamente un 30% y el plazo se amplía 10 días laborables.</p>
                        </div>
                    </div>
        </div>
      </div>
    </section>

    <!-- CTA final -->
    <section class="cta-section">
      <div class="content-container">
        <h2>Solicite una cotización para su proyecto</h2>
        <p>Respondemos en menos de 24 horas con presupuesto detallado, planos técnicos y muestras de materiales.</p>
        <a href="/contacto/" class="btn-primary">📋 Solicitar cotización ahora</a>
      </div>
    </section>
  </article>
</BaseLayout>

<style>
  .producto-page {
    font-family: var(--font-body, -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif);
    color: var(--color-text, #2C2416);
    background: var(--color-bg, #FDFCF9);
    line-height: 1.7;
  }

  /* Breadcrumb */
  .breadcrumb {
    background: var(--color-surface, #FFFFFF);
    border-bottom: 1px solid var(--color-border, #E8E3D9);
    padding: 12px 0;
  }
  .breadcrumb-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: var(--color-text-light, #6B6358);
  }
  .breadcrumb a {
    color: var(--color-text-light, #6B6358);
    text-decoration: none;
  }
  .breadcrumb a:hover { color: var(--color-primary, #1a3a5c); }
  .breadcrumb span { color: var(--color-text, #2C2416); font-weight: 500; }

  /* Producto Hero */
  .producto-hero {
    max-width: 1200px;
    margin: 0 auto;
    padding: 40px 24px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: start;
  }

  .gallery-main {
    background: #EEF0F3;
    border-radius: 8px;
    aspect-ratio: 4/3;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-light, #6B6358);
    font-size: 15px;
    text-align: center;
    padding: 40px;
  }
  .gallery-main-content h4 {
    font-size: 20px;
    margin-bottom: 8px;
    color: var(--color-primary, #1a3a5c);
  }
  .gallery-main-content p {
    font-size: 14px;
  }
  .gallery-thumbs {
    display: flex;
    gap: 8px;
    margin-top: 12px;
  }
  .gallery-thumb {
    width: 72px;
    height: 54px;
    background: #EEF0F3;
    border-radius: 4px;
    border: 2px solid transparent;
    cursor: pointer;
    transition: border-color 0.2s;
  }
  .gallery-thumb:hover, .gallery-thumb.active {
    border-color: var(--color-accent, #c9a962);
  }

  .producto-info h1 {
    font-size: 32px;
    line-height: 1.25;
    color: var(--color-text, #2C2416);
    margin-bottom: 12px;
    letter-spacing: -0.3px;
  }
  .producto-categoria {
    display: inline-block;
    background: #EEF0F3;
    color: var(--color-primary, #1a3a5c);
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    padding: 4px 12px;
    border-radius: 100px;
    margin-bottom: 16px;
  }
  .producto-intro {
    font-size: 16px;
    color: var(--color-text-light, #6B6358);
    line-height: 1.8;
    margin-bottom: 24px;
  }
  .producto-cta-group {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }
  .btn-primary {
    background: var(--color-primary, #1a3a5c);
    color: #fff;
    border: none;
    padding: 14px 32px;
    font-size: 15px;
    font-weight: 600;
    border-radius: 8px;
    cursor: pointer;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: background 0.2s;
  }
  .btn-primary:hover { background: #142d4a; }
  .btn-secondary {
    background: var(--color-surface, #FFFFFF);
    color: var(--color-primary, #1a3a5c);
    border: 2px solid var(--color-border, #E8E3D9);
    padding: 14px 32px;
    font-size: 15px;
    font-weight: 600;
    border-radius: 8px;
    cursor: pointer;
    text-decoration: none;
    transition: all 0.2s;
  }
  .btn-secondary:hover { border-color: var(--color-primary, #1a3a5c); }

  /* Secciones */
  .content-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }
  .section {
    padding: 48px 0;
    border-top: 1px solid var(--color-border, #E8E3D9);
  }
  .section-title {
    font-size: 24px;
    color: var(--color-text, #2C2416);
    margin-bottom: 28px;
    letter-spacing: -0.2px;
  }

  /* Ventajas */
  .ventajas-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }
  .ventaja-item {
    display: flex;
    gap: 16px;
    align-items: flex-start;
    padding: 24px;
    background: var(--color-surface, #FFFFFF);
    border-radius: 8px;
    box-shadow: 0 2px 12px rgba(44,36,22,0.06);
  }
  .ventaja-icon {
    font-size: 28px;
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #EEF0F3;
    border-radius: 8px;
  }
  .ventaja-content p {
    font-size: 14.5px;
    color: var(--color-text-light, #6B6358);
    line-height: 1.75;
  }

  /* Specs Table */
  .specs-wrapper {
    background: var(--color-surface, #FFFFFF);
    border-radius: 8px;
    box-shadow: 0 2px 12px rgba(44,36,22,0.06);
    overflow: hidden;
  }
  .specs-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 14.5px;
  }
  .specs-table td {
    padding: 14px 20px;
    border-bottom: 1px solid var(--color-border, #E8E3D9);
  }
  .spec-label {
    font-weight: 600;
    color: var(--color-text, #2C2416);
    width: 30%;
  }
  .spec-value {
    color: var(--color-text-light, #6B6358);
  }

  /* Usos */
  .usos-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .uso-card {
    padding: 28px 24px;
    background: var(--color-surface, #FFFFFF);
    border-radius: 8px;
    box-shadow: 0 2px 12px rgba(44,36,22,0.06);
    position: relative;
  }
  .uso-num {
    font-size: 36px;
    color: #D8DDE3;
    font-weight: bold;
    line-height: 1;
    margin-bottom: 12px;
    display: block;
  }
  .uso-card p {
    font-size: 14px;
    color: var(--color-text-light, #6B6358);
    line-height: 1.7;
  }

  /* FAQ */
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .faq-item {
    border: 1px solid var(--color-border, #E8E3D9);
    border-radius: 8px;
    background: var(--color-surface, #FFFFFF);
    overflow: hidden;
  }
  .faq-question {
    width: 100%;
    background: none;
    border: none;
    padding: 18px 24px;
    font-size: 15px;
    font-weight: 600;
    color: var(--color-text, #2C2416);
    text-align: left;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
  }
  .faq-arrow {
    font-size: 20px;
    font-weight: 300;
    color: var(--color-text-light, #6B6358);
    transition: transform 0.3s;
    flex-shrink: 0;
  }
  .faq-item.open .faq-arrow {
    transform: rotate(45deg);
  }
  .faq-answer {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
  }
  .faq-item.open .faq-answer {
    max-height: 500px;
  }
  .faq-answer p {
    padding: 0 24px 18px;
    font-size: 14.5px;
    color: var(--color-text-light, #6B6358);
    line-height: 1.75;
  }

  /* CTA */
  .cta-section {
    padding: 48px 0;
    border-top: 1px solid var(--color-border, #E8E3D9);
    text-align: center;
  }
  .cta-section h2 {
    font-size: 22px;
    margin-bottom: 12px;
  }
  .cta-section p {
    color: var(--color-text-light, #6B6358);
    margin-bottom: 24px;
  }

  @media (max-width: 768px) {
    .producto-hero {
      grid-template-columns: 1fr;
      gap: 24px;
    }
    .ventajas-grid {
      grid-template-columns: 1fr;
    }
    .usos-grid {
      grid-template-columns: 1fr;
    }
    .producto-info h1 {
      font-size: 24px;
    }
  }

    .gallery-main-img {
      width: 100%;
      height: 100%;
      object-fit: contain;
      position: absolute;
      top: 0;
      left: 0;
    }
    .gallery-thumb img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      border-radius: 4px;
    }
  </style>

<script>
  document.querySelectorAll('.faq-question').forEach(btn => {
    btn.addEventListener('click', () => {
      btn.closest('.faq-item')?.classList.toggle('open');
    });
  });
</script>
