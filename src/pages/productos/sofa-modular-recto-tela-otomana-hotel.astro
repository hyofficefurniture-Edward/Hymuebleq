---
import BaseLayout from '../../layouts/BaseLayout.astro';
const pageTitle = "Sofá Modular Recto Tela Otomana Hotel | Mobiliario Contract Hotelero";
const pageDescription = "Sofá modular recto de tela con otomana para hoteles. Estructura de pino macizo, tapizado 150K Martindale, módulos configurables. Fabricación a medida, pedido mínimo 30 uds.";
const canonicalUrl = "/productos/sofa-modular-recto-tela-otomana-hotel/";
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonicalPath={canonicalUrl}
>
  <!-- Schema.org JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "Sofá Modular Recto de Tela con Otomana para Hoteles",
    "description": "Sofá modular recto de tela con otomana para hoteles. Estructura de pino macizo, tapizado 150K Martindale, módulos configurables. Fabricación a medida, pedido mínimo 30 uds.",
    "category": "Sofás y Asientos",
    "brand": {
      "@type": "Brand",
      "name": "HYMUEBLE"
    },
    "manufacturer": {
      "@type": "Organization",
      "name": "Hongye Furniture Group Co., Ltd."
    },
    "offers": {
      "@type": "Offer",
      "availability": "https://schema.org/InStock",
      "priceSpecification": {
        "@type": "PriceSpecification",
        "price": "Consultar",
        "priceCurrency": "USD"
      }
    }
  })}>
  </script>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {"@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://hymueble.com/"},
      {"@type": "ListItem", "position": 2, "name": "Productos", "item": "https://hymueble.com/productos/"},
      {"@type": "ListItem", "position": 3, "name": "Sofá Modular Recto de Tela con Otomana para Hoteles"}
    ]
  })}>
  </script>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [{"@type": "Question", "name": "¿Se pueden añadir módulos más adelante?", "acceptedAnswer": {"@type": "Answer", "text": "Sí, el sistema modular permite añadir módulos adicionales en cualquier momento, incluso años después del pedido inicial. Mantenemos el mismo tejido y tonalidad de madera en stock para garantizar la uniformidad."}}, {"@type": "Question", "name": "¿Las fundas son lavables?", "acceptedAnswer": {"@type": "Answer", "text": "Sí, todas las fundas (asiento, respaldo y otomana) son desenfundables y lavables a máquina a 30°C. Esto reduce el coste de mantenimiento y permite una limpieza profunda sin necesidad de productos especiales."}}, {"@type": "Question", "name": "¿Ofrecen muestras de tejido para validar colores?", "acceptedAnswer": {"@type": "Answer", "text": "Sí, enviamos un muestrario completo con los 25 colores disponibles en 48 horas. Para pedidos superiores a 50 módulos, podemos teñir un color corporativo personalizado con un plazo adicional de 15 días."}}]
  })}>
  </script>

  <article class="producto-page">
    <!-- Breadcrumb -->
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <div class="breadcrumb-container">
        <a href="/">Inicio</a>
        <span aria-hidden="true">›</span>
        <a href="/productos/">Productos</a>
        <span aria-hidden="true">›</span>
        <span>Sofá Modular Recto de Tela con Otomana para Hoteles</span>
      </div>
    </nav>

    <!-- Product Hero -->
    <div class="producto-hero">
      <div class="producto-gallery">
        <div class="gallery-main">
          <img class="gallery-main-img" src="/images/productos/prd-10/prd-10-01.jpg" alt="Producto principal" loading="eager" width="600" height="600">
          <div class="gallery-main-content" style="display:none"><h4>Sofá Modular Recto de Tela con Otomana para Hoteles</h4>
            <p>Imagen principal del producto — 5 vistas disponibles</p>
          </div>
        </div>
        <div class="gallery-thumbs">
          <div class="gallery-thumb active"><img src="/images/productos/prd-10/prd-10-01.jpg" alt="Vista 1" loading="lazy" width="120" height="120" onclick="document.querySelector('.gallery-main-img').src='/images/productos/prd-10/prd-10-01.jpg'"></div><div class="gallery-thumb"><img src="/images/productos/prd-10/prd-10-02.jpg" alt="Vista 2" loading="lazy" width="120" height="120" onclick="document.querySelector('.gallery-main-img').src='/images/productos/prd-10/prd-10-02.jpg'"></div><div class="gallery-thumb"><img src="/images/productos/prd-10/prd-10-03.jpg" alt="Vista 3" loading="lazy" width="120" height="120" onclick="document.querySelector('.gallery-main-img').src='/images/productos/prd-10/prd-10-03.jpg'"></div><div class="gallery-thumb"><img src="/images/productos/prd-10/prd-10-04.jpg" alt="Vista 4" loading="lazy" width="120" height="120" onclick="document.querySelector('.gallery-main-img').src='/images/productos/prd-10/prd-10-04.jpg'"></div><div class="gallery-thumb"><img src="/images/productos/prd-10/prd-10-05.jpg" alt="Vista 5" loading="lazy" width="120" height="120" onclick="document.querySelector('.gallery-main-img').src='/images/productos/prd-10/prd-10-05.jpg'"></div>
        </div>
      </div>

      <div class="producto-info">
        <span class="producto-categoria">Sofás y Asientos</span>
        <h1>Sofá Modular Recto de Tela con Otomana para Hoteles</h1>
        <p class="producto-intro">El sofá modular recto con otomana está diseñado para zonas comunes de hotel que necesitan flexibilidad. Los módulos independientes se combinan formando configuraciones rectas, en L o con isla central, adaptándose a cualquier lobby, sala de estar o zona de descanso. El tapizado técnico de 150.000 ciclos Martindale y la estructura de pino macizo garantizan durabilidad en uso intensivo.</p>
        <div class="producto-cta-group">
          <a href="/contacto/" class="btn-primary">📋 Solicitar cotización</a>
          <a href="/contacto/" class="btn-secondary">📞 Contactar ventas</a>
        </div>
      </div>
    </div>

    <!-- Ventajas -->
    <section class="section">
      <div class="content-container">
        <h2 class="section-title">Ventajas del producto</h2>
        <div class="ventajas-grid">
                    <div class="ventaja-item">
                        <div class="ventaja-icon">🛡️</div>
                        <div class="ventaja-content">
                            <p>Los módulos son independientes y se acoplan entre sí con ganchos metálicos ocultos. Se pueden crear configuraciones de 2 a 8 plazas simplemente añadiendo o restando módulos, y cambiar la disposición de la sala en minutos sin herramientas ni personal especializado.</p>
                        </div>
                    </div>
                    <div class="ventaja-item">
                        <div class="ventaja-icon">📐</div>
                        <div class="ventaja-content">
                            <p>El tapizado técnico alcanza 150.000 ciclos Martindale y tiene tratamiento hidrófugo que convierte los líquidos en gotas que resbalan sin penetrar. Ensayos en hoteles con ocupación superior al 80% confirman que el aspecto del tejido se mantiene sin cambios visibles durante al menos 4 años.</p>
                        </div>
                    </div>
                    <div class="ventaja-item">
                        <div class="ventaja-icon">🔧</div>
                        <div class="ventaja-content">
                            <p>La otomana independiente funciona como reposapiés, asiento auxiliar o mesa improvisada con bandeja. En configuraciones de lobby, las otomanas sueltas permiten a los huéspedes crear su propia zona sin mover muebles pesados.</p>
                        </div>
                    </div>
        </div>
      </div>
    </section>

    <!-- Especificaciones técnicas -->
    <section class="section">
      <div class="content-container">
        <h2 class="section-title">Especificaciones técnicas</h2>
        <div class="specs-wrapper">
          <table class="specs-table">
            <tbody>
                        <tr>
                            <td class="spec-label">Estructura</td>
                            <td class="spec-value">Pino macizo secado al horno + tablero contrachapado 18 mm</td>
                        </tr>
                        <tr>
                            <td class="spec-label">Tapizado</td>
                            <td class="spec-value">Tejido técnico 150K Martindale, hidrófugo, 25 colores disponibles</td>
                        </tr>
                        <tr>
                            <td class="spec-label">Relleno asiento</td>
                            <td class="spec-value">Espuma HR 32 kg/m³ + fibra hueca siliconada</td>
                        </tr>
                        <tr>
                            <td class="spec-label">Relleno respaldo</td>
                            <td class="spec-value">Fibra hueca siliconada + muelles de zig-zag</td>
                        </tr>
                        <tr>
                            <td class="spec-label">Módulo estándar</td>
                            <td class="spec-value">Ancho 90 × fondo 90 × alto 85 cm; altura asiento 45 cm</td>
                        </tr>
                        <tr>
                            <td class="spec-label">Otomana</td>
                            <td class="spec-value">90 × 90 × 45 cm; tapizado coordinable; peso 18 kg</td>
                        </tr>
                        <tr>
                            <td class="spec-label">Configuraciones</td>
                            <td class="spec-value">2/3/4/6/8 plazas; recta, en L, con isla central</td>
                        </tr>
                        <tr>
                            <td class="spec-label">Resistencia fuego</td>
                            <td class="spec-value">BS 5852 Crib 5, CAL TB 117</td>
                        </tr>
                        <tr>
                            <td class="spec-label">Garantía</td>
                            <td class="spec-value">7 años estructura, 3 años tapizado</td>
                        </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- Aplicaciones -->
    <section class="section">
      <div class="content-container">
        <h2 class="section-title">Aplicaciones en proyectos hoteleros</h2>
        <div class="usos-grid">
                        <div class="uso-card">
                            <span class="uso-num">01</span>
                            <p>Lobby de hotel urbano: configuración en L de 4 módulos + 2 otomanas que crea una zona lounge informal junto a la recepción.</p>
                        </div>
                        <div class="uso-card">
                            <span class="uso-num">02</span>
                            <p>Sala de estar de planta ejecutiva: disposición lineal de 3 módulos frente a TV con otomanas laterales para apoyar bebidas y dispositivos.</p>
                        </div>
                        <div class="uso-card">
                            <span class="uso-num">03</span>
                            <p>Zona de descanso en spa o piscina cubierta: módulos con tapizado outdoor resistente a cloro y humedad, aptos para ambiente de baño.</p>
                        </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="section">
      <div class="content-container">
        <h2 class="section-title">Preguntas frecuentes</h2>
        <div class="faq-list">
                    <div class="faq-item">
                        <button class="faq-question" onclick="this.parentElement.classList.toggle('open')">
                            <span>¿Se pueden añadir módulos más adelante?</span>
                            <span class="faq-arrow">+</span>
                        </button>
                        <div class="faq-answer">
                            <p>Sí, el sistema modular permite añadir módulos adicionales en cualquier momento, incluso años después del pedido inicial. Mantenemos el mismo tejido y tonalidad de madera en stock para garantizar la uniformidad.</p>
                        </div>
                    </div>
                    <div class="faq-item">
                        <button class="faq-question" onclick="this.parentElement.classList.toggle('open')">
                            <span>¿Las fundas son lavables?</span>
                            <span class="faq-arrow">+</span>
                        </button>
                        <div class="faq-answer">
                            <p>Sí, todas las fundas (asiento, respaldo y otomana) son desenfundables y lavables a máquina a 30°C. Esto reduce el coste de mantenimiento y permite una limpieza profunda sin necesidad de productos especiales.</p>
                        </div>
                    </div>
                    <div class="faq-item">
                        <button class="faq-question" onclick="this.parentElement.classList.toggle('open')">
                            <span>¿Ofrecen muestras de tejido para validar colores?</span>
                            <span class="faq-arrow">+</span>
                        </button>
                        <div class="faq-answer">
                            <p>Sí, enviamos un muestrario completo con los 25 colores disponibles en 48 horas. Para pedidos superiores a 50 módulos, podemos teñir un color corporativo personalizado con un plazo adicional de 15 días.</p>
                        </div>
                    </div>
        </div>
      </div>
    </section>

    <!-- CTA final -->
    <section class="cta-section">
      <div class="content-container">
        <h2>Solicite una cotización para su proyecto</h2>
        <p>Respondemos en menos de 24 horas con presupuesto detallado, planos técnicos y muestras de materiales.</p>
        <a href="/contacto/" class="btn-primary">📋 Solicitar cotización ahora</a>
      </div>
    </section>
  </article>
</BaseLayout>

<style>
  .producto-page {
    font-family: var(--font-body, -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif);
    color: var(--color-text, #2C2416);
    background: var(--color-bg, #FDFCF9);
    line-height: 1.7;
  }

  /* Breadcrumb */
  .breadcrumb {
    background: var(--color-surface, #FFFFFF);
    border-bottom: 1px solid var(--color-border, #E8E3D9);
    padding: 12px 0;
  }
  .breadcrumb-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: var(--color-text-light, #6B6358);
  }
  .breadcrumb a {
    color: var(--color-text-light, #6B6358);
    text-decoration: none;
  }
  .breadcrumb a:hover { color: var(--color-primary, #1a3a5c); }
  .breadcrumb span { color: var(--color-text, #2C2416); font-weight: 500; }

  /* Producto Hero */
  .producto-hero {
    max-width: 1200px;
    margin: 0 auto;
    padding: 40px 24px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: start;
  }

  .gallery-main {
    background: #EEF0F3;
    border-radius: 8px;
    aspect-ratio: 4/3;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-light, #6B6358);
    font-size: 15px;
    text-align: center;
    padding: 40px;
  }
  .gallery-main-content h4 {
    font-size: 20px;
    margin-bottom: 8px;
    color: var(--color-primary, #1a3a5c);
  }
  .gallery-main-content p {
    font-size: 14px;
  }
  .gallery-thumbs {
    display: flex;
    gap: 8px;
    margin-top: 12px;
  }
  .gallery-thumb {
    width: 72px;
    height: 54px;
    background: #EEF0F3;
    border-radius: 4px;
    border: 2px solid transparent;
    cursor: pointer;
    transition: border-color 0.2s;
  }
  .gallery-thumb:hover, .gallery-thumb.active {
    border-color: var(--color-accent, #c9a962);
  }

  .producto-info h1 {
    font-size: 32px;
    line-height: 1.25;
    color: var(--color-text, #2C2416);
    margin-bottom: 12px;
    letter-spacing: -0.3px;
  }
  .producto-categoria {
    display: inline-block;
    background: #EEF0F3;
    color: var(--color-primary, #1a3a5c);
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    padding: 4px 12px;
    border-radius: 100px;
    margin-bottom: 16px;
  }
  .producto-intro {
    font-size: 16px;
    color: var(--color-text-light, #6B6358);
    line-height: 1.8;
    margin-bottom: 24px;
  }
  .producto-cta-group {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }
  .btn-primary {
    background: var(--color-primary, #1a3a5c);
    color: #fff;
    border: none;
    padding: 14px 32px;
    font-size: 15px;
    font-weight: 600;
    border-radius: 8px;
    cursor: pointer;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: background 0.2s;
  }
  .btn-primary:hover { background: #142d4a; }
  .btn-secondary {
    background: var(--color-surface, #FFFFFF);
    color: var(--color-primary, #1a3a5c);
    border: 2px solid var(--color-border, #E8E3D9);
    padding: 14px 32px;
    font-size: 15px;
    font-weight: 600;
    border-radius: 8px;
    cursor: pointer;
    text-decoration: none;
    transition: all 0.2s;
  }
  .btn-secondary:hover { border-color: var(--color-primary, #1a3a5c); }

  /* Secciones */
  .content-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }
  .section {
    padding: 48px 0;
    border-top: 1px solid var(--color-border, #E8E3D9);
  }
  .section-title {
    font-size: 24px;
    color: var(--color-text, #2C2416);
    margin-bottom: 28px;
    letter-spacing: -0.2px;
  }

  /* Ventajas */
  .ventajas-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }
  .ventaja-item {
    display: flex;
    gap: 16px;
    align-items: flex-start;
    padding: 24px;
    background: var(--color-surface, #FFFFFF);
    border-radius: 8px;
    box-shadow: 0 2px 12px rgba(44,36,22,0.06);
  }
  .ventaja-icon {
    font-size: 28px;
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #EEF0F3;
    border-radius: 8px;
  }
  .ventaja-content p {
    font-size: 14.5px;
    color: var(--color-text-light, #6B6358);
    line-height: 1.75;
  }

  /* Specs Table */
  .specs-wrapper {
    background: var(--color-surface, #FFFFFF);
    border-radius: 8px;
    box-shadow: 0 2px 12px rgba(44,36,22,0.06);
    overflow: hidden;
  }
  .specs-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 14.5px;
  }
  .specs-table td {
    padding: 14px 20px;
    border-bottom: 1px solid var(--color-border, #E8E3D9);
  }
  .spec-label {
    font-weight: 600;
    color: var(--color-text, #2C2416);
    width: 30%;
  }
  .spec-value {
    color: var(--color-text-light, #6B6358);
  }

  /* Usos */
  .usos-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .uso-card {
    padding: 28px 24px;
    background: var(--color-surface, #FFFFFF);
    border-radius: 8px;
    box-shadow: 0 2px 12px rgba(44,36,22,0.06);
    position: relative;
  }
  .uso-num {
    font-size: 36px;
    color: #D8DDE3;
    font-weight: bold;
    line-height: 1;
    margin-bottom: 12px;
    display: block;
  }
  .uso-card p {
    font-size: 14px;
    color: var(--color-text-light, #6B6358);
    line-height: 1.7;
  }

  /* FAQ */
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .faq-item {
    border: 1px solid var(--color-border, #E8E3D9);
    border-radius: 8px;
    background: var(--color-surface, #FFFFFF);
    overflow: hidden;
  }
  .faq-question {
    width: 100%;
    background: none;
    border: none;
    padding: 18px 24px;
    font-size: 15px;
    font-weight: 600;
    color: var(--color-text, #2C2416);
    text-align: left;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
  }
  .faq-arrow {
    font-size: 20px;
    font-weight: 300;
    color: var(--color-text-light, #6B6358);
    transition: transform 0.3s;
    flex-shrink: 0;
  }
  .faq-item.open .faq-arrow {
    transform: rotate(45deg);
  }
  .faq-answer {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
  }
  .faq-item.open .faq-answer {
    max-height: 500px;
  }
  .faq-answer p {
    padding: 0 24px 18px;
    font-size: 14.5px;
    color: var(--color-text-light, #6B6358);
    line-height: 1.75;
  }

  /* CTA */
  .cta-section {
    padding: 48px 0;
    border-top: 1px solid var(--color-border, #E8E3D9);
    text-align: center;
  }
  .cta-section h2 {
    font-size: 22px;
    margin-bottom: 12px;
  }
  .cta-section p {
    color: var(--color-text-light, #6B6358);
    margin-bottom: 24px;
  }

  @media (max-width: 768px) {
    .producto-hero {
      grid-template-columns: 1fr;
      gap: 24px;
    }
    .ventajas-grid {
      grid-template-columns: 1fr;
    }
    .usos-grid {
      grid-template-columns: 1fr;
    }
    .producto-info h1 {
      font-size: 24px;
    }
  }

    .gallery-main-img {
      width: 100%;
      height: 100%;
      object-fit: contain;
      position: absolute;
      top: 0;
      left: 0;
    }
    .gallery-thumb img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      border-radius: 4px;
    }
  </style>

<script>
  document.querySelectorAll('.faq-question').forEach(btn => {
    btn.addEventListener('click', () => {
      btn.closest('.faq-item')?.classList.toggle('open');
    });
  });
</script>
