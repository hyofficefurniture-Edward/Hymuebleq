---
import BaseLayout from '../../../layouts/BaseLayout.astro';
const pageTitle = "Productos de Mobiliario Hotelero — Página 2 | HYMUEBLE";
const pageDescription = "Segunda página del catálogo de mobiliario hotelero: sofás modulares, sofás compactos y mesitas de noche. Fabricación a medida para cadenas hoteleras.";
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
>
  <main class="productos-listing">
    <header class="listado-header">
      <div class="content-container">
        <h1>Productos de Mobiliario Hotelero — Página 2 | HYMUEBLE</h1>
        <p class="listado-subtitle">Segunda página del catálogo de mobiliario hotelero: sofás modulares, sofás compactos y mesitas de noche. Fabricación a medida para cadenas hoteleras.</p>
      </div>
    </header>

    <section class="productos-grid-section">
      <div class="content-container">
        <div class="productos-grid">
        <a href="/productos/sofa-modular-recto-tela-otomana-hotel/" class="producto-card">
          <div class="producto-card-img" style="background-image: url(/images/productos/prd-10/prd-10-01.jpg)">
            <span class="producto-card-cat">Sofás y Asientos</span>
          </div>
          <div class="producto-card-info">
            <h3>Sofá Modular Recto de Tela con Otomana para Hoteles</h3>
            <p class="producto-card-desc">El sofá modular recto con otomana está diseñado para zonas comunes de hotel que necesitan flexibilidad. Los módulos independientes se combinan formand...</p>
            <span class="producto-card-link">Ver producto →</span>
          </div>
        </a>
        <a href="/productos/sofa-moderno-dos-plazas-tapizado-hotel/" class="producto-card">
          <div class="producto-card-img" style="background-image: url(/images/productos/prd-11/prd-11-01.jpg)">
            <span class="producto-card-cat">Sofás y Asientos</span>
          </div>
          <div class="producto-card-info">
            <h3>Sofá Moderno de Dos Plazas con Tapizado Técnico para Hoteles</h3>
            <p class="producto-card-desc">El sofá de dos plazas para hoteles ocupa el espacio justo y ofrece el confort necesario para que el huésped se sienta en casa. Su diseño de líneas lim...</p>
            <span class="producto-card-link">Ver producto →</span>
          </div>
        </a>
        <a href="/productos/mesita-noche-flotante-usb-hotel/" class="producto-card">
          <div class="producto-card-img" style="background-image: url(/images/productos/prd-12/prd-12-01.jpg)">
            <span class="producto-card-cat">Mesas Auxiliares</span>
          </div>
          <div class="producto-card-info">
            <h3>Mesita de Noche Flotante con Puerto USB para Hoteles</h3>
            <p class="producto-card-desc">La mesita de noche flotante elimina las patas del suelo y con ellas los rincones donde se acumula el polvo y se enredan los cables. Anclada a la pared...</p>
            <span class="producto-card-link">Ver producto →</span>
          </div>
        </a>
        </div>
          <nav class="paginacion" aria-label="Paginación">
      <a href="/productos/" class="pag-link">← Página 1</a>
      <span class="pag-actual">Página 2</span>
    </nav>
      </div>
    </section>

    <section class="cta-section">
      <div class="content-container">
        <h2>¿Busca algo específico para su proyecto hotelero?</h2>
        <p>Consulte con nuestro equipo comercial. Fabricamos mobiliario a medida para cualquier cadena hotelera.</p>
        <a href="/contacto/" class="btn-primary">📋 Solicitar cotización</a>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .productos-listing {
    background: #FDFCF9;
  }

  .listado-header {
    background: #1a3a5c;
    color: #fff;
    padding: 64px 0 48px;
    text-align: center;
  }
  .listado-header h1 {
    font-size: 36px;
    margin-bottom: 12px;
    letter-spacing: -0.5px;
  }
  .listado-subtitle {
    font-size: 16px;
    opacity: 0.85;
    max-width: 600px;
    margin: 0 auto;
  }

  .productos-grid-section {
    padding: 48px 0;
  }
  .content-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .productos-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .producto-card {
    background: #fff;
    border-radius: 8px;
    box-shadow: 0 2px 12px rgba(44,36,22,0.06);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: box-shadow 0.2s, transform 0.2s;
    display: block;
  }
  .producto-card:hover {
    box-shadow: 0 8px 32px rgba(44,36,22,0.12);
    transform: translateY(-2px);
  }
  .producto-card-img {
    background: #EEF0F3;
    height: 200px;
    background-size: cover;
    background-position: center;
    display: flex;
    align-items: flex-start;
    justify-content: flex-end;
    padding: 16px;
  }
  .producto-card-cat {
    background: #1a3a5c;
    color: #fff;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    padding: 4px 10px;
    border-radius: 4px;
  }
  .producto-card-info {
    padding: 20px;
  }
  .producto-card-info h3 {
    font-size: 16px;
    line-height: 1.3;
    margin-bottom: 8px;
    color: #2C2416;
  }
  .producto-card-desc {
    font-size: 13.5px;
    color: #6B6358;
    line-height: 1.6;
    margin-bottom: 12px;
  }
  .producto-card-link {
    font-size: 13px;
    font-weight: 600;
    color: #1a3a5c;
  }

  .paginacion {
    display: flex;
    justify-content: center;
    gap: 16px;
    margin-top: 40px;
    padding-top: 32px;
    border-top: 1px solid #E8E3D9;
  }
  .pag-actual {
    padding: 8px 16px;
    background: #1a3a5c;
    color: #fff;
    border-radius: 6px;
    font-size: 14px;
    font-weight: 600;
  }
  .pag-link {
    padding: 8px 16px;
    border: 2px solid #E8E3D9;
    border-radius: 6px;
    font-size: 14px;
    color: #1a3a5c;
    text-decoration: none;
    font-weight: 600;
  }
  .pag-link:hover {
    border-color: #1a3a5c;
  }

  .cta-section {
    padding: 48px 0;
    border-top: 1px solid #E8E3D9;
    text-align: center;
    background: #fff;
  }
  .cta-section h2 {
    font-size: 22px;
    margin-bottom: 12px;
    color: #2C2416;
  }
  .cta-section p {
    color: #6B6358;
    margin-bottom: 24px;
  }
  .btn-primary {
    background: #1a3a5c;
    color: #fff;
    padding: 14px 32px;
    font-size: 15px;
    font-weight: 600;
    border-radius: 8px;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .btn-primary:hover {
    background: #142d4a;
  }

  @media (max-width: 768px) {
    .productos-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
