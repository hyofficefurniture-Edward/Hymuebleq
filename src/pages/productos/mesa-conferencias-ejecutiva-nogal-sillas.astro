---
import BaseLayout from '../../layouts/BaseLayout.astro';
const pageTitle = "Mesa Conferencias Ejecutiva Chapa Nogal | Mobiliario Hotelero Corporativo";
const pageDescription = "Mesa de conferencias ejecutiva con chapa de nogal FSC y sillas ergonómicas. Sistema modular tool-free, integración AV oculta, certificación BIFMA. Para hoteles y espacios corporativos.";
const canonicalUrl = `https://hymueble.com/productos/mesa-conferencias-ejecutiva-nogal-sillas/`;
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonicalURL={canonicalUrl}
>
  <!-- Schema.org JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "Mesa de Conferencias Ejecutiva con Chapa de Nogal y Sillas Ergonómicas",
    "description": "Mesa de conferencias ejecutiva con chapa de nogal FSC y sillas ergonómicas. Sistema modular tool-free, integración AV oculta, certificación BIFMA. Para hoteles y espacios corporativos.",
    "category": "Mesas",
    "brand": {
      "@type": "Brand",
      "name": "HYMUEBLE"
    },
    "manufacturer": {
      "@type": "Organization",
      "name": "Hongye Furniture Group Co., Ltd."
    },
    "offers": {
      "@type": "Offer",
      "availability": "https://schema.org/InStock",
      "priceSpecification": {
        "@type": "PriceSpecification",
        "price": "Consultar",
        "priceCurrency": "USD"
      }
    }
  })}>
  </script>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {"@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://hymueble.com/"},
      {"@type": "ListItem", "position": 2, "name": "Productos", "item": "https://hymueble.com/productos/"},
      {"@type": "ListItem", "position": 3, "name": "Mesa de Conferencias Ejecutiva con Chapa de Nogal y Sillas Ergonómicas"}
    ]
  })}>
  </script>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [{"@type": "Question", "name": "¿Es factible personalizar el color de la chapa para que combine con la decoración existente?", "acceptedAnswer": {"@type": "Answer", "text": "Sí, trabajamos con carta RAL completa para lacados y disponemos de 12 especies de chapa de madera natural. El muestrario se envía en 48 horas para que el equipo de interiorismo pueda validar la combinación in situ."}}, {"@type": "Question", "name": "¿Cómo se gestiona el cableado en configuraciones modulares grandes?", "acceptedAnswer": {"@type": "Answer", "text": "Cada módulo incorpora una regleta oculta con 4 tomas. Los módulos se conectan entre sí mediante latiguillos bajo el tablero, y todas las mesas convergen en una caja de suelo única. El plano de instalación se entrega con el pedido."}}, {"@type": "Question", "name": "¿Qué mantenimiento requiere la superficie de chapa de madera?", "acceptedAnswer": {"@type": "Answer", "text": "Mínimo. Recomendamos limpieza con paño de microfibra seco o ligeramente humedecido. La superficie lleva barniz de poliuretano mate de grado comercial que resiste manchas de café, bolígrafo y huellas dactilares."}}]
  })}>
  </script>

  <article class="producto-page">
    <!-- Breadcrumb -->
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <div class="breadcrumb-container">
        <a href="/">Inicio</a>
        <span aria-hidden="true">›</span>
        <a href="/productos/">Productos</a>
        <span aria-hidden="true">›</span>
        <span>Mesa de Conferencias Ejecutiva con Chapa de Nogal y Sillas Ergonómicas</span>
      </div>
    </nav>

    <!-- Product Hero -->
    <div class="producto-hero">
      <div class="producto-gallery">
        <div class="gallery-main">
          <div class="gallery-main-content">
            <h4>Mesa de Conferencias Ejecutiva con Chapa de Nogal y Sillas Ergonómicas</h4>
            <p>Imagen principal del producto — 5 vistas disponibles</p>
          </div>
        </div>
        <div class="gallery-thumbs">
          <div class="gallery-thumb"></div><div class="gallery-thumb"></div><div class="gallery-thumb"></div><div class="gallery-thumb"></div><div class="gallery-thumb"></div>
        </div>
      </div>

      <div class="producto-info">
        <span class="producto-categoria">Mesas</span>
        <h1>Mesa de Conferencias Ejecutiva con Chapa de Nogal y Sillas Ergonómicas</h1>
        <p class="producto-intro">La mesa de conferencias ejecutiva está diseñada para espacios donde la imagen importa tanto como la funcionalidad. Fabricada con chapa de nogal certificada FSC sobre estructura de aluminio, ofrece un acabado impecable que transmite solidez y buen gusto. El sistema modular sin herramientas permite reconfigurar la sala en menos de 20 minutos, adaptándose a reuniones de junta, formaciones o presentaciones corporativas.</p>
        <div class="producto-cta-group">
          <a href="/contacto/" class="btn-primary">📋 Solicitar cotización</a>
          <a href="/contacto/" class="btn-secondary">📞 Contactar ventas</a>
        </div>
      </div>
    </div>

    <!-- Ventajas -->
    <section class="section">
      <div class="content-container">
        <h2 class="section-title">Ventajas del producto</h2>
        <div class="ventajas-grid">
                    <div class="ventaja-item">
                        <div class="ventaja-icon">🛡️</div>
                        <div class="ventaja-content">
                            <p>La chapa de nogal con certificación FSC sobre bastidor de aluminio supera los estándares de durabilidad BIFMA en un 30%. Diseñada para resistir el uso intensivo en hoteles con salas de reuniones de alto tránsito, la superficie mantiene su aspecto original tras miles de horas de uso.</p>
                        </div>
                    </div>
                    <div class="ventaja-item">
                        <div class="ventaja-icon">📐</div>
                        <div class="ventaja-content">
                            <p>Los conectores snap-fit permiten cambiar la disposición de la sala (forma de U, aula, junta directiva) sin herramientas en menos de 20 minutos. Cada módulo admite de 1 a 12 plazas, ampliable mediante unión modular sin límite práctico de tamaño.</p>
                        </div>
                    </div>
                    <div class="ventaja-item">
                        <div class="ventaja-icon">🔧</div>
                        <div class="ventaja-content">
                            <p>Las mesas integran módulos de conectividad ocultos con puertos USB-C, HDMI y RJ45. El cableado interno gestionado elimina el desorden visual sobre la superficie de trabajo, una ventaja que los clientes corporativos valoran especialmente en presentaciones con proyección.</p>
                        </div>
                    </div>
                    <div class="ventaja-item">
                        <div class="ventaja-icon">🎨</div>
                        <div class="ventaja-content">
                            <p>Las sillas incluyen respaldo contorneado, apoyabrazos regulables en 4 direcciones y soporte lumbar integrado. La espuma de alta densidad reduce la incomodidad en sesiones largas un 22% frente a sillas de conferencia estándar.</p>
                        </div>
                    </div>
        </div>
      </div>
    </section>

    <!-- Especificaciones técnicas -->
    <section class="section">
      <div class="content-container">
        <h2 class="section-title">Especificaciones técnicas</h2>
        <div class="specs-wrapper">
          <table class="specs-table">
            <tbody>
                        <tr>
                            <td class="spec-label">Tablero</td>
                            <td class="spec-value">Chapa de nogal FSC sobre bastidor de aluminio; espesor 40 mm</td>
                        </tr>
                        <tr>
                            <td class="spec-label">Dimensiones mesa</td>
                            <td class="spec-value">Largo 300-600 cm × ancho 120-150 cm × alto 74 cm (configurable)</td>
                        </tr>
                        <tr>
                            <td class="spec-label">Dimensiones silla</td>
                            <td class="spec-value">Asiento alto 46 cm × respaldo alto 81 cm × fondo 51 cm</td>
                        </tr>
                        <tr>
                            <td class="spec-label">Capacidad</td>
                            <td class="spec-value">6-24 plazas estándar, ampliable sin límite mediante módulos</td>
                        </tr>
                        <tr>
                            <td class="spec-label">Conectividad</td>
                            <td class="spec-value">USB-C, HDMI, RJ45 ocultos; regleta integrada con 4 enchufes por módulo</td>
                        </tr>
                        <tr>
                            <td class="spec-label">Acabados</td>
                            <td class="spec-value">Nogal espresso, roble natural, lacado blanco; detalles en latón mate</td>
                        </tr>
                        <tr>
                            <td class="spec-label">Certificaciones</td>
                            <td class="spec-value">BIFMA, FSC, GREENGUARD Gold, baja emisión formaldehído</td>
                        </tr>
                        <tr>
                            <td class="spec-label">Pedido mínimo</td>
                            <td class="spec-value">30 unidades</td>
                        </tr>
                        <tr>
                            <td class="spec-label">Garantía</td>
                            <td class="spec-value">5 años estructura, 2 años componentes electrónicos</td>
                        </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- Aplicaciones -->
    <section class="section">
      <div class="content-container">
        <h2 class="section-title">Aplicaciones en proyectos hoteleros</h2>
        <div class="usos-grid">
                        <div class="uso-card">
                            <span class="uso-num">01</span>
                            <p>Sala de juntas de hotel 5 estrellas: configuración de mesa única con 16-20 plazas, integración de pantalla en pared frontal y sistema de videoconferencia oculto.</p>
                        </div>
                        <div class="uso-card">
                            <span class="uso-num">02</span>
                            <p>Centro de convenciones anexo al hotel: configuración modular para hasta 100 personas en formato aula, con mesas individuales acoplables y canalización de cableado por suelo.</p>
                        </div>
                        <div class="uso-card">
                            <span class="uso-num">03</span>
                            <p>Espacio de coworking dentro del hotel: módulos independientes de 2-4 plazas que los huéspedes ejecutivos pueden reservar por horas con toda la tecnología integrada.</p>
                        </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="section">
      <div class="content-container">
        <h2 class="section-title">Preguntas frecuentes</h2>
        <div class="faq-list">
                    <div class="faq-item">
                        <button class="faq-question" onclick="this.parentElement.classList.toggle('open')">
                            <span>¿Es factible personalizar el color de la chapa para que combine con la decoración existente?</span>
                            <span class="faq-arrow">+</span>
                        </button>
                        <div class="faq-answer">
                            <p>Sí, trabajamos con carta RAL completa para lacados y disponemos de 12 especies de chapa de madera natural. El muestrario se envía en 48 horas para que el equipo de interiorismo pueda validar la combinación in situ.</p>
                        </div>
                    </div>
                    <div class="faq-item">
                        <button class="faq-question" onclick="this.parentElement.classList.toggle('open')">
                            <span>¿Cómo se gestiona el cableado en configuraciones modulares grandes?</span>
                            <span class="faq-arrow">+</span>
                        </button>
                        <div class="faq-answer">
                            <p>Cada módulo incorpora una regleta oculta con 4 tomas. Los módulos se conectan entre sí mediante latiguillos bajo el tablero, y todas las mesas convergen en una caja de suelo única. El plano de instalación se entrega con el pedido.</p>
                        </div>
                    </div>
                    <div class="faq-item">
                        <button class="faq-question" onclick="this.parentElement.classList.toggle('open')">
                            <span>¿Qué mantenimiento requiere la superficie de chapa de madera?</span>
                            <span class="faq-arrow">+</span>
                        </button>
                        <div class="faq-answer">
                            <p>Mínimo. Recomendamos limpieza con paño de microfibra seco o ligeramente humedecido. La superficie lleva barniz de poliuretano mate de grado comercial que resiste manchas de café, bolígrafo y huellas dactilares.</p>
                        </div>
                    </div>
        </div>
      </div>
    </section>

    <!-- CTA final -->
    <section class="cta-section">
      <div class="content-container">
        <h2>Solicite una cotización para su proyecto</h2>
        <p>Respondemos en menos de 24 horas con presupuesto detallado, planos técnicos y muestras de materiales.</p>
        <a href="/contacto/" class="btn-primary">📋 Solicitar cotización ahora</a>
      </div>
    </section>
  </article>
</BaseLayout>

<style>
  .producto-page {
    font-family: var(--font-body, -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif);
    color: var(--color-text, #2C2416);
    background: var(--color-bg, #FDFCF9);
    line-height: 1.7;
  }

  /* Breadcrumb */
  .breadcrumb {
    background: var(--color-surface, #FFFFFF);
    border-bottom: 1px solid var(--color-border, #E8E3D9);
    padding: 12px 0;
  }
  .breadcrumb-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: var(--color-text-light, #6B6358);
  }
  .breadcrumb a {
    color: var(--color-text-light, #6B6358);
    text-decoration: none;
  }
  .breadcrumb a:hover { color: var(--color-primary, #1a3a5c); }
  .breadcrumb span { color: var(--color-text, #2C2416); font-weight: 500; }

  /* Producto Hero */
  .producto-hero {
    max-width: 1200px;
    margin: 0 auto;
    padding: 40px 24px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: start;
  }

  .gallery-main {
    background: #EEF0F3;
    border-radius: 8px;
    aspect-ratio: 4/3;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-light, #6B6358);
    font-size: 15px;
    text-align: center;
    padding: 40px;
  }
  .gallery-main-content h4 {
    font-size: 20px;
    margin-bottom: 8px;
    color: var(--color-primary, #1a3a5c);
  }
  .gallery-main-content p {
    font-size: 14px;
  }
  .gallery-thumbs {
    display: flex;
    gap: 8px;
    margin-top: 12px;
  }
  .gallery-thumb {
    width: 72px;
    height: 54px;
    background: #EEF0F3;
    border-radius: 4px;
    border: 2px solid transparent;
    cursor: pointer;
    transition: border-color 0.2s;
  }
  .gallery-thumb:hover, .gallery-thumb.active {
    border-color: var(--color-accent, #c9a962);
  }

  .producto-info h1 {
    font-size: 32px;
    line-height: 1.25;
    color: var(--color-text, #2C2416);
    margin-bottom: 12px;
    letter-spacing: -0.3px;
  }
  .producto-categoria {
    display: inline-block;
    background: #EEF0F3;
    color: var(--color-primary, #1a3a5c);
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    padding: 4px 12px;
    border-radius: 100px;
    margin-bottom: 16px;
  }
  .producto-intro {
    font-size: 16px;
    color: var(--color-text-light, #6B6358);
    line-height: 1.8;
    margin-bottom: 24px;
  }
  .producto-cta-group {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }
  .btn-primary {
    background: var(--color-primary, #1a3a5c);
    color: #fff;
    border: none;
    padding: 14px 32px;
    font-size: 15px;
    font-weight: 600;
    border-radius: 8px;
    cursor: pointer;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: background 0.2s;
  }
  .btn-primary:hover { background: #142d4a; }
  .btn-secondary {
    background: var(--color-surface, #FFFFFF);
    color: var(--color-primary, #1a3a5c);
    border: 2px solid var(--color-border, #E8E3D9);
    padding: 14px 32px;
    font-size: 15px;
    font-weight: 600;
    border-radius: 8px;
    cursor: pointer;
    text-decoration: none;
    transition: all 0.2s;
  }
  .btn-secondary:hover { border-color: var(--color-primary, #1a3a5c); }

  /* Secciones */
  .content-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }
  .section {
    padding: 48px 0;
    border-top: 1px solid var(--color-border, #E8E3D9);
  }
  .section-title {
    font-size: 24px;
    color: var(--color-text, #2C2416);
    margin-bottom: 28px;
    letter-spacing: -0.2px;
  }

  /* Ventajas */
  .ventajas-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }
  .ventaja-item {
    display: flex;
    gap: 16px;
    align-items: flex-start;
    padding: 24px;
    background: var(--color-surface, #FFFFFF);
    border-radius: 8px;
    box-shadow: 0 2px 12px rgba(44,36,22,0.06);
  }
  .ventaja-icon {
    font-size: 28px;
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #EEF0F3;
    border-radius: 8px;
  }
  .ventaja-content p {
    font-size: 14.5px;
    color: var(--color-text-light, #6B6358);
    line-height: 1.75;
  }

  /* Specs Table */
  .specs-wrapper {
    background: var(--color-surface, #FFFFFF);
    border-radius: 8px;
    box-shadow: 0 2px 12px rgba(44,36,22,0.06);
    overflow: hidden;
  }
  .specs-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 14.5px;
  }
  .specs-table td {
    padding: 14px 20px;
    border-bottom: 1px solid var(--color-border, #E8E3D9);
  }
  .spec-label {
    font-weight: 600;
    color: var(--color-text, #2C2416);
    width: 30%;
  }
  .spec-value {
    color: var(--color-text-light, #6B6358);
  }

  /* Usos */
  .usos-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .uso-card {
    padding: 28px 24px;
    background: var(--color-surface, #FFFFFF);
    border-radius: 8px;
    box-shadow: 0 2px 12px rgba(44,36,22,0.06);
    position: relative;
  }
  .uso-num {
    font-size: 36px;
    color: #D8DDE3;
    font-weight: bold;
    line-height: 1;
    margin-bottom: 12px;
    display: block;
  }
  .uso-card p {
    font-size: 14px;
    color: var(--color-text-light, #6B6358);
    line-height: 1.7;
  }

  /* FAQ */
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .faq-item {
    border: 1px solid var(--color-border, #E8E3D9);
    border-radius: 8px;
    background: var(--color-surface, #FFFFFF);
    overflow: hidden;
  }
  .faq-question {
    width: 100%;
    background: none;
    border: none;
    padding: 18px 24px;
    font-size: 15px;
    font-weight: 600;
    color: var(--color-text, #2C2416);
    text-align: left;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
  }
  .faq-arrow {
    font-size: 20px;
    font-weight: 300;
    color: var(--color-text-light, #6B6358);
    transition: transform 0.3s;
    flex-shrink: 0;
  }
  .faq-item.open .faq-arrow {
    transform: rotate(45deg);
  }
  .faq-answer {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
  }
  .faq-item.open .faq-answer {
    max-height: 500px;
  }
  .faq-answer p {
    padding: 0 24px 18px;
    font-size: 14.5px;
    color: var(--color-text-light, #6B6358);
    line-height: 1.75;
  }

  /* CTA */
  .cta-section {
    padding: 48px 0;
    border-top: 1px solid var(--color-border, #E8E3D9);
    text-align: center;
  }
  .cta-section h2 {
    font-size: 22px;
    margin-bottom: 12px;
  }
  .cta-section p {
    color: var(--color-text-light, #6B6358);
    margin-bottom: 24px;
  }

  @media (max-width: 768px) {
    .producto-hero {
      grid-template-columns: 1fr;
      gap: 24px;
    }
    .ventajas-grid {
      grid-template-columns: 1fr;
    }
    .usos-grid {
      grid-template-columns: 1fr;
    }
    .producto-info h1 {
      font-size: 24px;
    }
  }
</style>

<script>
  document.querySelectorAll('.faq-question').forEach(btn => {
    btn.addEventListener('click', function() {
      this.closest('.faq-item').classList.toggle('open');
    });
  });
</script>
