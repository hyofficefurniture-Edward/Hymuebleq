---
import BaseLayout from '../../layouts/BaseLayout.astro';
const pageTitle = "Mesita Noche Flotante USB Hotel | Mobiliario Habitación Hotelera | Fabricante";
const pageDescription = "Mesita de noche flotante con puerto USB-A/C y enchufe integrado para hoteles. Instalación en pared con sistema antivotco, acabados personalizables. Pedido mínimo 30 uds.";
const canonicalUrl = "/productos/mesita-noche-flotante-usb-hotel/";
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonicalPath={canonicalUrl}
>
  <!-- Schema.org JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "Mesita de Noche Flotante con Puerto USB para Hoteles",
    "description": "Mesita de noche flotante con puerto USB-A/C y enchufe integrado para hoteles. Instalación en pared con sistema antivotco, acabados personalizables. Pedido mínimo 30 uds.",
    "category": "Mesas Auxiliares",
    "brand": {
      "@type": "Brand",
      "name": "HYMUEBLE"
    },
    "manufacturer": {
      "@type": "Organization",
      "name": "Hongye Furniture Group Co., Ltd."
    },
    "offers": {
      "@type": "Offer",
      "availability": "https://schema.org/InStock",
      "priceSpecification": {
        "@type": "PriceSpecification",
        "price": "Consultar",
        "priceCurrency": "USD"
      }
    }
  })}>
  </script>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {"@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://hymueble.com/"},
      {"@type": "ListItem", "position": 2, "name": "Productos", "item": "https://hymueble.com/productos/"},
      {"@type": "ListItem", "position": 3, "name": "Mesita de Noche Flotante con Puerto USB para Hoteles"}
    ]
  })}>
  </script>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [{"@type": "Question", "name": "¿Se necesita una pared de ladrillo o sirve tabique de pladur?", "acceptedAnswer": {"@type": "Answer", "text": "Funciona en ambos casos. Para tabique de pladur suministramos tacos específicos de expansión para placa de yeso con carga de rotura de 50 kg por punto. Con 4 puntos de fijación, el sistema soporta los 110 kg declarados sin problema."}}, {"@type": "Question", "name": "¿Se puede pedir con doble cajón en lugar de bandeja abierta?", "acceptedAnswer": {"@type": "Answer", "text": "Sí, podemos sustituir la bandeja inferior por un segundo cajón de las mismas características. El precio varía ligeramente y el plazo se mantiene. Solo hay que indicarlo en la orden de pedido."}}, {"@type": "Question", "name": "¿Los puertos USB se pueden configurar para voltajes internacionales?", "acceptedAnswer": {"@type": "Answer", "text": "Sí. El módulo eléctrico se fabrica según la normativa del país de destino (110V/220V, tipo de enchufe A/B/C/G/I). Solo necesitamos saber el país de instalación para configurar el módulo correcto."}}]
  })}>
  </script>

  <article class="producto-page">
    <!-- Breadcrumb -->
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <div class="breadcrumb-container">
        <a href="/">Inicio</a>
        <span aria-hidden="true">›</span>
        <a href="/productos/">Productos</a>
        <span aria-hidden="true">›</span>
        <span>Mesita de Noche Flotante con Puerto USB para Hoteles</span>
      </div>
    </nav>

    <!-- Product Hero -->
    <div class="producto-hero">
      <div class="producto-gallery">
        <div class="gallery-main">
          <img class="gallery-main-img" src="/images/productos/prd-12/prd-12-01.jpg" alt="Mesita de Noche Flotante con Puerto USB para" loading="eager" width="600" height="600">
          <div class="gallery-main-content" style="display:none"><h4>Mesita de Noche Flotante con Puerto USB para Hoteles</h4>
            <p>Imagen principal del producto — 5 vistas disponibles</p>
          </div>
        </div>
        <div class="gallery-thumbs">
          <div class="gallery-thumb active"><img src="/images/productos/prd-12/prd-12-01.jpg" alt="Mesita de Noche Flotante con - vista 1 de 5" loading="lazy" width="120" height="120" onclick="document.querySelector('.gallery-main-img').src='/images/productos/prd-12/prd-12-01.jpg'"></div><div class="gallery-thumb"><img src="/images/productos/prd-12/prd-12-02.jpg" alt="Mesita de Noche Flotante con - vista 2 de 5" loading="lazy" width="120" height="120" onclick="document.querySelector('.gallery-main-img').src='/images/productos/prd-12/prd-12-02.jpg'"></div><div class="gallery-thumb"><img src="/images/productos/prd-12/prd-12-03.jpg" alt="Mesita de Noche Flotante con - vista 3 de 5" loading="lazy" width="120" height="120" onclick="document.querySelector('.gallery-main-img').src='/images/productos/prd-12/prd-12-03.jpg'"></div><div class="gallery-thumb"><img src="/images/productos/prd-12/prd-12-04.jpg" alt="Mesita de Noche Flotante con - vista 4 de 5" loading="lazy" width="120" height="120" onclick="document.querySelector('.gallery-main-img').src='/images/productos/prd-12/prd-12-04.jpg'"></div><div class="gallery-thumb"><img src="/images/productos/prd-12/prd-12-05.jpg" alt="Mesita de Noche Flotante con - vista 5 de 5" loading="lazy" width="120" height="120" onclick="document.querySelector('.gallery-main-img').src='/images/productos/prd-12/prd-12-05.jpg'"></div>
        </div>
      </div>

      <div class="producto-info">
        <span class="producto-categoria">Mesas Auxiliares</span>
        <h1>Mesita de Noche Flotante con Puerto USB para Hoteles</h1>
        <p class="producto-intro">La mesita de noche flotante elimina las patas del suelo y con ellas los rincones donde se acumula el polvo y se enredan los cables. Anclada a la pared mediante un soporte de acero con fijación antivuelco, soporta hasta 110 kg sin ceder un milímetro. El módulo de conectividad integrado ofrece al huésped puertos USB-A, USB-C y un enchufe de 220V, todo oculto en el panel trasero para mantener la superficie despejada.</p>
        <div class="producto-cta-group">
          <a href="/contacto/" class="btn-primary">📋 Solicitar cotización</a>
          <a href="/contacto/" class="btn-secondary">📞 Contactar ventas</a>
        </div>
      </div>
    </div>

    <!-- Ventajas -->
    <section class="section">
      <div class="content-container">
        <h2 class="section-title">Ventajas del producto</h2>
        <div class="ventajas-grid">
                    <div class="ventaja-item">
                        <div class="ventaja-icon">🛡️</div>
                        <div class="ventaja-content">
                            <p>Al no tener patas, la mesita flotante libera el suelo por completo y facilita la limpieza de la habitación. El robot aspirador o la fregona pasan sin obstáculos, y el personal de pisos ahorra 90 segundos por habitación, lo que suma 75 minutos al día en un hotel de 50 habitaciones.</p>
                        </div>
                    </div>
                    <div class="ventaja-item">
                        <div class="ventaja-icon">📐</div>
                        <div class="ventaja-content">
                            <p>El módulo de carga integrado (USB-A, USB-C y enchufe) reduce un 40% las llamadas a recepción pidiendo adaptadores o alargadores. Los cables quedan ocultos tras el panel trasero y el huésped solo ve una superficie limpia con sus dispositivos cargando.</p>
                        </div>
                    </div>
                    <div class="ventaja-item">
                        <div class="ventaja-icon">🔧</div>
                        <div class="ventaja-content">
                            <p>El cajón con cierre suave ofrece un 20% más de volumen interior que las mesitas de noche estándar gracias al diseño sin patas, que permite aprovechar todo el fondo del mueble. Capacidad para un libro, gafas, cargador y objetos personales sin sensación de desorden.</p>
                        </div>
                    </div>
        </div>
      </div>
    </section>

    <!-- Especificaciones técnicas -->
    <section class="section">
      <div class="content-container">
        <h2 class="section-title">Especificaciones técnicas</h2>
        <div class="specs-wrapper">
          <table class="specs-table">
            <tbody>
                        <tr>
                            <td class="spec-label">Material</td>
                            <td class="spec-value">Chapa de madera natural sobre MDF E1 hidrófugo; cantos ABS 2 mm</td>
                        </tr>
                        <tr>
                            <td class="spec-label">Dimensiones</td>
                            <td class="spec-value">Ancho 60 × fondo 40 × alto 24 cm (fondo total incluido soporte: 45 cm)</td>
                        </tr>
                        <tr>
                            <td class="spec-label">Cajón</td>
                            <td class="spec-value">Full-extension cierre suave; interior 52×34×10 cm</td>
                        </tr>
                        <tr>
                            <td class="spec-label">Bandeja inferior</td>
                            <td class="spec-value">Abierta: 52×32 cm, útil para revistas, tablet o libro de lectura</td>
                        </tr>
                        <tr>
                            <td class="spec-label">Conectividad</td>
                            <td class="spec-value">2× USB-A + 1× USB-C + 1 enchufe 220V (certificación UL); cableado oculto</td>
                        </tr>
                        <tr>
                            <td class="spec-label">Iluminación opcional</td>
                            <td class="spec-value">LED 3000K bajo la mesita, 2W, regulable, efecto luz ambiente indirecta</td>
                        </tr>
                        <tr>
                            <td class="spec-label">Fijación</td>
                            <td class="spec-value">Soporte acero 8 mm con 4 tacos de expansión; sistema antivuelco integrado</td>
                        </tr>
                        <tr>
                            <td class="spec-label">Carga máxima</td>
                            <td class="spec-value">110 kg distribuidos; cajón 45 kg</td>
                        </tr>
                        <tr>
                            <td class="spec-label">Certificaciones</td>
                            <td class="spec-value">CAL TB 117, BS 5852 Crib 5; componentes eléctricos UL</td>
                        </tr>
                        <tr>
                            <td class="spec-label">Garantía</td>
                            <td class="spec-value">5 años estructura y herrajes; 2 años componentes eléctricos</td>
                        </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- Aplicaciones -->
    <section class="section">
      <div class="content-container">
        <h2 class="section-title">Aplicaciones en proyectos hoteleros</h2>
        <div class="usos-grid">
                        <div class="uso-card">
                            <span class="uso-num">01</span>
                            <p>Habitación de hotel con cama king size: dos mesitas flotantes simétricas a ambos lados de la cama, con iluminación LED inferior que crea un efecto de cama flotante muy valorado en hoteles de diseño.</p>
                        </div>
                        <div class="uso-card">
                            <span class="uso-num">02</span>
                            <p>Habitación doble: una mesita entre las dos camas individuales, con doble módulo de carga para que cada huésped tenga sus propios puertos sin compartir.</p>
                        </div>
                        <div class="uso-card">
                            <span class="uso-num">03</span>
                            <p>Suite con zona de trabajo: mesita flotante junto al escritorio como superficie auxiliar para apoyar documentos, con los puertos de carga orientados hacia la zona de trabajo.</p>
                        </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="section">
      <div class="content-container">
        <h2 class="section-title">Preguntas frecuentes</h2>
        <div class="faq-list">
                    <div class="faq-item">
                        <button class="faq-question" onclick="this.parentElement.classList.toggle('open')">
                            <span>¿Se necesita una pared de ladrillo o sirve tabique de pladur?</span>
                            <span class="faq-arrow">+</span>
                        </button>
                        <div class="faq-answer">
                            <p>Funciona en ambos casos. Para tabique de pladur suministramos tacos específicos de expansión para placa de yeso con carga de rotura de 50 kg por punto. Con 4 puntos de fijación, el sistema soporta los 110 kg declarados sin problema.</p>
                        </div>
                    </div>
                    <div class="faq-item">
                        <button class="faq-question" onclick="this.parentElement.classList.toggle('open')">
                            <span>¿Se puede pedir con doble cajón en lugar de bandeja abierta?</span>
                            <span class="faq-arrow">+</span>
                        </button>
                        <div class="faq-answer">
                            <p>Sí, podemos sustituir la bandeja inferior por un segundo cajón de las mismas características. El precio varía ligeramente y el plazo se mantiene. Solo hay que indicarlo en la orden de pedido.</p>
                        </div>
                    </div>
                    <div class="faq-item">
                        <button class="faq-question" onclick="this.parentElement.classList.toggle('open')">
                            <span>¿Los puertos USB se pueden configurar para voltajes internacionales?</span>
                            <span class="faq-arrow">+</span>
                        </button>
                        <div class="faq-answer">
                            <p>Sí. El módulo eléctrico se fabrica según la normativa del país de destino (110V/220V, tipo de enchufe A/B/C/G/I). Solo necesitamos saber el país de instalación para configurar el módulo correcto.</p>
                        </div>
                    </div>
        </div>
      </div>
    </section>

    <!-- CTA final -->
    <section class="cta-section">
      <div class="content-container">
        <h2>Solicite una cotización para su proyecto</h2>
        <p>Respondemos en menos de 24 horas con presupuesto detallado, planos técnicos y muestras de materiales.</p>
        <a href="/contacto/" class="btn-primary">📋 Solicitar cotización ahora</a>
      </div>
    </section>
  </article>
</BaseLayout>

<style>
  .producto-page {
    font-family: var(--font-body, -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif);
    color: var(--color-text, #2C2416);
    background: var(--color-bg, #FDFCF9);
    line-height: 1.7;
  }

  /* Breadcrumb */
  .breadcrumb {
    background: var(--color-surface, #FFFFFF);
    border-bottom: 1px solid var(--color-border, #E8E3D9);
    padding: 12px 0;
  }
  .breadcrumb-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: var(--color-text-light, #6B6358);
  }
  .breadcrumb a {
    color: var(--color-text-light, #6B6358);
    text-decoration: none;
  }
  .breadcrumb a:hover { color: var(--color-primary, #1a3a5c); }
  .breadcrumb span { color: var(--color-text, #2C2416); font-weight: 500; }

  /* Producto Hero */
  .producto-hero {
    max-width: 1200px;
    margin: 0 auto;
    padding: 40px 24px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: start;
  }

  .gallery-main {
    background: #EEF0F3;
    border-radius: 8px;
    aspect-ratio: 4/3;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-light, #6B6358);
    font-size: 15px;
    text-align: center;
    padding: 40px;
  }
  .gallery-main-content h4 {
    font-size: 20px;
    margin-bottom: 8px;
    color: var(--color-primary, #1a3a5c);
  }
  .gallery-main-content p {
    font-size: 14px;
  }
  .gallery-thumbs {
    display: flex;
    gap: 8px;
    margin-top: 12px;
  }
  .gallery-thumb {
    width: 72px;
    height: 54px;
    background: #EEF0F3;
    border-radius: 4px;
    border: 2px solid transparent;
    cursor: pointer;
    transition: border-color 0.2s;
  }
  .gallery-thumb:hover, .gallery-thumb.active {
    border-color: var(--color-accent, #c9a962);
  }

  .producto-info h1 {
    font-size: 32px;
    line-height: 1.25;
    color: var(--color-text, #2C2416);
    margin-bottom: 12px;
    letter-spacing: -0.3px;
  }
  .producto-categoria {
    display: inline-block;
    background: #EEF0F3;
    color: var(--color-primary, #1a3a5c);
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    padding: 4px 12px;
    border-radius: 100px;
    margin-bottom: 16px;
  }
  .producto-intro {
    font-size: 16px;
    color: var(--color-text-light, #6B6358);
    line-height: 1.8;
    margin-bottom: 24px;
  }
  .producto-cta-group {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }
  .btn-primary {
    background: var(--color-primary, #1a3a5c);
    color: #fff;
    border: none;
    padding: 14px 32px;
    font-size: 15px;
    font-weight: 600;
    border-radius: 8px;
    cursor: pointer;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: background 0.2s;
  }
  .btn-primary:hover { background: #142d4a; }
  .btn-secondary {
    background: var(--color-surface, #FFFFFF);
    color: var(--color-primary, #1a3a5c);
    border: 2px solid var(--color-border, #E8E3D9);
    padding: 14px 32px;
    font-size: 15px;
    font-weight: 600;
    border-radius: 8px;
    cursor: pointer;
    text-decoration: none;
    transition: all 0.2s;
  }
  .btn-secondary:hover { border-color: var(--color-primary, #1a3a5c); }

  /* Secciones */
  .content-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }
  .section {
    padding: 48px 0;
    border-top: 1px solid var(--color-border, #E8E3D9);
  }
  .section-title {
    font-size: 24px;
    color: var(--color-text, #2C2416);
    margin-bottom: 28px;
    letter-spacing: -0.2px;
  }

  /* Ventajas */
  .ventajas-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }
  .ventaja-item {
    display: flex;
    gap: 16px;
    align-items: flex-start;
    padding: 24px;
    background: var(--color-surface, #FFFFFF);
    border-radius: 8px;
    box-shadow: 0 2px 12px rgba(44,36,22,0.06);
  }
  .ventaja-icon {
    font-size: 28px;
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #EEF0F3;
    border-radius: 8px;
  }
  .ventaja-content p {
    font-size: 14.5px;
    color: var(--color-text-light, #6B6358);
    line-height: 1.75;
  }

  /* Specs Table */
  .specs-wrapper {
    background: var(--color-surface, #FFFFFF);
    border-radius: 8px;
    box-shadow: 0 2px 12px rgba(44,36,22,0.06);
    overflow: hidden;
  }
  .specs-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 14.5px;
  }
  .specs-table td {
    padding: 14px 20px;
    border-bottom: 1px solid var(--color-border, #E8E3D9);
  }
  .spec-label {
    font-weight: 600;
    color: var(--color-text, #2C2416);
    width: 30%;
  }
  .spec-value {
    color: var(--color-text-light, #6B6358);
  }

  /* Usos */
  .usos-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .uso-card {
    padding: 28px 24px;
    background: var(--color-surface, #FFFFFF);
    border-radius: 8px;
    box-shadow: 0 2px 12px rgba(44,36,22,0.06);
    position: relative;
  }
  .uso-num {
    font-size: 36px;
    color: #D8DDE3;
    font-weight: bold;
    line-height: 1;
    margin-bottom: 12px;
    display: block;
  }
  .uso-card p {
    font-size: 14px;
    color: var(--color-text-light, #6B6358);
    line-height: 1.7;
  }

  /* FAQ */
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .faq-item {
    border: 1px solid var(--color-border, #E8E3D9);
    border-radius: 8px;
    background: var(--color-surface, #FFFFFF);
    overflow: hidden;
  }
  .faq-question {
    width: 100%;
    background: none;
    border: none;
    padding: 18px 24px;
    font-size: 15px;
    font-weight: 600;
    color: var(--color-text, #2C2416);
    text-align: left;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
  }
  .faq-arrow {
    font-size: 20px;
    font-weight: 300;
    color: var(--color-text-light, #6B6358);
    transition: transform 0.3s;
    flex-shrink: 0;
  }
  .faq-item.open .faq-arrow {
    transform: rotate(45deg);
  }
  .faq-answer {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
  }
  .faq-item.open .faq-answer {
    max-height: 500px;
  }
  .faq-answer p {
    padding: 0 24px 18px;
    font-size: 14.5px;
    color: var(--color-text-light, #6B6358);
    line-height: 1.75;
  }

  /* CTA */
  .cta-section {
    padding: 48px 0;
    border-top: 1px solid var(--color-border, #E8E3D9);
    text-align: center;
  }
  .cta-section h2 {
    font-size: 22px;
    margin-bottom: 12px;
  }
  .cta-section p {
    color: var(--color-text-light, #6B6358);
    margin-bottom: 24px;
  }

  @media (max-width: 768px) {
    .producto-hero {
      grid-template-columns: 1fr;
      gap: 24px;
    }
    .ventajas-grid {
      grid-template-columns: 1fr;
    }
    .usos-grid {
      grid-template-columns: 1fr;
    }
    .producto-info h1 {
      font-size: 24px;
    }
  }

    .gallery-main-img {
      width: 100%;
      height: 100%;
      object-fit: contain;
      position: absolute;
      top: 0;
      left: 0;
    }
    .gallery-thumb img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      border-radius: 4px;
    }
  </style>

<script>
  document.querySelectorAll('.faq-question').forEach(btn => {
    btn.addEventListener('click', () => {
      btn.closest('.faq-item')?.classList.toggle('open');
    });
  });
</script>
