---
import BaseLayout from '../../layouts/BaseLayout.astro';
const pageTitle = "Armario Hotelero Empotrado Chapa Madera | Fabricante Muebles Hotel";
const pageDescription = "Armario empotrado hotelero con chapa de madera natural. Fabricación a medida para proyectos hoteleros 3-5 estrellas. Acabados personalizables, herrajes suaves, pedido mínimo 30 unidades.";
const canonicalUrl = "/productos/armario-hotelero-empotrado-chapa-madera/";
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonicalPath={canonicalUrl}
>
  <!-- Schema.org JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "Armario Hotelero Empotrado con Chapa de Madera Natural",
    "description": "Armario empotrado hotelero con chapa de madera natural. Fabricación a medida para proyectos hoteleros 3-5 estrellas. Acabados personalizables, herrajes suaves, pedido mínimo 30 unidades.",
    "category": "Armarios y Almacenaje",
    "brand": {
      "@type": "Brand",
      "name": "HYMUEBLE"
    },
    "manufacturer": {
      "@type": "Organization",
      "name": "Hongye Furniture Group Co., Ltd."
    },
    "offers": {
      "@type": "Offer",
      "availability": "https://schema.org/InStock",
      "priceSpecification": {
        "@type": "PriceSpecification",
        "price": "Consultar",
        "priceCurrency": "USD"
      }
    }
  })}>
  </script>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {"@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://hymueble.com/"},
      {"@type": "ListItem", "position": 2, "name": "Productos", "item": "https://hymueble.com/productos/"},
      {"@type": "ListItem", "position": 3, "name": "Armario Hotelero Empotrado con Chapa de Madera Natural"}
    ]
  })}>
  </script>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [{"@type": "Question", "name": "¿Se puede adaptar el armario a huecos con medidas no estándar?", "acceptedAnswer": {"@type": "Answer", "text": "Sí. Fabricamos cada armario a medida según los planos de obra. Solo necesitamos las dimensiones exactas del hueco (ancho, alto, fondo) y el equipo técnico diseña la solución óptima, incluyendo recortes para vigas, conductos o instalaciones existentes."}}, {"@type": "Question", "name": "¿Qué mantenimiento requiere la chapa de madera en entorno hotelero?", "acceptedAnswer": {"@type": "Answer", "text": "Mínimo. La chapa lleva un barniz mate de poliuretano que repele el polvo y resiste rayaduras leves. Recomendamos limpieza semanal con paño de microfibra ligeramente humedecido. El acabado mantiene su aspecto original durante 8-10 años con uso normal."}}, {"@type": "Question", "name": "¿Incluyen el montaje en obra?", "acceptedAnswer": {"@type": "Answer", "text": "Ofrecemos dos modalidades: envío de kits premontados con manual de instalación (recomendado para proyectos de menos de 50 unidades) o servicio completo de montaje con equipo técnico desplazado. El montaje profesional toma 45-60 minutos por unidad."}}]
  })}>
  </script>

  <article class="producto-page">
    <!-- Breadcrumb -->
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <div class="breadcrumb-container">
        <a href="/">Inicio</a>
        <span aria-hidden="true">›</span>
        <a href="/productos/">Productos</a>
        <span aria-hidden="true">›</span>
        <span>Armario Hotelero Empotrado con Chapa de Madera Natural</span>
      </div>
    </nav>

    <!-- Product Hero -->
    <div class="producto-hero">
      <div class="producto-gallery">
        <div class="gallery-main">
          <img class="gallery-main-img" src="/images/productos/prd-01/prd-01-01.jpg" alt="Producto principal" loading="eager" width="600" height="600">
          <div class="gallery-main-content" style="display:none"><h4>Armario Hotelero Empotrado con Chapa de Madera Natural</h4>
            <p>Imagen principal del producto — 6 vistas disponibles</p>
          </div>
        </div>
        <div class="gallery-thumbs">
          <div class="gallery-thumb active"><img src="/images/productos/prd-01/prd-01-01.jpg" alt="Vista 1" loading="lazy" width="120" height="120" onclick="document.querySelector('.gallery-main-img').src='/images/productos/prd-01/prd-01-01.jpg'"></div><div class="gallery-thumb"><img src="/images/productos/prd-01/prd-01-02.jpg" alt="Vista 2" loading="lazy" width="120" height="120" onclick="document.querySelector('.gallery-main-img').src='/images/productos/prd-01/prd-01-02.jpg'"></div><div class="gallery-thumb"><img src="/images/productos/prd-01/prd-01-03.jpg" alt="Vista 3" loading="lazy" width="120" height="120" onclick="document.querySelector('.gallery-main-img').src='/images/productos/prd-01/prd-01-03.jpg'"></div><div class="gallery-thumb"><img src="/images/productos/prd-01/prd-01-04.jpg" alt="Vista 4" loading="lazy" width="120" height="120" onclick="document.querySelector('.gallery-main-img').src='/images/productos/prd-01/prd-01-04.jpg'"></div><div class="gallery-thumb"></div><div class="gallery-thumb"></div>
        </div>
      </div>

      <div class="producto-info">
        <span class="producto-categoria">Armarios y Almacenaje</span>
        <h1>Armario Hotelero Empotrado con Chapa de Madera Natural</h1>
        <p class="producto-intro">Nuestro armario hotelero empotrado combina la calidez de la chapa de madera natural con la funcionalidad que exige la hotelería moderna. Diseñado para optimizar el espacio en habitaciones de 3 a 5 estrellas, cada unidad se fabrica bajo pedido con materiales certificados E1 y acabados resistentes al uso intensivo. Una solución de almacenaje que aporta distinción al huésped y rentabilidad al proyecto.</p>
        <div class="producto-cta-group">
          <a href="/contacto/" class="btn-primary">📋 Solicitar cotización</a>
          <a href="/contacto/" class="btn-secondary">📞 Contactar ventas</a>
        </div>
      </div>
    </div>

    <!-- Ventajas -->
    <section class="section">
      <div class="content-container">
        <h2 class="section-title">Ventajas del producto</h2>
        <div class="ventajas-grid">
                    <div class="ventaja-item">
                        <div class="ventaja-icon">🛡️</div>
                        <div class="ventaja-content">
                            <p>Fabricado con chapa de madera natural sobre tablero MDF E1, este armario soporta más de 50.000 ciclos de apertura sin deterioro visible. Los cantos sellados con ABS de 2 mm evitan la absorción de humedad, garantizando una vida útil superior a 10 años en entornos hoteleros de alto tránsito.</p>
                        </div>
                    </div>
                    <div class="ventaja-item">
                        <div class="ventaja-icon">📐</div>
                        <div class="ventaja-content">
                            <p>El sistema de puertas correderas con guías de aluminio anodizado aprovecha cada centímetro disponible. Frente a los armarios batientes convencionales, este diseño ahorra un 30% de espacio de circulación en la habitación, permitiendo layouts más amplios y funcionales.</p>
                        </div>
                    </div>
                    <div class="ventaja-item">
                        <div class="ventaja-icon">🔧</div>
                        <div class="ventaja-content">
                            <p>Equipado con herrajes Blum de cierre suave en cajones y puertas, iluminación LED interior con sensor de apertura, y barra para colgar regulable en altura. El interior incluye compartimentos modulares para caja fuerte, minibar y maletero, adaptándose a los estándares de cualquier cadena hotelera internacional.</p>
                        </div>
                    </div>
                    <div class="ventaja-item">
                        <div class="ventaja-icon">🎨</div>
                        <div class="ventaja-content">
                            <p>Ofrecemos personalización completa: desde el tipo de chapa (roble, nogal, fresno) hasta el tono del lacado. Se pueden integrar detalles como tiradores de piel, frentes acanalados o paneles decorativos a juego con el cabecero. El departamento técnico elabora planos de detalle para cada proyecto en un plazo de 5 días hábiles.</p>
                        </div>
                    </div>
        </div>
      </div>
    </section>

    <!-- Especificaciones técnicas -->
    <section class="section">
      <div class="content-container">
        <h2 class="section-title">Especificaciones técnicas</h2>
        <div class="specs-wrapper">
          <table class="specs-table">
            <tbody>
                        <tr>
                            <td class="spec-label">Material principal</td>
                            <td class="spec-value">Chapa de madera natural sobre MDF E1 hidrófugo</td>
                        </tr>
                        <tr>
                            <td class="spec-label">Dimensiones estándar</td>
                            <td class="spec-value">Ancho 1200-2400 mm × Fondo 600 mm × Alto 2200 mm (configurable)</td>
                        </tr>
                        <tr>
                            <td class="spec-label">Herrajes</td>
                            <td class="spec-value">Blum: correderas, bisagras cierre suave, cajones full-extension</td>
                        </tr>
                        <tr>
                            <td class="spec-label">Iluminación</td>
                            <td class="spec-value">LED 4000K interior con sensor de puerta, 12V, consumo &lt;5W</td>
                        </tr>
                        <tr>
                            <td class="spec-label">Acabados</td>
                            <td class="spec-value">Lacado mate/satinado, chapa natural barnizada, RAL a medida</td>
                        </tr>
                        <tr>
                            <td class="spec-label">Capacidad</td>
                            <td class="spec-value">2-4 cuerpos modulares, configurables con caja fuerte, minibar, zapatero</td>
                        </tr>
                        <tr>
                            <td class="spec-label">Certificaciones</td>
                            <td class="spec-value">FSC, E1 emisiones, resistencia fuego Clase B-s1,d0 (bajo pedido)</td>
                        </tr>
                        <tr>
                            <td class="spec-label">Pedido mínimo</td>
                            <td class="spec-value">30 unidades</td>
                        </tr>
                        <tr>
                            <td class="spec-label">Plazo fabricación</td>
                            <td class="spec-value">25-35 días laborables según volumen</td>
                        </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- Aplicaciones -->
    <section class="section">
      <div class="content-container">
        <h2 class="section-title">Aplicaciones en proyectos hoteleros</h2>
        <div class="usos-grid">
                        <div class="uso-card">
                            <span class="uso-num">01</span>
                            <p>Habitación estándar de hotel 4-5 estrellas: instalación en pared principal con integración de TV, minibar y caja fuerte en módulos independientes.</p>
                        </div>
                        <div class="uso-card">
                            <span class="uso-num">02</span>
                            <p>Suite presidencial: configuración de vestidor completo con doble cuerpo de armarios, iluminación interior regulable y espejo de cuerpo entero integrado en las puertas.</p>
                        </div>
                        <div class="uso-card">
                            <span class="uso-num">03</span>
                            <p>Apartahotel o residencia de larga estancia: armario con mayor fondo (650 mm) y compartimento para electrodomésticos, adaptado a huéspedes que permanecen más de 7 noches.</p>
                        </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="section">
      <div class="content-container">
        <h2 class="section-title">Preguntas frecuentes</h2>
        <div class="faq-list">
                    <div class="faq-item">
                        <button class="faq-question" onclick="this.parentElement.classList.toggle('open')">
                            <span>¿Se puede adaptar el armario a huecos con medidas no estándar?</span>
                            <span class="faq-arrow">+</span>
                        </button>
                        <div class="faq-answer">
                            <p>Sí. Fabricamos cada armario a medida según los planos de obra. Solo necesitamos las dimensiones exactas del hueco (ancho, alto, fondo) y el equipo técnico diseña la solución óptima, incluyendo recortes para vigas, conductos o instalaciones existentes.</p>
                        </div>
                    </div>
                    <div class="faq-item">
                        <button class="faq-question" onclick="this.parentElement.classList.toggle('open')">
                            <span>¿Qué mantenimiento requiere la chapa de madera en entorno hotelero?</span>
                            <span class="faq-arrow">+</span>
                        </button>
                        <div class="faq-answer">
                            <p>Mínimo. La chapa lleva un barniz mate de poliuretano que repele el polvo y resiste rayaduras leves. Recomendamos limpieza semanal con paño de microfibra ligeramente humedecido. El acabado mantiene su aspecto original durante 8-10 años con uso normal.</p>
                        </div>
                    </div>
                    <div class="faq-item">
                        <button class="faq-question" onclick="this.parentElement.classList.toggle('open')">
                            <span>¿Incluyen el montaje en obra?</span>
                            <span class="faq-arrow">+</span>
                        </button>
                        <div class="faq-answer">
                            <p>Ofrecemos dos modalidades: envío de kits premontados con manual de instalación (recomendado para proyectos de menos de 50 unidades) o servicio completo de montaje con equipo técnico desplazado. El montaje profesional toma 45-60 minutos por unidad.</p>
                        </div>
                    </div>
        </div>
      </div>
    </section>

    <!-- CTA final -->
    <section class="cta-section">
      <div class="content-container">
        <h2>Solicite una cotización para su proyecto</h2>
        <p>Respondemos en menos de 24 horas con presupuesto detallado, planos técnicos y muestras de materiales.</p>
        <a href="/contacto/" class="btn-primary">📋 Solicitar cotización ahora</a>
      </div>
    </section>
  </article>
</BaseLayout>

<style>
  .producto-page {
    font-family: var(--font-body, -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif);
    color: var(--color-text, #2C2416);
    background: var(--color-bg, #FDFCF9);
    line-height: 1.7;
  }

  /* Breadcrumb */
  .breadcrumb {
    background: var(--color-surface, #FFFFFF);
    border-bottom: 1px solid var(--color-border, #E8E3D9);
    padding: 12px 0;
  }
  .breadcrumb-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: var(--color-text-light, #6B6358);
  }
  .breadcrumb a {
    color: var(--color-text-light, #6B6358);
    text-decoration: none;
  }
  .breadcrumb a:hover { color: var(--color-primary, #1a3a5c); }
  .breadcrumb span { color: var(--color-text, #2C2416); font-weight: 500; }

  /* Producto Hero */
  .producto-hero {
    max-width: 1200px;
    margin: 0 auto;
    padding: 40px 24px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: start;
  }

  .gallery-main {
    background: #EEF0F3;
    border-radius: 8px;
    aspect-ratio: 4/3;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-light, #6B6358);
    font-size: 15px;
    text-align: center;
    padding: 40px;
  }
  .gallery-main-content h4 {
    font-size: 20px;
    margin-bottom: 8px;
    color: var(--color-primary, #1a3a5c);
  }
  .gallery-main-content p {
    font-size: 14px;
  }
  .gallery-thumbs {
    display: flex;
    gap: 8px;
    margin-top: 12px;
  }
  .gallery-thumb {
    width: 72px;
    height: 54px;
    background: #EEF0F3;
    border-radius: 4px;
    border: 2px solid transparent;
    cursor: pointer;
    transition: border-color 0.2s;
  }
  .gallery-thumb:hover, .gallery-thumb.active {
    border-color: var(--color-accent, #c9a962);
  }

  .producto-info h1 {
    font-size: 32px;
    line-height: 1.25;
    color: var(--color-text, #2C2416);
    margin-bottom: 12px;
    letter-spacing: -0.3px;
  }
  .producto-categoria {
    display: inline-block;
    background: #EEF0F3;
    color: var(--color-primary, #1a3a5c);
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    padding: 4px 12px;
    border-radius: 100px;
    margin-bottom: 16px;
  }
  .producto-intro {
    font-size: 16px;
    color: var(--color-text-light, #6B6358);
    line-height: 1.8;
    margin-bottom: 24px;
  }
  .producto-cta-group {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }
  .btn-primary {
    background: var(--color-primary, #1a3a5c);
    color: #fff;
    border: none;
    padding: 14px 32px;
    font-size: 15px;
    font-weight: 600;
    border-radius: 8px;
    cursor: pointer;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: background 0.2s;
  }
  .btn-primary:hover { background: #142d4a; }
  .btn-secondary {
    background: var(--color-surface, #FFFFFF);
    color: var(--color-primary, #1a3a5c);
    border: 2px solid var(--color-border, #E8E3D9);
    padding: 14px 32px;
    font-size: 15px;
    font-weight: 600;
    border-radius: 8px;
    cursor: pointer;
    text-decoration: none;
    transition: all 0.2s;
  }
  .btn-secondary:hover { border-color: var(--color-primary, #1a3a5c); }

  /* Secciones */
  .content-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }
  .section {
    padding: 48px 0;
    border-top: 1px solid var(--color-border, #E8E3D9);
  }
  .section-title {
    font-size: 24px;
    color: var(--color-text, #2C2416);
    margin-bottom: 28px;
    letter-spacing: -0.2px;
  }

  /* Ventajas */
  .ventajas-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }
  .ventaja-item {
    display: flex;
    gap: 16px;
    align-items: flex-start;
    padding: 24px;
    background: var(--color-surface, #FFFFFF);
    border-radius: 8px;
    box-shadow: 0 2px 12px rgba(44,36,22,0.06);
  }
  .ventaja-icon {
    font-size: 28px;
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #EEF0F3;
    border-radius: 8px;
  }
  .ventaja-content p {
    font-size: 14.5px;
    color: var(--color-text-light, #6B6358);
    line-height: 1.75;
  }

  /* Specs Table */
  .specs-wrapper {
    background: var(--color-surface, #FFFFFF);
    border-radius: 8px;
    box-shadow: 0 2px 12px rgba(44,36,22,0.06);
    overflow: hidden;
  }
  .specs-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 14.5px;
  }
  .specs-table td {
    padding: 14px 20px;
    border-bottom: 1px solid var(--color-border, #E8E3D9);
  }
  .spec-label {
    font-weight: 600;
    color: var(--color-text, #2C2416);
    width: 30%;
  }
  .spec-value {
    color: var(--color-text-light, #6B6358);
  }

  /* Usos */
  .usos-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .uso-card {
    padding: 28px 24px;
    background: var(--color-surface, #FFFFFF);
    border-radius: 8px;
    box-shadow: 0 2px 12px rgba(44,36,22,0.06);
    position: relative;
  }
  .uso-num {
    font-size: 36px;
    color: #D8DDE3;
    font-weight: bold;
    line-height: 1;
    margin-bottom: 12px;
    display: block;
  }
  .uso-card p {
    font-size: 14px;
    color: var(--color-text-light, #6B6358);
    line-height: 1.7;
  }

  /* FAQ */
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .faq-item {
    border: 1px solid var(--color-border, #E8E3D9);
    border-radius: 8px;
    background: var(--color-surface, #FFFFFF);
    overflow: hidden;
  }
  .faq-question {
    width: 100%;
    background: none;
    border: none;
    padding: 18px 24px;
    font-size: 15px;
    font-weight: 600;
    color: var(--color-text, #2C2416);
    text-align: left;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
  }
  .faq-arrow {
    font-size: 20px;
    font-weight: 300;
    color: var(--color-text-light, #6B6358);
    transition: transform 0.3s;
    flex-shrink: 0;
  }
  .faq-item.open .faq-arrow {
    transform: rotate(45deg);
  }
  .faq-answer {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
  }
  .faq-item.open .faq-answer {
    max-height: 500px;
  }
  .faq-answer p {
    padding: 0 24px 18px;
    font-size: 14.5px;
    color: var(--color-text-light, #6B6358);
    line-height: 1.75;
  }

  /* CTA */
  .cta-section {
    padding: 48px 0;
    border-top: 1px solid var(--color-border, #E8E3D9);
    text-align: center;
  }
  .cta-section h2 {
    font-size: 22px;
    margin-bottom: 12px;
  }
  .cta-section p {
    color: var(--color-text-light, #6B6358);
    margin-bottom: 24px;
  }

  @media (max-width: 768px) {
    .producto-hero {
      grid-template-columns: 1fr;
      gap: 24px;
    }
    .ventajas-grid {
      grid-template-columns: 1fr;
    }
    .usos-grid {
      grid-template-columns: 1fr;
    }
    .producto-info h1 {
      font-size: 24px;
    }
  }

    .gallery-main-img {
      width: 100%;
      height: 100%;
      object-fit: contain;
      position: absolute;
      top: 0;
      left: 0;
    }
    .gallery-thumb img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      border-radius: 4px;
    }
  </style>

<script>
  document.querySelectorAll('.faq-question').forEach(btn => {
    btn.addEventListener('click', () => {
      btn.closest('.faq-item')?.classList.toggle('open');
    });
  });
</script>
