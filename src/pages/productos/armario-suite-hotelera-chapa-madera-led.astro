---
import BaseLayout from '../../layouts/BaseLayout.astro';
const pageTitle = "Armario Suite Hotelera Chapa Madera LED | Fabricante Mobiliario 5 Estrellas";
const pageDescription = "Armario de suite hotelera con chapa de madera, cajonera integrada e iluminación LED interior. Diseño para hoteles 4-5 estrellas, acabados personalizables, pedido mínimo 30 uds.";
const canonicalUrl = "/productos/armario-suite-hotelera-chapa-madera-led/";
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonicalPath={canonicalUrl}
>
  <!-- Schema.org JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "Armario de Suite Hotelera con Chapa de Madera, Cajonera e Iluminación LED",
    "description": "Armario de suite hotelera con chapa de madera, cajonera integrada e iluminación LED interior. Diseño para hoteles 4-5 estrellas, acabados personalizables, pedido mínimo 30 uds.",
    "category": "Armarios y Almacenaje",
    "brand": {
      "@type": "Brand",
      "name": "HYMUEBLE"
    },
    "manufacturer": {
      "@type": "Organization",
      "name": "Hongye Furniture Group Co., Ltd."
    },
    "offers": {
      "@type": "Offer",
      "availability": "https://schema.org/InStock",
      "priceSpecification": {
        "@type": "PriceSpecification",
        "price": "Consultar",
        "priceCurrency": "USD"
      }
    }
  })}>
  </script>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {"@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://hymueble.com/"},
      {"@type": "ListItem", "position": 2, "name": "Productos", "item": "https://hymueble.com/productos/"},
      {"@type": "ListItem", "position": 3, "name": "Armario de Suite Hotelera con Chapa de Madera, Cajonera e Iluminación LED"}
    ]
  })}>
  </script>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [{"@type": "Question", "name": "¿El sistema LED se puede conectar al sistema de gestión de habitación?", "acceptedAnswer": {"@type": "Answer", "text": "Sí. El driver LED admite conexión a sistemas de control centralizado mediante contacto seco. El armario puede integrarse en las escenas de iluminación de la habitación (bienvenida, descanso, limpieza) sin modificaciones adicionales."}}, {"@type": "Question", "name": "¿Se puede añadir caja fuerte empotrada?", "acceptedAnswer": {"@type": "Answer", "text": "Sí, uno de los módulos de cajonera puede sustituirse por un hueco preparado para caja fuerte estándar de hotel (modelos Elsafe o similar). Solo hay que indicarlo en el pedido y prever la toma de corriente en la pared trasera."}}, {"@type": "Question", "name": "¿Cuánto tiempo lleva instalar un armario en la habitación?", "acceptedAnswer": {"@type": "Answer", "text": "El armario llega en módulos premontados. Dos instaladores montan un armario estándar de 240 cm en aproximadamente 90 minutos, incluyendo la fijación a pared, la conexión LED y los ajustes finales de puertas y cajones."}}]
  })}>
  </script>

  <article class="producto-page">
    <!-- Breadcrumb -->
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <div class="breadcrumb-container">
        <a href="/">Inicio</a>
        <span aria-hidden="true">›</span>
        <a href="/productos/">Productos</a>
        <span aria-hidden="true">›</span>
        <span>Armario de Suite Hotelera con Chapa de Madera, Cajonera e Iluminación LED</span>
      </div>
    </nav>

    <!-- Product Hero -->
    <div class="producto-hero">
      <div class="producto-gallery">
        <div class="gallery-main">
          <img class="gallery-main-img" src="/images/productos/prd-08/prd-08-01.jpg" alt="Armario de Suite Hotelera con Chapa de Madera," loading="eager" width="600" height="600">
          <div class="gallery-main-content" style="display:none"><h4>Armario de Suite Hotelera con Chapa de Madera, Cajonera e Iluminación LED</h4>
            <p>Imagen principal del producto — 5 vistas disponibles</p>
          </div>
        </div>
        <div class="gallery-thumbs">
          <div class="gallery-thumb active"><img src="/images/productos/prd-08/prd-08-01.jpg" alt="Armario de Suite Hotelera con - vista 1 de 5" loading="lazy" width="120" height="120" onclick="document.querySelector('.gallery-main-img').src='/images/productos/prd-08/prd-08-01.jpg'"></div><div class="gallery-thumb"><img src="/images/productos/prd-08/prd-08-02.jpg" alt="Armario de Suite Hotelera con - vista 2 de 5" loading="lazy" width="120" height="120" onclick="document.querySelector('.gallery-main-img').src='/images/productos/prd-08/prd-08-02.jpg'"></div><div class="gallery-thumb"><img src="/images/productos/prd-08/prd-08-03.jpg" alt="Armario de Suite Hotelera con - vista 3 de 5" loading="lazy" width="120" height="120" onclick="document.querySelector('.gallery-main-img').src='/images/productos/prd-08/prd-08-03.jpg'"></div><div class="gallery-thumb"><img src="/images/productos/prd-08/prd-08-04.jpg" alt="Armario de Suite Hotelera con - vista 4 de 5" loading="lazy" width="120" height="120" onclick="document.querySelector('.gallery-main-img').src='/images/productos/prd-08/prd-08-04.jpg'"></div><div class="gallery-thumb"><img src="/images/productos/prd-08/prd-08-05.jpg" alt="Armario de Suite Hotelera con - vista 5 de 5" loading="lazy" width="120" height="120" onclick="document.querySelector('.gallery-main-img').src='/images/productos/prd-08/prd-08-05.jpg'"></div>
        </div>
      </div>

      <div class="producto-info">
        <span class="producto-categoria">Armarios y Almacenaje</span>
        <h1>Armario de Suite Hotelera con Chapa de Madera, Cajonera e Iluminación LED</h1>
        <p class="producto-intro">El armario de suite hotelera está concebido para habitaciones donde el huésped espera algo más que un lugar donde colgar la ropa. Con cajonera integrada, iluminación LED interior, zapatero extraíble y un espejo de cuerpo entero en la puerta, cada detalle está pensado para que la experiencia de deshacer la maleta resulte un placer. Fabricado con chapa de madera natural y herrajes de precisión.</p>
        <div class="producto-cta-group">
          <a href="/contacto/" class="btn-primary">📋 Solicitar cotización</a>
          <a href="/contacto/" class="btn-secondary">📞 Contactar ventas</a>
        </div>
      </div>
    </div>

    <!-- Ventajas -->
    <section class="section">
      <div class="content-container">
        <h2 class="section-title">Ventajas del producto</h2>
        <div class="ventajas-grid">
                    <div class="ventaja-item">
                        <div class="ventaja-icon">🛡️</div>
                        <div class="ventaja-content">
                            <p>El interior se ilumina por completo al abrir las puertas gracias a las tiras LED de 4000K con sensor magnético. No hay zonas oscuras ni interruptores que buscar: el huésped ve toda su ropa de un vistazo. El consumo es inferior a 8W, lo que no afecta al balance energético de la habitación.</p>
                        </div>
                    </div>
                    <div class="ventaja-item">
                        <div class="ventaja-icon">📐</div>
                        <div class="ventaja-content">
                            <p>La cajonera integrada de 3+2 cuerpos ofrece compartimentos independientes para ropa interior, accesorios y documentos. Los cajones, con guías full-extension y cierre suave, se deslizan con una suavidad que transmite calidad al primer contacto. Capacidad total: 120 litros.</p>
                        </div>
                    </div>
                    <div class="ventaja-item">
                        <div class="ventaja-icon">🔧</div>
                        <div class="ventaja-content">
                            <p>El espejo de cuerpo entero va integrado en una de las puertas correderas, ahorrando el espacio que ocuparía un espejo independiente en la pared. Un detalle que las cadenas hoteleras valoran porque libera metros lineales de pared para otros usos.</p>
                        </div>
                    </div>
        </div>
      </div>
    </section>

    <!-- Especificaciones técnicas -->
    <section class="section">
      <div class="content-container">
        <h2 class="section-title">Especificaciones técnicas</h2>
        <div class="specs-wrapper">
          <table class="specs-table">
            <tbody>
                        <tr>
                            <td class="spec-label">Material</td>
                            <td class="spec-value">Chapa de madera natural sobre MDF E1 hidrófugo; cantos ABS 2 mm</td>
                        </tr>
                        <tr>
                            <td class="spec-label">Dimensiones</td>
                            <td class="spec-value">Ancho 2400 × fondo 600 × alto 2300 mm (configurable por módulos)</td>
                        </tr>
                        <tr>
                            <td class="spec-label">Composición interior</td>
                            <td class="spec-value">Barra colgar doble altura + cajonera 5 cuerpos + zapatero extraíble + balda superior</td>
                        </tr>
                        <tr>
                            <td class="spec-label">Puertas</td>
                            <td class="spec-value">Correderas con guías aluminio anodizado y freno de cierre suave</td>
                        </tr>
                        <tr>
                            <td class="spec-label">Iluminación</td>
                            <td class="spec-value">LED 4000K, 8W, sensor magnético de puerta, driver 12V oculto</td>
                        </tr>
                        <tr>
                            <td class="spec-label">Espejo</td>
                            <td class="spec-value">Integrado en puerta (600×1800 mm), cristal plateado 5 mm, cantos pulidos</td>
                        </tr>
                        <tr>
                            <td class="spec-label">Herrajes</td>
                            <td class="spec-value">Blum: cajones full-extension, bisagras clip, amortiguadores integrados</td>
                        </tr>
                        <tr>
                            <td class="spec-label">Certificaciones</td>
                            <td class="spec-value">FSC, E1, resistencia fuego Clase B-s1,d0 (bajo pedido)</td>
                        </tr>
                        <tr>
                            <td class="spec-label">Garantía</td>
                            <td class="spec-value">5 años estructura y herrajes, 2 años sistema LED</td>
                        </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- Aplicaciones -->
    <section class="section">
      <div class="content-container">
        <h2 class="section-title">Aplicaciones en proyectos hoteleros</h2>
        <div class="usos-grid">
                        <div class="uso-card">
                            <span class="uso-num">01</span>
                            <p>Suite presidencial: armario de 3 módulos (360 cm) con zona de él y zona de ella independientes, compartimento para joyero de seguridad y banqueta tapizada interior.</p>
                        </div>
                        <div class="uso-card">
                            <span class="uso-num">02</span>
                            <p>Junior suite: armario de 2 módulos (240 cm) con espejo integrado y cajonera completa, pensado para estancias de 2-4 noches con equipaje estándar.</p>
                        </div>
                        <div class="uso-card">
                            <span class="uso-num">03</span>
                            <p>Habitación executive: versión compacta de 180 cm para estancias de negocios de 1-2 noches, priorizando la barra para colgar trajes sobre la cajonera.</p>
                        </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="section">
      <div class="content-container">
        <h2 class="section-title">Preguntas frecuentes</h2>
        <div class="faq-list">
                    <div class="faq-item">
                        <button class="faq-question" onclick="this.parentElement.classList.toggle('open')">
                            <span>¿El sistema LED se puede conectar al sistema de gestión de habitación?</span>
                            <span class="faq-arrow">+</span>
                        </button>
                        <div class="faq-answer">
                            <p>Sí. El driver LED admite conexión a sistemas de control centralizado mediante contacto seco. El armario puede integrarse en las escenas de iluminación de la habitación (bienvenida, descanso, limpieza) sin modificaciones adicionales.</p>
                        </div>
                    </div>
                    <div class="faq-item">
                        <button class="faq-question" onclick="this.parentElement.classList.toggle('open')">
                            <span>¿Se puede añadir caja fuerte empotrada?</span>
                            <span class="faq-arrow">+</span>
                        </button>
                        <div class="faq-answer">
                            <p>Sí, uno de los módulos de cajonera puede sustituirse por un hueco preparado para caja fuerte estándar de hotel (modelos Elsafe o similar). Solo hay que indicarlo en el pedido y prever la toma de corriente en la pared trasera.</p>
                        </div>
                    </div>
                    <div class="faq-item">
                        <button class="faq-question" onclick="this.parentElement.classList.toggle('open')">
                            <span>¿Cuánto tiempo lleva instalar un armario en la habitación?</span>
                            <span class="faq-arrow">+</span>
                        </button>
                        <div class="faq-answer">
                            <p>El armario llega en módulos premontados. Dos instaladores montan un armario estándar de 240 cm en aproximadamente 90 minutos, incluyendo la fijación a pared, la conexión LED y los ajustes finales de puertas y cajones.</p>
                        </div>
                    </div>
        </div>
      </div>
    </section>

    <!-- CTA final -->
    <section class="cta-section">
      <div class="content-container">
        <h2>Solicite una cotización para su proyecto</h2>
        <p>Respondemos en menos de 24 horas con presupuesto detallado, planos técnicos y muestras de materiales.</p>
        <a href="/contacto/" class="btn-primary">📋 Solicitar cotización ahora</a>
      </div>
    </section>
  </article>
</BaseLayout>

<style>
  .producto-page {
    font-family: var(--font-body, -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif);
    color: var(--color-text, #2C2416);
    background: var(--color-bg, #FDFCF9);
    line-height: 1.7;
  }

  /* Breadcrumb */
  .breadcrumb {
    background: var(--color-surface, #FFFFFF);
    border-bottom: 1px solid var(--color-border, #E8E3D9);
    padding: 12px 0;
  }
  .breadcrumb-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: var(--color-text-light, #6B6358);
  }
  .breadcrumb a {
    color: var(--color-text-light, #6B6358);
    text-decoration: none;
  }
  .breadcrumb a:hover { color: var(--color-primary, #1a3a5c); }
  .breadcrumb span { color: var(--color-text, #2C2416); font-weight: 500; }

  /* Producto Hero */
  .producto-hero {
    max-width: 1200px;
    margin: 0 auto;
    padding: 40px 24px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: start;
  }

  .gallery-main {
    background: #EEF0F3;
    border-radius: 8px;
    aspect-ratio: 4/3;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-light, #6B6358);
    font-size: 15px;
    text-align: center;
    padding: 40px;
  }
  .gallery-main-content h4 {
    font-size: 20px;
    margin-bottom: 8px;
    color: var(--color-primary, #1a3a5c);
  }
  .gallery-main-content p {
    font-size: 14px;
  }
  .gallery-thumbs {
    display: flex;
    gap: 8px;
    margin-top: 12px;
  }
  .gallery-thumb {
    width: 72px;
    height: 54px;
    background: #EEF0F3;
    border-radius: 4px;
    border: 2px solid transparent;
    cursor: pointer;
    transition: border-color 0.2s;
  }
  .gallery-thumb:hover, .gallery-thumb.active {
    border-color: var(--color-accent, #c9a962);
  }

  .producto-info h1 {
    font-size: 32px;
    line-height: 1.25;
    color: var(--color-text, #2C2416);
    margin-bottom: 12px;
    letter-spacing: -0.3px;
  }
  .producto-categoria {
    display: inline-block;
    background: #EEF0F3;
    color: var(--color-primary, #1a3a5c);
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    padding: 4px 12px;
    border-radius: 100px;
    margin-bottom: 16px;
  }
  .producto-intro {
    font-size: 16px;
    color: var(--color-text-light, #6B6358);
    line-height: 1.8;
    margin-bottom: 24px;
  }
  .producto-cta-group {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }
  .btn-primary {
    background: var(--color-primary, #1a3a5c);
    color: #fff;
    border: none;
    padding: 14px 32px;
    font-size: 15px;
    font-weight: 600;
    border-radius: 8px;
    cursor: pointer;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: background 0.2s;
  }
  .btn-primary:hover { background: #142d4a; }
  .btn-secondary {
    background: var(--color-surface, #FFFFFF);
    color: var(--color-primary, #1a3a5c);
    border: 2px solid var(--color-border, #E8E3D9);
    padding: 14px 32px;
    font-size: 15px;
    font-weight: 600;
    border-radius: 8px;
    cursor: pointer;
    text-decoration: none;
    transition: all 0.2s;
  }
  .btn-secondary:hover { border-color: var(--color-primary, #1a3a5c); }

  /* Secciones */
  .content-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }
  .section {
    padding: 48px 0;
    border-top: 1px solid var(--color-border, #E8E3D9);
  }
  .section-title {
    font-size: 24px;
    color: var(--color-text, #2C2416);
    margin-bottom: 28px;
    letter-spacing: -0.2px;
  }

  /* Ventajas */
  .ventajas-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }
  .ventaja-item {
    display: flex;
    gap: 16px;
    align-items: flex-start;
    padding: 24px;
    background: var(--color-surface, #FFFFFF);
    border-radius: 8px;
    box-shadow: 0 2px 12px rgba(44,36,22,0.06);
  }
  .ventaja-icon {
    font-size: 28px;
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #EEF0F3;
    border-radius: 8px;
  }
  .ventaja-content p {
    font-size: 14.5px;
    color: var(--color-text-light, #6B6358);
    line-height: 1.75;
  }

  /* Specs Table */
  .specs-wrapper {
    background: var(--color-surface, #FFFFFF);
    border-radius: 8px;
    box-shadow: 0 2px 12px rgba(44,36,22,0.06);
    overflow: hidden;
  }
  .specs-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 14.5px;
  }
  .specs-table td {
    padding: 14px 20px;
    border-bottom: 1px solid var(--color-border, #E8E3D9);
  }
  .spec-label {
    font-weight: 600;
    color: var(--color-text, #2C2416);
    width: 30%;
  }
  .spec-value {
    color: var(--color-text-light, #6B6358);
  }

  /* Usos */
  .usos-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .uso-card {
    padding: 28px 24px;
    background: var(--color-surface, #FFFFFF);
    border-radius: 8px;
    box-shadow: 0 2px 12px rgba(44,36,22,0.06);
    position: relative;
  }
  .uso-num {
    font-size: 36px;
    color: #D8DDE3;
    font-weight: bold;
    line-height: 1;
    margin-bottom: 12px;
    display: block;
  }
  .uso-card p {
    font-size: 14px;
    color: var(--color-text-light, #6B6358);
    line-height: 1.7;
  }

  /* FAQ */
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .faq-item {
    border: 1px solid var(--color-border, #E8E3D9);
    border-radius: 8px;
    background: var(--color-surface, #FFFFFF);
    overflow: hidden;
  }
  .faq-question {
    width: 100%;
    background: none;
    border: none;
    padding: 18px 24px;
    font-size: 15px;
    font-weight: 600;
    color: var(--color-text, #2C2416);
    text-align: left;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
  }
  .faq-arrow {
    font-size: 20px;
    font-weight: 300;
    color: var(--color-text-light, #6B6358);
    transition: transform 0.3s;
    flex-shrink: 0;
  }
  .faq-item.open .faq-arrow {
    transform: rotate(45deg);
  }
  .faq-answer {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
  }
  .faq-item.open .faq-answer {
    max-height: 500px;
  }
  .faq-answer p {
    padding: 0 24px 18px;
    font-size: 14.5px;
    color: var(--color-text-light, #6B6358);
    line-height: 1.75;
  }

  /* CTA */
  .cta-section {
    padding: 48px 0;
    border-top: 1px solid var(--color-border, #E8E3D9);
    text-align: center;
  }
  .cta-section h2 {
    font-size: 22px;
    margin-bottom: 12px;
  }
  .cta-section p {
    color: var(--color-text-light, #6B6358);
    margin-bottom: 24px;
  }

  @media (max-width: 768px) {
    .producto-hero {
      grid-template-columns: 1fr;
      gap: 24px;
    }
    .ventajas-grid {
      grid-template-columns: 1fr;
    }
    .usos-grid {
      grid-template-columns: 1fr;
    }
    .producto-info h1 {
      font-size: 24px;
    }
  }

    .gallery-main-img {
      width: 100%;
      height: 100%;
      object-fit: contain;
      position: absolute;
      top: 0;
      left: 0;
    }
    .gallery-thumb img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      border-radius: 4px;
    }
  </style>

<script>
  document.querySelectorAll('.faq-question').forEach(btn => {
    btn.addEventListener('click', () => {
      btn.closest('.faq-item')?.classList.toggle('open');
    });
  });
</script>
