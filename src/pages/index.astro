---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHead from "../components/SectionHead.astro";
import CategoryGrid from "../components/CategoryGrid.astro";
import ProjectCard from "../components/ProjectCard.astro";
import ProcessSteps from "../components/ProcessSteps.astro";
import FactoryEvidence from "../components/FactoryEvidence.astro";
import TrustStrip from "../components/TrustStrip.astro";
import FAQTabs from "../components/FAQTabs.astro";
import CTA from "../components/CTA.astro";
import ScrollRail from "../components/ScrollRail.astro";
import { brand, metrics, projects, qualityCheckpoints, qualityProofs, showrooms } from "../data/site";
---
<BaseLayout
  title="Hymueble | Muebles para proyectos B2B en Latinoamérica"
  description="Hymueble ofrece mobiliario para proyectos B2B en mercados hispanos: hoteles, oficinas, salud, educación y residencial, con fabricación directa en China."
  keywords={["mobiliario para proyectos B2B", "muebles comerciales", "fabricación directa en China", "fabricante de muebles", "proveedor de mobiliario", "mobiliario hotelero", "mobiliario de oficina"]}
  image="/assets/hymueble/generated/home-virtual-showroom-atrium.webp"
>
  <section class="home-hero">
    <div class="container home-hero-grid">
      <div class="home-hero-copy">
        <p class="eyebrow">Proveedor directo para proyectos comerciales</p>
        <h1>Muebles para proyectos B2B en Latinoamérica, directo de fábrica en China</h1>
        <p class="lead">Mobiliario para hoteles, oficinas y proyectos comerciales con selección, producción, control de calidad y soporte de exportación desde China.</p>
        <div class="btn-row">
          <a class="btn primary" href="/contacto/">Solicitar cotización</a>
          <a class="btn ghost light" href={brand.showroom}>Explorar showroom virtual</a>
        </div>
      </div>
      <div class="home-hero-visual">
        <img class="home-hero-bg" src={encodeURI("/assets/hymueble/generated/home-virtual-showroom-atrium.webp")} alt="Showroom virtual de mobiliario comercial Hymueble" loading="eager" decoding="async" fetchpriority="high" />
      </div>
    </div>
    <div class="container home-hero-proof">
      <span>Sin intermediarios</span>
      <span>5 sectores B2B</span>
      <span>Control de calidad</span>
      <span>Exportación y embalaje</span>
    </div>
  </section>

  <section class="section alt">
    <div class="container">
      <div class="metric-grid">
        {metrics.map((metric) => (
          <div class="metric">
            <strong>{metric.value}</strong>
            <span>{metric.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section showroom-section" id="showrooms">
    <div class="container showroom-grid">
      <div class="showroom-copy">
        <p class="eyebrow">Experiencia remota</p>
        <h2>Showrooms virtuales para revisar antes de cotizar</h2>
        <p>Explora espacios reales por sector y comparte referencias más claras antes de pedir una propuesta.</p>
        <ScrollRail label="Showrooms virtuales por sector">
          <div class="showroom-options" data-scroll-track>
            {showrooms.map((showroom, index) => (
              <a class:list={["showroom-option-card", { featured: index === 0 }]} href={showroom.href} data-showroom-modal data-showroom-title={`Showroom virtual de ${showroom.sector}`}>
                <img src={encodeURI(showroom.image)} alt={`Showroom virtual de ${showroom.sector}`} loading="lazy" decoding="async" />
                <span class="showroom-option-index">{String(index + 1).padStart(2, "0")}</span>
                <strong>{showroom.sector}</strong>
                <span>
                  {showroom.sector === "Hoteles" && "Habitaciones, lobby y áreas públicas."}
                  {showroom.sector === "Oficinas" && "Puestos, salas y recepción corporativa."}
                  {showroom.sector === "Salud" && "Habitaciones, espera y consulta."}
                  {showroom.sector === "Educación" && "Aulas, biblioteca y espacios comunes."}
                </span>
                <small>Ver recorrido</small>
              </a>
            ))}
          </div>
        </ScrollRail>
        <div class="btn-row">
          <a class="btn primary" href="/showroom/">Ver todos los showrooms</a>
          <a class="btn line light" href="/contacto/">Enviar requerimientos</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container video-panel">
      <div>
        <p class="eyebrow">Video corporativo</p>
        <h2>Conoce la fábrica antes de iniciar una cotización</h2>
        <p>Una primera revisión visual ayuda a compradores, contratistas y diseñadores a entender escala, proceso y capacidad antes de enviar planos o cantidades.</p>
        <div class="btn-row">
          <a class="btn primary" href="/contacto/">Consultar ahora</a>
          <a class="btn line" href={brand.whatsapp} target="_blank" rel="noreferrer">WhatsApp</a>
        </div>
      </div>
      <div class="video-frame video-embed">
        <iframe
          src="https://www.youtube.com/embed/a1ECkth6WnQ?rel=0&modestbranding=1"
          title="Video corporativo de fábrica Hymueble"
          loading="lazy"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          referrerpolicy="strict-origin-when-cross-origin"
          allowfullscreen
        ></iframe>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHead
        eyebrow="Catálogos por sector"
        title="Mobiliario para cada tipo de proyecto"
        text="Catálogos y suministro B2B para los cinco sectores que más demandan mobiliario a escala, con opciones para compras por volumen, remodelaciones y distribución."
      />
      <CategoryGrid />
    </div>
  </section>

  <section class="section route-bridge-section">
    <div class="container route-bridge">
      <div class="route-bridge-copy">
        <p class="eyebrow">Cómo avanzar</p>
        <h2>Elige la ruta según tu etapa de compra</h2>
        <p>Catálogo para explorar familias, proyectos para revisar alcance y contacto para enviar planos, cantidades o una lista inicial.</p>
      </div>
      <div class="route-bridge-grid" aria-label="Rutas principales para compradores B2B">
        <a class="route-bridge-card" href="/catalogo/">
          <span>01</span>
          <strong>Explorar catálogo</strong>
            <p>Revisa sectores, espacios y familias de mobiliario.</p>
        </a>
        <a class="route-bridge-card" href="/proyectos/">
          <span>02</span>
          <strong>Ver rutas de proyecto</strong>
            <p>Evalúa alcance, proceso y referencias de proyecto.</p>
        </a>
        <a class="route-bridge-card strong" href="/contacto/">
          <span>03</span>
          <strong>Enviar requerimientos</strong>
            <p>Comparte ciudad, espacios, cantidades y plazo estimado.</p>
        </a>
      </div>
    </div>
  </section>

  <section class="section alt">
    <div class="container">
      <SectionHead
        eyebrow="Prueba comercial"
        title="Proyectos reales de mobiliario B2B"
        text="Hoteles, oficinas y espacios comerciales en Latinoamérica y el mundo. Cada referencia ayuda a evaluar experiencia antes de hacer una consulta."
      />
      <ScrollRail label="Proyectos destacados">
        <div class="card-grid home-project-rail" data-scroll-track>
          {projects.map((project) => <ProjectCard project={project} imageField="homeImage" />)}
        </div>
      </ScrollRail>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHead
        eyebrow="Proceso"
        title="De la consulta a la entrega: solución integral para tu proyecto"
        text="Selección, cotización, diseño, muestra, fabricación, control de calidad, exportación y soporte bajo un mismo proceso para proyectos B2B."
      />
      <ProcessSteps />
    </div>
  </section>

  <section class="section quality-section">
    <div class="container">
      <SectionHead
        eyebrow="Control de calidad"
        title="Puntos de control para reducir riesgo antes del embarque"
        text="Reducimos incertidumbre en materiales, muestras, producción, empaque, inspección final y salida desde China."
      />
      <div class="quality-steps">
        {qualityProofs.map((item) => (
          <article>
            <img src={encodeURI(item.image)} alt={item.alt ?? item.title} loading="lazy" decoding="async" />
            <div>
              <span>{item.step}</span>
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </div>
          </article>
        ))}
      </div>
      <div class="quality-checkpoints" aria-label="Puntos de control de calidad para proyectos B2B">
        {qualityCheckpoints.map((item, index) => (
          <div class="quality-checkpoint">
            <span>{String(index + 1).padStart(2, "0")}</span>
            <strong>{item.label}</strong>
            <p>{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section alt">
    <div class="container">
      <SectionHead
        eyebrow="Fábrica directa"
        title="Equipos reales para producir, controlar y exportar"
        text="Mostramos la capacidad de fábrica con equipos y procesos visibles: canteado, CNC, acabado, control y preparación para proyectos internacionales."
      />
      <FactoryEvidence />
    </div>
  </section>

  <section class="section">
    <div class="container">
      <TrustStrip
        eyebrow="Certificaciones y cooperación"
        title="Base de confianza para compradores internacionales"
        text="Organizamos las señales clave para una compra internacional: fábrica, calidad, proyectos, documentación y soporte comercial."
      />
    </div>
  </section>

  <section class="section">
    <div class="container faq-section-shell">
      <div class="faq-section-head">
        <p class="eyebrow">Preguntas frecuentes</p>
        <h2>FAQ</h2>
        <p>Respuestas breves para equipos de compras, contratistas, hoteles, oficinas y distribuidores que evalúan proveedores en China.</p>
      </div>
      <FAQTabs />
    </div>
  </section>

  <CTA />
</BaseLayout>
