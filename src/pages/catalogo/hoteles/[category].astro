---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Hero from "../../../components/Hero.astro";
import SectionHead from "../../../components/SectionHead.astro";
import ProcessSteps from "../../../components/ProcessSteps.astro";
import CTA from "../../../components/CTA.astro";
import { hotelCatalog } from "../../../data/site";
import { getHotelReferenceFilters, getHotelReferencesByCategory } from "../../../data/hotelReferences";

export function getStaticPaths() {
  const categoryDetails = {
    "habitaciones": {
      seoTitle: "Habitaciones para proyectos hoteleros",
      subtitle: "Muebles para habitaciones de hotel con camas, cabeceras, escritorios y armarios a medida, pensados para compra por volumen y cotización por proyecto.",
      keywords: ["muebles para habitaciones de hotel", "habitaciones de hotel", "mobiliario hotelero", "muebles para hoteles", "camas para hotel", "cabeceras de hotel"],
      bullets: ["Mobiliario fijo y suelto", "Medidas y acabados según planos", "Paquetes por habitación piloto o compra por volumen"],
      supportImage: "/assets/hymueble/hoteles/目录/酒店-目录-卡片-客房.webp",
      supportAlt: "mobiliario para habitaciones de hotel",
    },
    "muebles-de-bano": {
      seoTitle: "Muebles de baño para hoteles",
      subtitle: "Muebles de baño para hoteles, con tocadores, almacenamiento y acabados coordinados para revisar antes de cotizar un proyecto hotelero.",
      keywords: ["muebles de baño para hoteles", "tocadores de baño para hotel", "mobiliario para baño hotelero", "mobiliario hotelero", "muebles para hoteles", "cotización por proyecto"],
      bullets: ["Materiales resistentes a humedad", "Diseño coordinado con habitación", "Producción por lote para remodelaciones"],
      supportImage: "/assets/hymueble/hoteles/目录/酒店-目录-卡片-浴室.webp",
      supportAlt: "muebles de baño para habitaciones de hotel",
    },
    "muebles-exteriores": {
      seoTitle: "Mobiliario exterior para hoteles",
      subtitle: "Mobiliario exterior para hoteles, terrazas y áreas comerciales, con referencias para comparar materiales, resistencia y cotización por proyecto.",
      keywords: ["mobiliario exterior para hoteles", "muebles exteriores para hoteles", "muebles para terrazas de hotel", "terrazas de hotel", "mobiliario hotelero", "cotización por proyecto"],
      bullets: ["Opciones para uso exterior", "Mobiliario para amenidades", "Coordinación de materiales y tapicería"],
      supportImage: "/assets/hymueble/hoteles/目录/酒店-目录-卡片-户外.webp",
      supportAlt: "mobiliario exterior para hoteles y terrazas",
    },
    "muebles-para-bar": {
      seoTitle: "Muebles para bar de hotel",
      subtitle: "Muebles para bar de hotel, con barras, bancos y áreas de servicio para revisar referencias visuales antes de cotizar por proyecto.",
      keywords: ["muebles para bar de hotel", "mobiliario para bar hotelero", "barras de hotel", "bancos para bar", "mobiliario hotelero", "muebles para hoteles"],
      bullets: ["Alturas y ergonomía por operación", "Acabados resistentes a uso intensivo", "Soluciones para hoteles, resorts y restaurantes"],
      supportImage: "/assets/hymueble/casos/kempinski-dining-bar-case.webp",
      supportAlt: "mobiliario para bar hotelero",
    },
    "muebles-para-restaurante": {
      seoTitle: "Muebles para restaurante de hotel",
      subtitle: "Muebles para restaurante de hotel, con mesas, sillas y bancas para comparar distribución y preparar cotización por proyecto.",
      keywords: ["muebles para restaurante de hotel", "mobiliario para restaurantes de hotel", "mesas para hotel", "sillas para restaurante de hotel", "mobiliario hotelero", "muebles para hoteles"],
      bullets: ["Mobiliario para alto tráfico", "Coordinación con concepto interior", "Producción para aperturas o renovación"],
      supportImage: "/assets/hymueble/hoteles/目录/酒店-目录-卡片-餐厅.webp",
      supportAlt: "mobiliario para restaurantes de hotel",
    },
    "mobiliario-para-conferencias": {
      seoTitle: "Mobiliario para conferencias",
      subtitle: "Mobiliario para conferencias hoteleras, con mesas, sillas y salas flexibles para eventos, reuniones y cotización por proyecto.",
      keywords: ["mobiliario para conferencias", "muebles para salas de reuniones de hotel", "salas de conferencias hoteleras", "mobiliario hotelero", "muebles para hoteles", "cotización por proyecto"],
      bullets: ["Configuraciones flexibles", "Apilado y movilidad cuando aplica", "Soporte para hoteles de negocios y salones"],
      supportImage: "/assets/hymueble/hoteles/目录/酒店-目录-卡片-会议室.webp",
      supportAlt: "mobiliario para conferencias hoteleras",
    },
  };

  return hotelCatalog.map((item) => {
    const category = item.href.split("/").filter(Boolean).at(-1) ?? "habitaciones";
    return { params: { category }, props: { item, detail: categoryDetails[category as keyof typeof categoryDetails] } };
  });
}

const { item, detail } = Astro.props;
const categorySlug = item.href.split("/").filter(Boolean).at(-1) ?? "habitaciones";
const references = getHotelReferencesByCategory(categorySlug);
const referenceFilters = getHotelReferenceFilters(references);
const itemListJsonLd = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: `${detail.seoTitle} - referencias para cotizar`,
  itemListElement: references.map((reference, index) => ({
    "@type": "ListItem",
    position: index + 1,
    item: {
      "@type": "CreativeWork",
      name: reference.title,
      description: reference.summary,
      about: `${item.title} - ${reference.filter}`,
      associatedMedia: {
        "@type": "ImageObject",
        contentUrl: new URL(reference.image, Astro.site ?? new URL("https://hymueble.com")).toString(),
      },
    },
  })),
};
---
<BaseLayout
  title={`${detail.seoTitle} | Hymueble`}
  description={detail.subtitle}
  keywords={detail.keywords}
  image={item.image}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(itemListJsonLd)}></script>

  <Hero
    eyebrow="Catálogo hotelero"
    title={detail.seoTitle}
    lead={detail.subtitle}
    image={item.image}
    badgeTitle={detail.seoTitle}
    badgeText="Fabricación directa, personalización y cotización por proyecto."
    primaryLabel="Cotizar esta categoría"
    primaryHref="/contacto/"
    secondaryLabel="Volver al catálogo"
    secondaryHref="/catalogo/hoteles/"
  />

  <section class="section alt">
    <div class="container">
      <SectionHead
        eyebrow="Alcance"
        title="Qué puede incluir esta categoría"
        text="Esta ficha orienta compras por espacio y ayuda a preparar una conversación clara sobre medidas, acabados, cantidades y requisitos técnicos."
      />
      <div class="proof-grid">
        {detail.bullets.map((bullet) => (
          <div class="info-card compact">
            <strong>{bullet}</strong>
            <span>Se revisa junto con cantidades, planos, materiales, acabados y plazo esperado.</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHead
        eyebrow="Referencias"
        title="Referencias para cotizar"
        text="Usa estas referencias como punto de partida para revisar espacios, combinaciones de mobiliario, cantidades y acabados antes de solicitar una propuesta."
      />
      <div class="reference-filter-row" data-reference-filters aria-label="Filtrar referencias por uso">
        <button class="reference-filter is-active" type="button" data-reference-filter="all" aria-pressed="true">Todos</button>
        {referenceFilters.map((filter) => (
          <button class="reference-filter" type="button" data-reference-filter={filter} aria-pressed="false">{filter}</button>
        ))}
      </div>
      <div class="card-grid reference-grid" data-reference-grid>
        {references.map((reference) => (
          <article class="catalog-card reference-card" data-reference-card data-reference-filter={reference.filter}>
            <img src={encodeURI(reference.image)} alt={reference.alt} loading="lazy" decoding="async" />
            <div class="card-body">
              <div class="reference-card-head">
                <span class="eyebrow">{reference.filter}</span>
                <h3>{reference.title}</h3>
              </div>
              <p>{reference.summary}</p>
              <div class="reference-chip-list" aria-label="Aplicaciones">
                {reference.applications.map((application) => <span>{application}</span>)}
                <span>{reference.customization}</span>
              </div>
              <div class="btn-row">
                <button class="btn primary" type="button" data-download-catalog data-catalog-interest={reference.ctaInterest}>Consultar esta referencia</button>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container split-band">
      <div>
        <p class="eyebrow">Cotización por proyecto</p>
        <h2>Envía tus requisitos antes de cerrar especificaciones</h2>
        <p class="section-note">Trabajamos desde referencias, planos, lista FF&E o cantidades iniciales para traducir tu necesidad a materiales, medidas y producción.</p>
        <div class="btn-row section-actions">
          <a class="btn primary" href="/contacto/">Enviar requisitos</a>
          <button class="btn line" type="button" data-download-catalog data-catalog-interest={`Muebles para hoteles - ${item.title}`}>Solicitar catálogo PDF</button>
        </div>
      </div>
      <img src={encodeURI(detail.supportImage)} alt={detail.supportAlt} loading="lazy" decoding="async" />
    </div>
  </section>

  <section class="section alt">
    <div class="container">
      <SectionHead
        eyebrow="Proceso"
        title="Cómo avanzamos desde categoría hasta producción"
        text="El flujo se mantiene claro para equipos de diseño, compras, construcción y operación hotelera."
      />
      <ProcessSteps />
    </div>
  </section>

  <CTA title={`¿Necesitas ${item.title.toLowerCase()} para tu hotel?`} text="Comparte ciudad, tipo de hotel, cantidades y referencias. Te responderemos con próximos pasos de cotización." />

  <script>
    const setupReferenceFilters = () => {
      document.querySelectorAll<HTMLElement>("[data-reference-filters]").forEach((filterRow) => {
        const buttons = [...filterRow.querySelectorAll<HTMLButtonElement>("[data-reference-filter]")];
        const grid = filterRow.nextElementSibling;
        const cards = [...(grid?.querySelectorAll<HTMLElement>("[data-reference-card]") ?? [])];

        buttons.forEach((button) => {
          button.addEventListener("click", () => {
            const selected = button.dataset.referenceFilter ?? "all";
            buttons.forEach((item) => {
              const isActive = item === button;
              item.classList.toggle("is-active", isActive);
              item.setAttribute("aria-pressed", String(isActive));
            });
            cards.forEach((card) => {
              card.hidden = selected !== "all" && card.dataset.referenceFilter !== selected;
            });
          });
        });
      });
    };

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", setupReferenceFilters, { once: true });
    } else {
      setupReferenceFilters();
    }
  </script>
</BaseLayout>
