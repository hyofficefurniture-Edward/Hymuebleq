---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Hero from "../../components/Hero.astro";
import SectionHead from "../../components/SectionHead.astro";
import CatalogCard from "../../components/CatalogCard.astro";
import ProcessSteps from "../../components/ProcessSteps.astro";
import CTA from "../../components/CTA.astro";
import { categories, sectorCatalogs } from "../../data/site";

export function getStaticPaths() {
  return [
    { params: { sector: "oficinas" } },
    { params: { sector: "salud" } },
    { params: { sector: "educacion" } },
    { params: { sector: "residencial" } },
  ];
}

const sector = Astro.params.sector ?? "oficinas";
const category = categories.find((item) => item.catalog.endsWith(`/${sector}/`)) ?? categories[1];
const catalogItems = sectorCatalogs[sector as keyof typeof sectorCatalogs] ?? [];
const catalogInterestPrefix = `${category.title} - `;
---
<BaseLayout
  title={`${category.catalogSeoTitle ?? `Catálogo de ${category.title}`} | Hymueble`}
  description={category.catalogSeoDescription}
  keywords={category.catalogSeoKeywords}
  image={category.catalogImage}
>
  <Hero
    eyebrow="Catálogo B2B"
    title={`Catálogo de ${category.title} para proyectos B2B`}
    lead={`Explora las líneas principales de mobiliario para ${category.title.toLowerCase()}. Esta ruta queda lista para integrar PDF, fichas técnicas y selección por volumen.`}
    image={category.catalogImage}
    badgeTitle={category.catalogSeoTitle ?? `Catálogo de ${category.title}`}
    badgeText="Productos por espacio, personalización y solicitud de cotización."
    primaryLabel="Solicitar catálogo"
    primaryHref="/contacto/"
    secondaryLabel="Ver sector"
    secondaryHref={category.href}
  />

  <section class="section alt">
    <div class="container">
      <SectionHead
        eyebrow="Categorías"
        title="Selecciona la categoría relacionada con tu proyecto"
        text="Cada bloque funciona como punto de partida para una consulta de compras, distribución, remodelación o equipamiento por proyecto."
      />
      <div class="card-grid">
        {catalogItems.map((item) => <CatalogCard item={item} catalogInterestPrefix={catalogInterestPrefix} />)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHead
        eyebrow="Cotización"
        title="Cómo usamos el catálogo en una compra B2B"
        text="El catálogo no es una lista cerrada: sirve para alinear referencias, materiales, cantidades y nivel de personalización antes de preparar una propuesta."
      />
      <ProcessSteps />
      <div class="btn-row section-actions">
        <button class="btn primary" type="button" data-download-catalog data-catalog-interest={`Catálogo de ${category.title}`}>Descargar catálogo PDF</button>
        <a class="btn line" href="/contacto/">Enviar requisitos del proyecto</a>
      </div>
    </div>
  </section>

  <CTA />
</BaseLayout>
