---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import SectionHead from "../components/SectionHead.astro";
import FactoryProcessEvidence from "../components/FactoryProcessEvidence.astro";
import CTA from "../components/CTA.astro";
import ScrollRail from "../components/ScrollRail.astro";
import { certificationHighlights, factoryEquipmentHighlights, factoryHeroImage, metrics, qualificationProofs } from "../data/site";
---
<BaseLayout
  title="Fábrica de muebles en China para proyectos | Hymueble"
  description="Fábrica de muebles en China para proyectos comerciales, con fabricación a medida, control de calidad, embalaje para exportación y soporte de compra directa."
  keywords={["fábrica de muebles en China", "fabricante de muebles a medida", "fabricante de mobiliario para proyectos", "directo de fábrica", "control de calidad", "embalaje para exportación"]}
  image={factoryHeroImage}
>
  <Hero
    eyebrow="Fábrica directa en China"
    title="Fábrica de muebles en China para proyectos comerciales"
    lead="Fabricante de mobiliario para proyectos con equipos HOMAG, Bacci, CNC de seis caras, acabado al agua y control final antes del embarque."
    image={factoryHeroImage}
    imageAlt="centro CNC Bacci de cinco ejes en fábrica de mobiliario"
    badgeTitle="Equipos visibles"
    badgeText="Canteado, CNC, acabado, control y preparación para exportación."
    primaryLabel="Enviar requerimientos"
    primaryHref="/contacto/"
    secondaryLabel="Ver equipos"
    secondaryHref="#equipos"
  />

  <section class="section alt">
    <div class="container">
      <div class="metric-grid">
        {metrics.map((metric) => (
          <div class="metric">
            <strong>{metric.value}</strong>
            <span>{metric.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHead
        eyebrow="Evidencia de fábrica"
        title="Lo importante no es decir fábrica, sino mostrar el proceso"
        text="Para compras internacionales, el comprador necesita ver capacidad real: equipos, control de superficie, repetición de piezas y preparación para exportación."
      />
      <div class="factory-proof-grid">
        <article>
          <span>01</span>
          <h3>Equipos verificables</h3>
          <p>HOMAG, Bacci y CNC de seis caras apoyan piezas repetidas, paneles y componentes especiales.</p>
        </article>
        <article>
          <span>02</span>
          <h3>Proceso documentado</h3>
          <p>Revisión de materiales, fabricación, acabado, inspección y preparación de salida con evidencia visual.</p>
        </article>
        <article>
          <span>03</span>
          <h3>Compra con menos fricción</h3>
          <p>El equipo comercial recibe planos, cantidades y acabados para evaluar viabilidad antes de confirmar pedido.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section alt" id="equipos">
    <div class="container">
      <SectionHead
        eyebrow="Equipos y proceso"
        title="Capacidad industrial que se puede revisar visualmente"
        text="Organizamos los procesos clave en una secuencia simple para compras por proyecto: borde, madera sólida, paneles, acabado, control y salida."
      />
      <FactoryProcessEvidence />
      <div class="factory-equipment-grid">
        {factoryEquipmentHighlights.map((item) => (
          <article>
            <span>{item.title}</span>
            <h3>{item.label}</h3>
            <p>{item.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container split-band">
      <div>
        <p class="eyebrow">Personalización según proyecto</p>
        <h2>Del plano al producto: medidas, materiales y acabados controlados</h2>
        <p class="section-note">Antes de producir, revisamos planos, cantidades, materiales, colores y uso previsto. El objetivo es reducir ajustes tardíos y preparar una cotización realista.</p>
        <div class="factory-mini-list" aria-label="Puntos de revisión antes de producir">
          <span>Planos y medidas</span>
          <span>Materiales y acabados</span>
          <span>Empaque por ruta</span>
        </div>
        <div class="btn-row section-actions">
          <a class="btn primary" href="/contacto/">Cuéntanos tu proyecto</a>
          <button class="btn line" type="button" data-download-catalog data-catalog-interest="Capacidades de fábrica y mobiliario para proyectos">Solicitar catálogo</button>
        </div>
      </div>
      <img src={encodeURI("/assets/hymueble/fabrica/equipos/six-axis-drilling.webp")} alt="perforación CNC de seis caras para muebles de proyecto" loading="lazy" decoding="async" />
    </div>
  </section>

  <section class="section alt qualification-section">
    <div class="container">
      <SectionHead
        eyebrow="Certificaciones y control"
        title="Evidencia documental para reducir riesgo de compra"
        text="Además de mostrar capacidad de producción, organizamos certificados, licencias y materiales corporativos para que compradores internacionales puedan revisar respaldo antes de avanzar."
      />
      <ScrollRail label="Certificaciones y documentos de fábrica">
        <div class="qualification-showcase" data-scroll-track>
          {qualificationProofs.map((item) => (
            <article class="qualification-card">
              <img src={encodeURI(item.image)} alt={item.alt ?? item.title} loading="lazy" decoding="async" />
              <div>
                <span>{item.label}</span>
                <h3>{item.title}</h3>
                <p>{item.text}</p>
              </div>
            </article>
          ))}
        </div>
      </ScrollRail>
      <div class="certification-strip" aria-label="Certificaciones y documentos destacados">
        {certificationHighlights.map((item) => <span>{item}</span>)}
      </div>
    </div>
  </section>

  <CTA title="¿Quieres revisar la capacidad de fábrica para tu proyecto?" text="Comparte planos, cantidades aproximadas, sector y ciudad. Evaluaremos materiales, proceso, tiempos y próximos pasos." />
</BaseLayout>
