---
import BaseLayout from "../layouts/BaseLayout.astro";
import ContactForm from "../components/ContactForm.astro";
import { brand, contactConsultationImage, showrooms } from "../data/site";
---
<BaseLayout
  title="Solicitar cotización de muebles | Hymueble"
  description="Solicitar cotización de muebles para hoteles, oficinas y proyectos comerciales. Comparte sector, ciudad, cantidades, planos o referencias para una revisión inicial."
  keywords={["solicitar cotización de muebles", "cotizar proyecto de mobiliario", "cotización de mobiliario", "proveedor de mobiliario", "fabricación directa en China", "WhatsApp"]}
  image={contactConsultationImage}
>
  <section class="section">
    <div class="container form-shell">
      <div class="form-card">
        <ContactForm />
      </div>
      <div class="contact-panel">
        <img src={encodeURI(contactConsultationImage)} alt="Revisión de materiales para proyecto de mobiliario" loading="eager" decoding="async" fetchpriority="high" />
        <div>
          <p class="eyebrow">Cotización por proyecto</p>
          <h1>Solicitar cotización de muebles</h1>
          <p class="contact-note">Para cotizar muebles para tu proyecto, comparte sector, ciudad, espacios y una idea inicial del alcance. Si todavía no tienes planos, lista FF&E o medidas, podemos revisarlos después por WhatsApp o correo.</p>
          <div class="btn-row">
            <a class="btn dark" href={brand.whatsapp} target="_blank" rel="noreferrer">Hablar por WhatsApp</a>
            <a class="btn line" href="/showroom/">Ver showroom primero</a>
          </div>
        </div>
      </div>
    </div>
  </section>
  <section class="section alt">
    <div class="container split-band">
      <div>
        <p class="eyebrow">Cómo preparar tu consulta</p>
        <h2>Empieza con lo básico; afinamos los detalles después</h2>
        <p class="contact-note spaced">Para preparar la cotización, puedes enviar sector, ciudad, WhatsApp, cantidades aproximadas y una breve descripción. Los planos, listas FF&E o fotos de referencia ayudan, pero no son obligatorios para iniciar.</p>
      </div>
      <img src={encodeURI("/assets/hymueble/fabrica/produccion/real-export-packaging.webp")} alt="Embalaje de exportación para mobiliario de proyecto" loading="lazy" decoding="async" />
    </div>
  </section>
  <section class="section">
    <div class="container split-band">
      <div>
        <p class="eyebrow">Referencia visual antes de enviar</p>
        <h2>Si aún no tienes una lista completa, usa el showroom como referencia</h2>
        <p class="contact-note spaced">Para pedir una cotización con referencias claras, puedes revisar recorridos por sector y compartirlos con compras, diseño o arquitectura.</p>
        <div class="btn-row contact-actions">
          <a class="btn primary" href="/showroom/">Ver todos los showrooms</a>
          <a class="btn line" href={showrooms[0].href} data-showroom-modal data-showroom-title="Showroom virtual de hoteles">Entrar al showroom hotelero</a>
        </div>
      </div>
      <img src={encodeURI(showrooms[0].image)} alt="Showroom virtual para preparar una consulta de mobiliario" loading="lazy" decoding="async" />
    </div>
  </section>
  <section class="section alt">
    <div class="container split-band">
      <div class="map-card">
        <p class="eyebrow">Base de fabricación</p>
        <h2>Guangdong, China</h2>
        <p>Coordinamos producción, calidad, embalaje y documentación comercial desde una base industrial para proyectos internacionales.</p>
      </div>
      <div>
        <p class="eyebrow">Después de enviar</p>
        <h2>Te contactamos por WhatsApp o correo</h2>
        <p class="contact-note spaced">Para avanzar con tu cotización, revisamos sector, espacios, país, urgencia y material disponible. Si necesitas catálogo, reunión o revisión de planos, te indicamos el siguiente paso.</p>
        <div class="btn-row contact-actions">
          <a class="btn primary" href={brand.whatsapp} target="_blank" rel="noreferrer">Abrir WhatsApp</a>
          <a class="btn line" href="/catalogo/">Ver catálogos</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
