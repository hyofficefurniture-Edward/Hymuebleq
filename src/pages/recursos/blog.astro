---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SectionHead from "../../components/SectionHead.astro";
import CTA from "../../components/CTA.astro";

const blogHeroImage = "/assets/hymueble/recursos/博客/资源-博客-Hero-工厂CNC.webp";
const guideCards = [
  {
    label: "Guía de compra",
    title: "Cómo preparar una solicitud de mobiliario B2B",
    text: "Define tipo de proyecto, espacios, cantidades, medidas de referencia, ciudad de entrega y fecha objetivo antes de pedir precio.",
    points: ["Alcance", "Cantidades", "Plazo"],
  },
  {
    label: "Proveedor de fábrica",
    title: "Qué revisar para saber si un proveedor puede manejar proyectos",
    text: "Revisa capacidad de producción, control documental, casos, showroom, muestras, embalaje y soporte para exportación.",
    points: ["Fábrica", "Casos", "Exportación"],
  },
  {
    label: "Calidad",
    title: "Qué revisar antes de aprobar producción por volumen",
    text: "Materiales, acabados, herrajes, muestras, tolerancias, inspección en proceso y evidencia previa al embalaje.",
    points: ["Muestras", "Acabados", "Inspección"],
  },
  {
    label: "Importación",
    title: "Información que ayuda a cotizar con menos rondas",
    text: "Planos, listas FF&E, referencias visuales, cantidades aproximadas y restricciones de obra reducen ida y vuelta comercial.",
    points: ["Planos", "FF&E", "Referencias"],
  },
];

const blogArticles = [
  {
    label: "Guía de proveedores",
    title: "Top 10 Fabricantes de Muebles para Hoteles en China 2026",
    text: "Compare los 10 fabricantes más fiables de mobiliario hotelero por capacidad, precio y plazo de entrega. Incluye matriz de comparación y tabla de presupuesto por tipo de hotel.",
    href: "/recursos/top-10-fabricantes-muebles-hoteles-china-2026/",
    image: "/assets/hymueble/recursos/blog/images/hym-01-img-03-lobby-hotel-proyecto.webp",
    imageAlt: "Lobby de hotel boutique amueblado por Hongye Furniture Group con recepción de madera, sillones y mesas auxiliares",
  },
  {
    label: "Guía de proveedores",
    title: "Top 10 Proveedores de Mobiliario de Oficina Ergonómico 2026",
    text: "Ranking de los 10 mejores proveedores de mobiliario de oficina ergonómico en China. Comparativa de capacidad, certificaciones BIFMA, precios y plazos para compradores B2B en América Latina.",
    href: "/recursos/top-10-proveedores-mobiliario-oficina-ergonomico-2026/",
    image: "/assets/hymueble/recursos/blog/images/hym-02-img-01.jpg",
    imageAlt: "Silla ergonómica de malla exhibida en NeoCon Chicago 2026 por Hongye Furniture Group en stand Hymueble",
  },
];

const decisionBlocks = [
  {
    title: "Si ya tienes planos",
    text: "Envía layout, medidas, lista de espacios y prioridad por área. Podemos revisar alcance antes de preparar una cotización.",
  },
  {
    title: "Si solo tienes referencias",
    text: "Comparte imágenes, moodboard o enlaces de estilo. El equipo puede orientar materiales, categorías y ruta de muestras.",
  },
  {
    title: "Si estás comparando proveedores",
    text: "Usa showroom, casos, capacidad de fábrica y control de calidad para validar si el proveedor puede acompañar el proyecto.",
  },
];
---
<BaseLayout
  title="Blog para compradores B2B | Hymueble"
  description="Guías prácticas para compradores B2B de mobiliario comercial: selección de proveedor, calidad, importación y preparación de cotizaciones por proyecto."
  keywords={["blog de mobiliario B2B", "compradores B2B", "mobiliario comercial", "selección de proveedor", "calidad de mobiliario", "cotización por proyecto"]}
  image={blogHeroImage}
>
  <section class="section resource-hero">
    <div class="container resource-hero-grid">
      <div class="resource-hero-copy">
        <p class="eyebrow">Blog B2B</p>
        <h1>Guías para comprar mobiliario comercial directo de fábrica</h1>
        <p>
          Contenido pensado para equipos de compra, diseño, construcción e importación que necesitan reducir riesgo antes de cotizar.
        </p>
        <div class="btn-row">
          <a class="btn primary" href="/contacto/">Enviar datos iniciales</a>
          <a class="btn line" href="/showroom/">Ver showroom virtual</a>
        </div>
      </div>
      <figure class="resource-hero-media">
        <img src={encodeURI(blogHeroImage)} alt="Centro CNC y producción de mobiliario" loading="eager" decoding="async" fetchpriority="high" />
        <figcaption>Capacidad de fábrica, procesos y criterios de compra para proyectos B2B.</figcaption>
      </figure>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="eyebrow">Artículos</p>
      <h2>Lecturas recomendadas para compradores B2B</h2>
      <div class="blog-article-grid">
        {blogArticles.map((article) => (
          <article class="blog-article-card">
            <a href={article.href} class="blog-article-link">
              <figure class="blog-article-thumb">
                <img src={encodeURI(article.image)} alt={article.imageAlt} loading="lazy" decoding="async" width="600" height="400" />
              </figure>
              <div class="blog-article-body">
                <span class="blog-article-tag">{article.label}</span>
                <h3>{article.title}</h3>
                <p>{article.text}</p>
                <span class="blog-article-cta">Leer artículo →</span>
              </div>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section alt">
    <div class="container">
      <SectionHead
        eyebrow="Temas principales"
        title="Lecturas cortas para preparar una compra con más claridad"
        text="Cada recurso responde a dudas reales de compradores: proveedor, personalización, calidad, documentación y preparación de una solicitud."
      />
      <div class="resource-card-grid">
        {guideCards.map((card) => (
          <article class="resource-guide-card">
            <span>{card.label}</span>
            <h3>{card.title}</h3>
            <p>{card.text}</p>
            <ul>
              {card.points.map((point) => <li>{point}</li>)}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container resource-split">
      <div>
        <p class="eyebrow">Cómo usar estos recursos</p>
        <h2>El blog no reemplaza la cotización: ayuda a llegar mejor preparado</h2>
        <p>
          En proyectos B2B, el precio depende de alcance, medidas, acabados, volumen, empaque y ruta. Por eso priorizamos decisiones prácticas.
        </p>
      </div>
      <div class="resource-decision-list">
        {decisionBlocks.map((item) => (
          <article>
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <CTA
    title="¿Quieres que revisemos tu caso antes de cotizar?"
    text="Comparte tipo de proyecto, ciudad, espacios y planos o lista si los tienes. Una descripción inicial también sirve."
  />
</BaseLayout>

<style>
  /* Blog article card grid with thumbnail images */
  .blog-article-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 28px;
    margin-top: 32px;
  }

  .blog-article-card {
    border: 1px solid var(--line);
    border-radius: 12px;
    background: #fff;
    box-shadow: 0 18px 52px rgba(18, 26, 34, .06);
    overflow: hidden;
    transition: box-shadow .3s ease, transform .3s ease;
  }

  .blog-article-card:hover {
    box-shadow: 0 24px 68px rgba(18, 26, 34, .12);
    transform: translateY(-4px);
  }

  .blog-article-link {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    height: 100%;
  }

  .blog-article-thumb {
    margin: 0;
    overflow: hidden;
    aspect-ratio: 3 / 2;
    background: var(--bg);
  }

  .blog-article-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform .4s ease;
  }

  .blog-article-card:hover .blog-article-thumb img {
    transform: scale(1.06);
  }

  .blog-article-body {
    display: grid;
    gap: 12px;
    padding: 24px 26px 28px;
  }

  .blog-article-tag {
    color: var(--green);
    font-size: 12px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: .04em;
  }

  .blog-article-body h3 {
    font-size: 20px;
    line-height: 1.35;
    color: var(--title);
  }

  .blog-article-body p {
    color: var(--muted);
    font-size: 15px;
    line-height: 1.58;
  }

  .blog-article-cta {
    margin-top: 4px;
    color: var(--green);
    font-size: 14px;
    font-weight: 800;
    transition: gap .2s ease;
  }

  .blog-article-card:hover .blog-article-cta {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* Tablet: 2 columns */
  @media (max-width: 1080px) {
    .blog-article-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 22px;
    }
  }

  /* Mobile: 1 column */
  @media (max-width: 720px) {
    .blog-article-grid {
      grid-template-columns: 1fr;
      gap: 18px;
    }

    .blog-article-body {
      padding: 20px 22px 24px;
    }

    .blog-article-body h3 {
      font-size: 18px;
    }
  }
</style>
