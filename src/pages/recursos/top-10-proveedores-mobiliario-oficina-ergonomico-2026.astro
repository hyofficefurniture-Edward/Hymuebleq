          <tr><td>5</td><td>Henglin Chair</td><td>Volumen alto sillas operativas</td><td>200+ sillas</td><td>$</td><td>Sí</td><td>Inglés</td><td>No</td></tr>
          <tr><td>6</td><td>Bossin Furniture</td><td>Presupuesto controlado</td><td>50+ puestos</td><td>$</td><td>No</td><td>Inglés</td><td>No</td></tr>
          <tr><td>7</td><td>Okaa Furniture</td><td>Diseño minimalista moderno</td><td>20+ piezas</td><td>$$</td><td>Parcial</td><td>Inglés</td><td>No</td></tr>
