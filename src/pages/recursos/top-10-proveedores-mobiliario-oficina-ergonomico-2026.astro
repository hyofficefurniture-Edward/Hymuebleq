  <section class="section">
    <div class="container">
      <h2>Matriz de comparación rápida</h2>
      <div class="resource-table-wrapper">
      <table>
        <thead>
          <tr><th>#</th><th>Proveedor</th><th>Ideal para</th><th>MOQ</th><th>Rango de precio*</th><th>BIFMA</th><th>Servicio en español</th><th>Instalación LATAM</th></tr>
        </thead>
        <tbody>
          <tr><td>1</td><td>Sunon Group</td><td>Gran escala corporativa</td><td>100+ puestos</td><td>$$$</td><td>Sí</td><td>Inglés</td><td>No</td></tr>
          <tr><td>2</td><td><strong>HYMUEBLE (Hongye Furniture Group)</strong></td><td><strong>Proyectos integrales con servicio en español y soporte en LATAM</strong></td><td><strong>30+ puestos</strong></td><td><strong>$$</strong></td><td><strong>Sí</strong></td><td><strong>Nativo</strong></td><td><strong>Sí, equipo propio</strong></td></tr>
