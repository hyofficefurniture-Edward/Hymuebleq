---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Hero from "../../components/Hero.astro";
import SectionHead from "../../components/SectionHead.astro";
import ProjectCard from "../../components/ProjectCard.astro";
import CTA from "../../components/CTA.astro";
import { categories, projects, showrooms } from "../../data/site";

export function getStaticPaths() {
  return [
    { params: { sector: "oficinas" } },
    { params: { sector: "salud" } },
    { params: { sector: "educacion" } },
    { params: { sector: "residencial" } },
  ];
}

const sector = Astro.params.sector ?? "oficinas";
const category = categories.find((item) => item.projects.endsWith(`/${sector}/`)) ?? categories[1];
const sectorProjects = projects.filter((project) => {
  const normalized = project.sector.toLowerCase();
  return normalized === category.title.toLowerCase() || normalized === sector;
});
const hasSectorProjects = sectorProjects.length > 0;
const showroomBySector = {
  oficinas: showrooms[1],
  salud: showrooms[2],
  educacion: showrooms[3],
};
const sectorShowroom = showroomBySector[sector as keyof typeof showroomBySector];
const showcaseImage = sectorShowroom?.image ?? category.projectImage;
const projectTitleLabels = {
  oficinas: "oficinas",
  salud: "hospitales y clínicas",
  educacion: "escuelas y campus educativos",
  residencial: "desarrollos residenciales",
};
const projectContextLabels = {
  oficinas: "de oficina",
  salud: "de salud",
  educacion: "educativo",
  residencial: "residencial",
};
const supportLabels = {
  oficinas: "oficinas",
  salud: "salud",
  educacion: "educación",
  residencial: "mobiliario residencial",
};
const projectTitleLabel = projectTitleLabels[sector as keyof typeof projectTitleLabels] ?? category.title.toLowerCase();
const projectContextLabel = projectContextLabels[sector as keyof typeof projectContextLabels] ?? `de ${category.title.toLowerCase()}`;
const supportLabel = supportLabels[sector as keyof typeof supportLabels] ?? category.title.toLowerCase();
---
<BaseLayout
  title={`${category.projectsSeoTitle ?? `Proyectos de ${category.title}`} | Hymueble`}
  description={category.projectsSeoDescription}
  keywords={category.projectsSeoKeywords}
  image={category.projectImage}
>
  <Hero
    eyebrow={`Proyectos ${category.title}`}
    title={`Casos y referencias de mobiliario para ${projectTitleLabel}`}
    lead="Proyectos de mobiliario con casos documentados y referencias por sector para evaluar alcance antes de cotizar."
    image={category.projectImage}
    badgeTitle={category.projectsSeoTitle ?? `Casos de ${category.title}`}
    badgeText={hasSectorProjects ? "Referencias por sector, región y alcance para preparar una cotización." : "Ruta lista para revisar datos iniciales y preparar referencias comparables."}
    primaryLabel="Consultar proyecto similar"
    primaryHref="/contacto/"
    secondaryLabel="Ver catálogo"
    secondaryHref={category.catalog}
  />

  <section class="section alt">
    <div class="container">
      <SectionHead
        eyebrow="Referencias"
        title={`Descubre proyectos de mobiliario para ${projectTitleLabel}`}
        text={hasSectorProjects ? "Cada tarjeta resume sector, región y alcance para revisar experiencia antes de solicitar cotización." : "Este sector todavía no tiene una base pública completa de casos. En vez de reutilizar imágenes de otro sector, dejamos una ruta clara para revisar datos iniciales y preparar referencias comparables."}
      />
      {hasSectorProjects ? (
        <div class="card-grid">
          {sectorProjects.map((project) => <ProjectCard project={project} imageField="listingImage" />)}
        </div>
      ) : (
        <div class="proof-grid">
          <div class="info-card compact">
            <strong>Requisitos del espacio</strong>
            <span>Tipo de edificio, áreas a equipar, cantidades aproximadas y nivel de personalización.</span>
          </div>
          <div class="info-card compact">
            <strong>Referencias visuales</strong>
            <span>Planos, fotos, renders, acabados esperados o catálogo base para alinear la propuesta.</span>
          </div>
          <div class="info-card compact">
            <strong>Próximo paso</strong>
            <span>Enviar la consulta para preparar una comparación real sin reutilizar casos que no pertenecen al sector.</span>
          </div>
        </div>
      )}
    </div>
  </section>

  <section class="section">
    <div class="container split-band">
      <div>
        <p class="eyebrow">Antes de cotizar</p>
        <h2>{sectorShowroom ? `Revisa el showroom de ${sectorShowroom.sector.toLowerCase()} para alinear referencias visuales` : `Prepara referencias visuales para tu proyecto ${projectContextLabel}`}</h2>
        <p class="section-note">{sectorShowroom ? "Usa el recorrido para conversar sobre espacios, materiales, acabados y alcance." : "Comparte planos, fotos, renders o lista de mobiliario para preparar una referencia comparable sin mezclar casos de otro sector."}</p>
        <div class="btn-row section-actions">
          {sectorShowroom ? (
            <a class="btn primary" href={sectorShowroom.href} data-showroom-modal data-showroom-title={`Showroom virtual de ${sectorShowroom.sector}`}>Entrar al showroom</a>
          ) : (
            <a class="btn primary" href="/contacto/">Enviar datos iniciales</a>
          )}
          <a class="btn line" href="/showroom/">Ver todos los showrooms</a>
        </div>
      </div>
      <img src={encodeURI(showcaseImage)} alt={sectorShowroom ? `Showroom virtual para ${sectorShowroom.sector}` : category.projectAlt} loading="lazy" decoding="async" />
    </div>
  </section>

  <CTA title={`¿Necesitas cotizar un proyecto de ${supportLabel}?`} text="Envíanos tipo de proyecto, espacios, cantidades y ciudad. Revisamos viabilidad y próximos pasos." />
</BaseLayout>
