---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Hero from "../../../components/Hero.astro";
import SectionHead from "../../../components/SectionHead.astro";
import ProcessSteps from "../../../components/ProcessSteps.astro";
import CTA from "../../../components/CTA.astro";
import { projects } from "../../../data/site";
import { getProjectEvidenceLabel } from "../../../data/projectEvidence";

export function getStaticPaths() {
  return projects.map((item) => {
    const parts = item.href.split("/").filter(Boolean);
    const sector = parts[1] ?? "hoteles";
    const project = parts[2] ?? item.name.toLowerCase().replaceAll(" ", "-");
    return { params: { sector, project }, props: { item, notes: item.details } };
  });
}

const { item, notes } = Astro.props;
const evidenceLabel = getProjectEvidenceLabel(item);
const summaryEyebrow = evidenceLabel === "Escenario de solución" ? "Resumen del escenario" : "Resumen de la referencia";
const projectKeywordHeadings = {
  Hotel: "Referencia de mobiliario hotelero para proyectos",
  Oficinas: "Referencia de mobiliario de oficina para proyectos",
  Salud: "Referencia de mobiliario para salud y espacios médicos",
  Educación: "Referencia de mobiliario educativo para proyectos",
  Residencial: "Referencia de mobiliario residencial para proyectos",
};
const projectKeywordHeading = projectKeywordHeadings[item.sector as keyof typeof projectKeywordHeadings] ?? "Referencia de mobiliario para proyectos";
const projectNarrative =
  notes?.overview ??
  `${item.name} es una referencia de ${item.sector.toLowerCase()} en ${item.region}. El alcance visible incluye ${notes?.rooms ?? item.scope}. Esta página resume qué espacios se pueden comparar, qué evidencia se revisó y cómo usar la referencia antes de solicitar una cotización por proyecto.`;
---
<BaseLayout
  title={`${item.seoTitle ?? `${item.name} | Proyecto`} | Hymueble`}
  description={item.seoDescription ?? `${item.name}: referencia de mobiliario para ${item.sector}.`}
  keywords={item.seoKeywords}
  image={item.detailImage ?? item.image}
>
  <Hero
    eyebrow={evidenceLabel}
    title={item.name}
    lead={item.scope}
    image={item.detailImage ?? item.image}
    badgeTitle={item.region}
    badgeText={`${item.sector} · ${notes?.type ?? "Proyecto de mobiliario"} · ${evidenceLabel}`}
    primaryLabel="Consultar un proyecto similar"
    primaryHref="/contacto/"
    secondaryLabel="Volver a proyectos"
    secondaryHref={`/proyectos/${Astro.params.sector}/`}
  />

  <section class="section alt">
    <div class="container">
      <SectionHead
        eyebrow={summaryEyebrow}
        title={projectKeywordHeading}
        text="Este resumen muestra los datos útiles para compras: sector, región, alcance, tipo de proyecto, acabados y forma de usar la referencia para una nueva cotización."
      />
      <div class="proof-grid">
        <div class="info-card compact">
          <strong>Sector</strong>
          <span>{item.sector}</span>
        </div>
        <div class="info-card compact">
          <strong>Región</strong>
          <span>{item.region}</span>
        </div>
        <div class="info-card compact">
          <strong>Tipo de proyecto</strong>
          <span>{notes?.type ?? "Proyecto de mobiliario"}</span>
        </div>
        <div class="info-card compact">
          <strong>Alcance</strong>
          <span>{notes?.rooms ?? item.scope}</span>
        </div>
        <div class="info-card compact">
          <strong>Entrega</strong>
          <span>{notes?.year ?? "Referencia de proyecto"}</span>
        </div>
        <div class="info-card compact">
          <strong>Acabados y soporte</strong>
          <span>{notes?.finishes ?? "Mobiliario a medida y soporte de proyecto."}</span>
        </div>
      </div>
      {notes?.evidence && (
        <div class="certification-strip case-evidence" aria-label="Evidencia disponible del proyecto">
          {notes.evidence.map((item) => <span>{item}</span>)}
        </div>
      )}
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHead
        eyebrow="Lectura del proyecto"
        title="Contexto del proyecto y uso de la referencia"
        text={projectNarrative}
      />
      <div class="proof-grid">
        <div class="info-card compact">
          <strong>Espacios visibles</strong>
          <span>{notes?.spaces?.join(", ") ?? notes?.rooms ?? item.scope}</span>
        </div>
        <div class="info-card compact">
          <strong>Valor para compras</strong>
          <span>{notes?.procurementValue ?? "Referencia útil para comparar alcance, espacios y próximos pasos de cotización."}</span>
        </div>
        <div class="info-card compact">
          <strong>Fuente revisada</strong>
          <span>{item.sourceUrl ? "PDF interno y referencia publicada del grupo." : "Referencia documental interna."}</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container split-band">
      <div>
        <p class="eyebrow">Cómo usar esta referencia</p>
        <h2>Compara tu alcance antes de pedir cotización</h2>
        <p class="section-note">Si tu proyecto tiene espacios o materiales similares, usamos esta referencia para revisar viabilidad, producción, inspección y logística.</p>
        <div class="btn-row section-actions">
          <a class="btn primary" href="/contacto/">Enviar datos iniciales</a>
          <a class="btn line" href="/fabrica/">Ver capacidad de fábrica</a>
        </div>
      </div>
      <img src={encodeURI(notes?.supportImage ?? item.image)} alt={item.alt ?? item.name} loading="lazy" decoding="async" />
    </div>
  </section>

  <section class="section alt">
    <div class="container">
      <SectionHead
        eyebrow="Proceso"
        title="Del caso de referencia a una propuesta para tu proyecto"
        text="La secuencia ayuda a compras, diseño, obra y operación a revisar información antes de avanzar con una propuesta."
      />
      <ProcessSteps />
    </div>
  </section>

  <CTA title="¿Quieres cotizar un proyecto parecido?" text="Comparte sector, ciudad, espacios, cantidades y plazo. Te indicamos próximos pasos." />
</BaseLayout>
