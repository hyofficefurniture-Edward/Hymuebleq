---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Hero from "../../../components/Hero.astro";
import SectionHead from "../../../components/SectionHead.astro";
import ProcessSteps from "../../../components/ProcessSteps.astro";
import CTA from "../../../components/CTA.astro";
import { projects } from "../../../data/site";

export function getStaticPaths() {
  const projectNotes = {
    "grand-kempinski-hotel": {
      type: "Hotel internacional",
      year: "Referencia documentada con material interno de proyecto",
      rooms: "Habitaciones, restaurante, entretenimiento, bar y áreas públicas",
      finishes: "Mobiliario a medida, acabados coordinados, FF&E y soporte documental.",
      evidence: ["PDF de caso interno", "Habitaciones documentadas", "Restaurante y bar", "Entretenimiento y áreas públicas"],
      supportImage: "/assets/hymueble/casos/kempinski-dining-bar-case.webp",
    },
    "hilton-doubletree-hotel": {
      type: "Hotel de cadena",
      year: "Referencia documentada con material interno de proyecto",
      rooms: "Habitaciones, lobby, restaurante, reuniones, fitness y piscina",
      finishes: "Mobiliario hotelero, FF&E, entrega y soporte documental.",
      evidence: ["PDF de caso interno", "Video interno", "Habitaciones documentadas", "Banquete y reuniones", "Fitness y piscina"],
      supportImage: "/assets/hymueble/casos/hilton-project-installation-case.webp",
    },
    "raffles-hotel": {
      type: "Proyecto hotelero",
      year: "Referencia documentada con material interno de proyecto",
      rooms: "Mobiliario hotelero, FF&E y soporte de embalaje",
      finishes: "Soluciones a medida para ambientes hoteleros de alto estándar y documentación de entrega.",
      evidence: ["PDF de caso interno", "Soporte FF&E", "Evidencia de embalaje", "Proyecto hotelero"],
      supportImage: "/assets/hymueble/casos/raffles-packaging-proof-case.webp",
    },
    "huntington-school-of-lagos": {
      type: "Proyecto educativo",
      year: "Referencia de instalación con fotos y videos",
      rooms: "Aulas, recepción, auditorio y espacios escolares",
      finishes: "Mobiliario escolar, instalación y soporte de proyecto.",
      evidence: ["Fotos de instalación", "Proyecto educativo", "Mobiliario escolar", "Soporte en sitio"],
      supportImage: "/assets/hymueble/casos/huntington-auditorium-installation.webp",
    },
  };

  return projects.map((item) => {
    const parts = item.href.split("/").filter(Boolean);
    const sector = parts[1] ?? "hoteles";
    const project = parts[2] ?? item.name.toLowerCase().replaceAll(" ", "-");
    return { params: { sector, project }, props: { item, notes: projectNotes[project as keyof typeof projectNotes] } };
  });
}

const { item, notes } = Astro.props;
const projectKeywordHeading =
  item.sector === "Hotel"
    ? "Referencia de mobiliario hotelero para proyectos"
    : item.sector === "Educación"
      ? "Referencia de mobiliario educativo para proyectos"
      : "Referencia de mobiliario para proyectos B2B";
---
<BaseLayout
  title={`${item.seoTitle ?? `${item.name} | Proyecto`} | Hymueble`}
  description={item.seoDescription ?? `${item.name}: referencia de mobiliario B2B para ${item.sector}.`}
  keywords={item.seoKeywords}
  image={item.detailImage ?? item.image}
>
  <Hero
    eyebrow="Proyecto de referencia"
    title={item.name}
    lead={item.scope}
    image={item.detailImage ?? item.image}
    badgeTitle={item.region}
    badgeText={`${item.sector} · ${notes?.type ?? "Proyecto B2B"}`}
    primaryLabel="Consultar un proyecto similar"
    primaryHref="/contacto/"
    secondaryLabel="Volver a proyectos"
    secondaryHref={`/proyectos/${Astro.params.sector}/`}
  />

  <section class="section alt">
    <div class="container">
      <SectionHead
        eyebrow="Resumen del caso"
        title={projectKeywordHeading}
        text="Este resumen presenta la estructura comercial del caso: sector, región, alcance, tipo de proyecto, acabados y forma de usar la referencia para una nueva cotización."
      />
      <div class="proof-grid">
        <div class="info-card compact">
          <strong>Sector</strong>
          <span>{item.sector}</span>
        </div>
        <div class="info-card compact">
          <strong>Región</strong>
          <span>{item.region}</span>
        </div>
        <div class="info-card compact">
          <strong>Tipo de proyecto</strong>
          <span>{notes?.type ?? "Proyecto B2B"}</span>
        </div>
        <div class="info-card compact">
          <strong>Alcance</strong>
          <span>{notes?.rooms ?? item.scope}</span>
        </div>
        <div class="info-card compact">
          <strong>Entrega</strong>
          <span>{notes?.year ?? "Referencia de proyecto"}</span>
        </div>
        <div class="info-card compact">
          <strong>Acabados y soporte</strong>
          <span>{notes?.finishes ?? "Mobiliario a medida y soporte de proyecto."}</span>
        </div>
      </div>
      {notes?.evidence && (
        <div class="certification-strip case-evidence" aria-label="Evidencia disponible del proyecto">
          {notes.evidence.map((item) => <span>{item}</span>)}
        </div>
      )}
    </div>
  </section>

  <section class="section">
    <div class="container split-band">
      <div>
        <p class="eyebrow">Cómo usar esta referencia</p>
        <h2>Compara tu alcance antes de pedir cotización</h2>
        <p class="section-note">Si tu proyecto tiene espacios o materiales similares, usamos esta referencia para revisar viabilidad, producción, inspección y logística.</p>
        <div class="btn-row section-actions">
          <a class="btn primary" href="/contacto/">Enviar requisitos</a>
          <a class="btn line" href="/fabrica/">Ver capacidad de fábrica</a>
        </div>
      </div>
      <img src={encodeURI(notes?.supportImage ?? item.image)} alt={item.alt ?? item.name} loading="lazy" decoding="async" />
    </div>
  </section>

  <section class="section alt">
    <div class="container">
      <SectionHead
        eyebrow="Proceso"
        title="Del caso de referencia a una propuesta para tu proyecto"
        text="El flujo de trabajo mantiene una secuencia clara para equipos de compras, diseño, construcción y operación."
      />
      <ProcessSteps />
    </div>
  </section>

  <CTA title="¿Quieres cotizar un proyecto parecido?" text="Comparte sector, ciudad, espacios, cantidades y plazo. Te indicamos próximos pasos." />
</BaseLayout>
