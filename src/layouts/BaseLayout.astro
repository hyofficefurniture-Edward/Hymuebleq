---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import CatalogLeadModal from "../components/CatalogLeadModal.astro";
import ShowroomModal from "../components/ShowroomModal.astro";
import { brand } from "../data/site";

interface Props {
  title: string;
  description: string;
  keywords?: string[];
  image?: string;
  canonicalPath?: string;
  type?: "website" | "article";
  noindex?: boolean;
}

const {
  title,
  description,
  keywords,
  image = "/assets/hymueble/generated/home-virtual-showroom-atrium.webp",
  canonicalPath,
  type = "website",
  noindex = false,
} = Astro.props;
const siteUrl = Astro.site ?? new URL("https://hymueble.com");
const canonicalUrl = new URL(canonicalPath ?? Astro.url.pathname, siteUrl).toString();
const imageUrl = new URL(image, siteUrl).toString();
const preloadImage = image.startsWith("http") ? image : encodeURI(image);
const organizationJsonLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: brand.name,
  url: siteUrl.toString(),
  logo: new URL(brand.logo, siteUrl).toString(),
  email: brand.email,
  contactPoint: [
    {
      "@type": "ContactPoint",
      contactType: "sales",
      availableLanguage: ["Spanish", "English"],
      areaServed: "Latin America",
    },
  ],
};
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    {keywords?.length ? <meta name="keywords" content={keywords.join(", ")} /> : null}
    <meta name="robots" content={noindex ? "noindex,nofollow" : "index,follow"} />
    <meta name="theme-color" content="#121D29" />
    <meta name="application-name" content={brand.name} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="preload" as="image" href={preloadImage} type="image/webp" fetchpriority="high" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="alternate icon" href="/favicon.png" type="image/png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta property="og:locale" content="es_419" />
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content={brand.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:alt" content={`${brand.name} - ${description}`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(organizationJsonLd)}></script>
    <title>{title}</title>
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <CatalogLeadModal />
    <ShowroomModal />
    <a class="whatsapp-float" href={brand.whatsapp} target="_blank" rel="noreferrer" aria-label="Hablar por WhatsApp">
      <svg viewBox="0 0 32 32" aria-hidden="true">
        <path d="M16 3.2c-7 0-12.7 5.6-12.7 12.5 0 2.2.6 4.4 1.7 6.3L3.2 28.8l7-1.8c1.8 1 3.8 1.5 5.8 1.5 7 0 12.7-5.6 12.7-12.6S23 3.2 16 3.2Zm0 22.9c-1.8 0-3.5-.5-5-1.4l-.4-.2-4.1 1.1 1.1-4-.3-.4c-1-1.6-1.6-3.4-1.6-5.3 0-5.6 4.6-10.2 10.3-10.2 5.7 0 10.3 4.6 10.3 10.2S21.7 26.1 16 26.1Zm5.6-7.6c-.3-.2-1.8-.9-2.1-1-.3-.1-.5-.2-.7.2-.2.3-.8 1-.9 1.2-.2.2-.3.2-.6.1-.3-.2-1.3-.5-2.5-1.5-.9-.8-1.5-1.8-1.7-2.1-.2-.3 0-.5.1-.6.1-.1.3-.3.5-.5.1-.2.2-.3.3-.5.1-.2.1-.4 0-.5-.1-.2-.7-1.7-1-2.3-.3-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-.3.3-1 1-1 2.5s1.1 2.9 1.2 3.1c.2.2 2.1 3.2 5.1 4.5.7.3 1.3.5 1.7.6.7.2 1.4.2 1.9.1.6-.1 1.8-.7 2-1.4.3-.7.3-1.3.2-1.4-.1-.2-.2-.3-.5-.4Z" />
      </svg>
    </a>
    <script>
      const setupSiteInteractions = () => {
        const menuButton = document.querySelector("[data-menu-button]");
        const navLinks = document.querySelector("[data-nav-links]");
        const catalogModal = document.querySelector<HTMLElement>("[data-catalog-modal]");
        const catalogModalTitle = document.querySelector<HTMLElement>("[data-catalog-modal-title]");
        const catalogModalText = document.querySelector<HTMLElement>("[data-catalog-modal-text]");
        const catalogInterestInput = document.querySelector<HTMLInputElement>("[data-catalog-interest-input]");
        const showroomModal = document.querySelector<HTMLElement>("[data-showroom-modal-shell]");
        const showroomFrame = document.querySelector<HTMLIFrameElement>("[data-showroom-modal-frame]");
        const showroomTitle = document.querySelector<HTMLElement>("[data-showroom-modal-title]");
        const showroomCloseButton = document.querySelector<HTMLButtonElement>(".showroom-modal-close");
        let lastShowroomTrigger: HTMLElement | null = null;

        menuButton?.addEventListener("click", () => {
          navLinks?.classList.toggle("is-open");
          document.body.classList.toggle("menu-open");
        });

        const defaultCatalogTitle = catalogModalTitle?.textContent ?? "Descarga el catálogo de mobiliario";
        const defaultCatalogText = catalogModalText?.textContent ?? "Déjanos tus datos de proyecto y te enviaremos el catálogo adecuado para tu sector.";

        const openCatalogModal = (trigger?: HTMLElement) => {
          const interest = trigger?.dataset.catalogInterest?.trim();
          if (catalogModalTitle) {
            catalogModalTitle.textContent = interest ? `Solicitar catálogo: ${interest}` : defaultCatalogTitle;
          }
          if (catalogModalText) {
            catalogModalText.textContent = interest
              ? "Completa los datos básicos y nuestro equipo sabrá qué material necesitas revisar."
              : defaultCatalogText;
          }
          if (catalogInterestInput) {
            catalogInterestInput.value = interest || "Catálogo general";
          }
          catalogModal?.classList.add("is-open");
          catalogModal?.setAttribute("aria-hidden", "false");
        };

        const closeCatalogModal = () => {
          catalogModal?.classList.remove("is-open");
          catalogModal?.setAttribute("aria-hidden", "true");
        };

        document.querySelectorAll("[data-download-catalog]").forEach((button) => {
          button.addEventListener("click", () => openCatalogModal(button as HTMLElement));
        });

        document.querySelectorAll("[data-modal-close]").forEach((button) => {
          button.addEventListener("click", closeCatalogModal);
        });

        catalogModal?.addEventListener("click", (event) => {
          if (event.target === catalogModal) {
            closeCatalogModal();
          }
        });

        const openShowroomModal = (href: string, title: string) => {
          if (!showroomModal || !showroomFrame || !showroomTitle) return;
          showroomTitle.textContent = title;
          showroomFrame.src = href;
          showroomModal.classList.add("is-open");
          showroomModal.setAttribute("aria-hidden", "false");
          document.body.classList.add("modal-open");
          requestAnimationFrame(() => showroomCloseButton?.focus());
        };

        const closeShowroomModal = () => {
          if (!showroomModal || !showroomFrame) return;
          showroomModal.classList.remove("is-open");
          showroomModal.setAttribute("aria-hidden", "true");
          showroomFrame.src = "about:blank";
          document.body.classList.remove("modal-open");
          lastShowroomTrigger?.focus();
        };

        document.querySelectorAll<HTMLAnchorElement>("[data-showroom-modal]").forEach((link) => {
          link.addEventListener("click", (event) => {
            event.preventDefault();
            lastShowroomTrigger = link;
            openShowroomModal(link.href, link.dataset.showroomTitle ?? link.textContent?.trim() ?? "Showroom virtual Hymueble");
          });
        });

        document.querySelectorAll("[data-showroom-modal-close]").forEach((button) => {
          button.addEventListener("click", closeShowroomModal);
        });

        document.addEventListener("keydown", (event) => {
          if (event.key === "Escape" && showroomModal?.classList.contains("is-open")) {
            closeShowroomModal();
          }
        });

        document.querySelectorAll("form[data-demo-form]").forEach((form) => {
          form.addEventListener("submit", (event) => {
            event.preventDefault();
            form.classList.add("is-sent");
            form.querySelector<HTMLElement>(".form-success")?.focus();
          });
        });

        document.querySelectorAll<HTMLInputElement>("[data-file-input]").forEach((input) => {
          input.addEventListener("change", () => {
            const output = input.closest(".file-upload")?.querySelector<HTMLElement>("[data-file-name]");
            if (!output) return;

            const fileCount = input.files?.length ?? 0;
            if (fileCount === 0) {
              output.textContent = output.dataset.empty ?? "Ningún archivo seleccionado";
            } else if (fileCount === 1) {
              output.textContent = input.files?.[0]?.name ?? "1 archivo seleccionado";
            } else {
              output.textContent = `${fileCount} archivos seleccionados`;
            }
          });
        });

        document.querySelectorAll<HTMLElement>("[data-scroll-rail]").forEach((shell) => {
          const track = shell.querySelector<HTMLElement>("[data-scroll-track]");
          const prevButton = shell.querySelector<HTMLButtonElement>("[data-scroll-prev]");
          const nextButton = shell.querySelector<HTMLButtonElement>("[data-scroll-next]");
          if (!track || !prevButton || !nextButton) return;

          let ticking = false;
          const edgeTolerance = 4;

          const updateRailState = () => {
            const maxScroll = Math.max(0, track.scrollWidth - track.clientWidth);
            const isScrollable = maxScroll > edgeTolerance;
            shell.classList.toggle("is-scrollable", isScrollable);
            prevButton.disabled = !isScrollable || track.scrollLeft <= edgeTolerance;
            nextButton.disabled = !isScrollable || track.scrollLeft >= maxScroll - edgeTolerance;
          };

          const requestRailState = () => {
            if (ticking) return;
            ticking = true;
            requestAnimationFrame(() => {
              ticking = false;
              updateRailState();
            });
          };

          const scrollTrack = (direction: number) => {
            const amount = Math.max(220, track.clientWidth * 0.78);
            track.scrollBy({ left: direction * amount, behavior: "smooth" });
            window.setTimeout(updateRailState, 320);
          };

          prevButton.addEventListener("click", () => scrollTrack(-1));
          nextButton.addEventListener("click", () => scrollTrack(1));
          track.addEventListener("scroll", requestRailState, { passive: true });
          window.addEventListener("load", updateRailState, { once: true });

          if ("ResizeObserver" in window) {
            const observer = new ResizeObserver(requestRailState);
            observer.observe(shell);
            observer.observe(track);
          }
          window.addEventListener("resize", requestRailState);

          updateRailState();
          window.setTimeout(updateRailState, 300);
        });
      };

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", setupSiteInteractions, { once: true });
      } else {
        setupSiteInteractions();
      }
    </script>
  </body>
</html>
