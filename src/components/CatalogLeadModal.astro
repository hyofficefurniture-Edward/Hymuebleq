---
import ContactForm from "./ContactForm.astro";
---
<div class="modal" data-catalog-modal aria-hidden="true">
  <div class="modal-panel" role="dialog" aria-modal="true" aria-label="Solicitar catálogo">
    <div class="modal-head">
      <div>
        <h3 data-catalog-modal-title>Catálogo de muebles para tu proyecto</h3>
        <p data-catalog-modal-text>Catálogo de muebles por sector: déjanos ciudad y alcance para enviarte el material más útil.</p>
      </div>
      <button class="modal-close" type="button" data-modal-close aria-label="Cerrar">×</button>
    </div>
    <div class="form-card">
      <ContactForm compact idPrefix="catalog" submitLabel="Solicitar catálogo" catalogLead />
    </div>
  </div>
</div>
