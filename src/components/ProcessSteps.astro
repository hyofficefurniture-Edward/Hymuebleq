---
import { processSteps } from "../data/site";
import ScrollRail from "./ScrollRail.astro";

const processIcons = [
  `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M7 3h10v18H7z"/><path d="M9.5 7h5"/><path d="M9.5 11h5"/><path d="M9.5 15h2.5"/></svg>`,
  `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 17 17 4l3 3L7 20H4z"/><path d="m14 7 3 3"/><path d="M5 13h4"/></svg>`,
  `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 4h14v16H5z"/><path d="M8 8h8"/><path d="M8 12h5"/><path d="M16 16h.01"/></svg>`,
  `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 15c3-5 7-7 12-6l4 1-1 4c-2 5-6 7-12 6z"/><path d="M8 16c2-2 4-3 7-4"/></svg>`,
  `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 8h14v11H5z"/><path d="M8 8V5h8v3"/><path d="M8 13h8"/><path d="M8 16h5"/></svg>`,
  `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 15h16"/><path d="M7 15V9l5-3 5 3v6"/><path d="M8 18h8"/><path d="M10 12h4"/></svg>`,
  `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3 20 7v5c0 5-3.4 8-8 9-4.6-1-8-4-8-9V7z"/><path d="m8.5 12 2.2 2.2 4.8-5"/></svg>`,
  `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 5h14v14H5z"/><path d="M8 12l2.2 2.2L16 8.5"/><path d="M8 18h8"/></svg>`,
  `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 8 12 4l8 4-8 4z"/><path d="M4 8v8l8 4 8-4V8"/><path d="M12 12v8"/></svg>`,
  `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 16h13V7H3z"/><path d="M16 11h3l2 3v2h-5z"/><path d="M7 19a2 2 0 1 0 0-4 2 2 0 0 0 0 4z"/><path d="M18 19a2 2 0 1 0 0-4 2 2 0 0 0 0 4z"/></svg>`,
  `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3v18"/><path d="M5 10l7-7 7 7"/><path d="M7 21h10"/><path d="M9 14h6"/></svg>`,
  `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M7 7a7 7 0 0 1 12 5v2"/><path d="M5 17v-5a7 7 0 0 1 12-5"/><path d="M4 17h4v4H4z"/><path d="M16 17h4v4h-4z"/><path d="M12 21h4"/></svg>`,
];
---
<ScrollRail label="Proceso de proyecto">
  <div class="process-scroll" data-scroll-track>
    <div class="process">
      {processSteps.map(([title, text], index) => (
        <article class="process-item">
          <div class="process-head">
            <span class="process-number">{String(index + 1).padStart(2, "0")}</span>
            <span class="process-icon" set:html={processIcons[index]} />
          </div>
          <h3>{title}</h3>
          <p>{text}</p>
        </article>
      ))}
    </div>
  </div>
</ScrollRail>
