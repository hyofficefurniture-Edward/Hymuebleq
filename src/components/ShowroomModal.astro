<div class="showroom-modal" data-showroom-modal-shell aria-hidden="true">
  <div class="showroom-modal-backdrop" data-showroom-modal-close></div>
  <section class="showroom-modal-panel" role="dialog" aria-modal="true" aria-labelledby="showroom-modal-title">
    <header class="showroom-modal-head">
      <div>
        <p class="eyebrow">Showroom virtual</p>
        <h2 id="showroom-modal-title" data-showroom-modal-title>Recorrido virtual Hymueble</h2>
      </div>
      <button class="showroom-modal-close" type="button" data-showroom-modal-close aria-label="Cerrar showroom">Cerrar</button>
    </header>
    <div class="showroom-modal-frame">
      <iframe
        data-showroom-modal-frame
        title="Showroom virtual Hymueble"
        src="about:blank"
        allow="xr-spatial-tracking"
        allowfullscreen
        loading="lazy"
      ></iframe>
    </div>
  </section>
</div>
