---
import { formConfig } from "../data/site";

interface Props {
  compact?: boolean;
  idPrefix?: string;
  submitLabel?: string;
  catalogLead?: boolean;
}

const { compact = false, idPrefix = "project", submitLabel = "Enviar mi consulta de proyecto", catalogLead = false } = Astro.props;
const id = (name: string) => `${idPrefix}-${name}`;
const isDemoForm = !formConfig.action;
const statusMessage = isDemoForm
  ? "Modo de vista previa: al enviar, un consultor te contactará en menos de 24 horas por WhatsApp o correo."
  : "¡Muchas gracias! Recibimos tu consulta. En menos de 24 horas un consultor te contactará por WhatsApp o correo.";
---
<form
  class="project-form"
  method="post"
  action={formConfig.action || undefined}
  data-demo-form={isDemoForm ? "" : undefined}
  data-form-purpose="project-inquiry"
>
  <input type="hidden" name="access_key" value={formConfig.accessKey} />
  <input type="hidden" name="subject" value={formConfig.subject} />
  <input type="hidden" name="from_name" value={formConfig.fromName} />
  <input type="checkbox" name="botcheck" style="display: none;" tabindex="-1" aria-hidden="true" />
  <input type="hidden" name="source_path" value={Astro.url.pathname} />
  {catalogLead && <input type="hidden" name="catalog_interest" value="Catálogo general" data-catalog-interest-input />}
  <div class="form-intro full">
    <span>Consulta rápida</span>
    <strong>Cuéntanos lo básico del proyecto.</strong>
    <p>Al enviar, te contactaremos en menos de 24 horas por WhatsApp o correo.</p>
    <p>Si ya tienes planos, lista FF&E, cantidades o fotos de referencia, también puedes compartirlos más abajo.</p>
  </div>
  <div class:list={["field", { full: compact }]}>
    <label for={id("company")}>Nombre o empresa *</label>
    <input id={id("company")} name="company" required placeholder="Tu nombre o empresa" />
  </div>
  <div class:list={["field", { full: compact }]}>
    <label for={id("whatsapp")}>WhatsApp *</label>
    <input id={id("whatsapp")} name="whatsapp" required placeholder="+52 55 0000 0000" />
  </div>
  <div class:list={["field", { full: compact }]}>
    <label for={id("email")}>Correo electrónico (opcional)</label>
    <input id={id("email")} type="email" name="email" placeholder="tucorreo@empresa.com" />
  </div>
  <div class:list={["field", { full: compact }]}>
    <label for={id("location")}>País o ciudad del proyecto *</label>
    <input id={id("location")} name="location" required placeholder="Ej. Ciudad de México, Bogotá" />
  </div>
  <div class:list={["field", { full: compact }]}>
    <label for={id("sector")}>Tipo de proyecto *</label>
    <select id={id("sector")} name="sector" required>
      <option value="">Selecciona un sector</option>
      <option>Hoteles</option>
      <option>Oficinas</option>
      <option>Salud</option>
      <option>Educación</option>
      <option>Residencial</option>
      <option>Otro</option>
    </select>
  </div>
  <div class="field full">
    <label for={id("message")}>Cuéntanos lo básico de tu proyecto</label>
    <textarea id={id("message")} name="message" placeholder="Ej. 80 habitaciones, lobby, restaurante, cantidades aproximadas y fecha de apertura..."></textarea>
  </div>
  <details class="form-optional full">
    <summary>Agregar detalles opcionales</summary>
    <div class="form-section-grid">
      <div class:list={["field", { full: compact }]}>
        <label for={id("spaces")}>Espacios a equipar</label>
        <input id={id("spaces")} name="spaces" placeholder="Habitaciones, lobby, restaurante..." />
      </div>
      <div class:list={["field", { full: compact }]}>
        <label for={id("quantity")}>Cantidad aproximada</label>
        <input id={id("quantity")} name="quantity" placeholder="Ej. 80 habitaciones, 120 puestos" />
      </div>
      <div class:list={["field", { full: compact }]}>
        <label for={id("stage")}>Estado del proyecto</label>
        <select id={id("stage")} name="stage">
          <option value="">Selecciona una etapa</option>
          <option>Idea inicial</option>
          <option>Con planos o lista FF&E</option>
          <option>En cotización</option>
          <option>En construcción o remodelación</option>
          <option>Compra urgente</option>
        </select>
      </div>
      <div class:list={["field", { full: compact }]}>
        <label for={id("timeline")}>Tiempo estimado</label>
        <input id={id("timeline")} name="timeline" placeholder="Ej. apertura en 3 meses" />
      </div>
      <div class:list={["field", { full: compact }]}>
        <label for={id("budget")}>Presupuesto o rango objetivo</label>
        <input id={id("budget")} name="budget" placeholder="Opcional: rango estimado" />
      </div>
    </div>
  </details>
  <p class="privacy">Tu información se usa para atender tu consulta. Consulta nuestra <a href="/privacidad/">política de privacidad</a>.</p>
  <p class="form-followup">Si prefieres, también puedes escribirnos directamente por WhatsApp.</p>
  <div class="form-success" role="status" aria-live="polite" tabindex="-1">{statusMessage}</div>
  <div class="field full">
    <button class="btn primary" type="submit">{submitLabel}</button>
  </div>
</form>
